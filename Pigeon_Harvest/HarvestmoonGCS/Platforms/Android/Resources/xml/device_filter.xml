<?xml version="1.0" encoding="utf-8"?>
<resources>
  <!-- USB Serial Device Filter for MAVLink -->
  <!-- This allows the app to detect common USB-to-Serial adapters -->
  
  <!-- FTDI FT232 (very common for flight controllers) -->
  <usb-device vendor-id="1027" />
  
  <!-- Prolific PL2303 -->
  <usb-device vendor-id="1659" />
  
  <!-- Silicon Labs CP210x -->
  <usb-device vendor-id="4292" />
  
  <!-- CH340/CH341 -->
  <usb-device vendor-id="6790" />
  
  <!-- Arduino (various boards) -->
  <usb-device vendor-id="9025" />
  <usb-device vendor-id="10755" />
  
  <!-- Pixhawk/PX4 -->
  <usb-device vendor-id="9900" />
  
  <!-- Generic CDC ACM devices -->
  <usb-device class="2" />
  
  <!-- Allow all USB devices (fallback) -->
  <!-- Remove this if you want to restrict to specific vendors only -->
  <!-- <usb-device /> -->
</resources>
