<UserControl x:Class="HarvestmoonGCS.Controls.ModernSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="256">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SidebarNavButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButtonStyle}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Margin" Value="6,1"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="4,0,0,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- SidebarRoot width is controlled from code-behind via ApplyCompactMode() -->
    <Grid x:Name="SidebarRoot" Width="180" Background="{ThemeResource SidebarBrush}" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Logo Area — full mode -->
        <StackPanel x:Name="LogoFull" Grid.Row="0" Padding="14" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="EFRISA"
                           FontSize="17"
                           FontWeight="Bold"
                           CharacterSpacing="200"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource ForegroundBrush}"/>
                <TextBlock Text="Politeknik Elektronika Negeri Surabaya"
                           FontSize="8"
                           Foreground="{ThemeResource MutedForegroundBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Margin="0,16,0,0" HorizontalAlignment="Center">
                <Image Source="ms-appx:///Assets/logo/pigeonlogo.png" Height="38" Stretch="Uniform" HorizontalAlignment="Center"/>
                <TextBlock Text="MOONHARVEST"
                           FontWeight="Bold"
                           FontSize="11"
                           CharacterSpacing="100"
                           Foreground="{ThemeResource NavFlightBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <TextBlock Text="Unified GCS"
                           FontSize="9"
                           Foreground="{ThemeResource MutedForegroundBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Logo Area — compact/icon-only mode (shown on Android tablet) -->
        <StackPanel x:Name="LogoCompact" Grid.Row="0" Padding="6,10"
                    BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,0,0,1"
                    Visibility="Collapsed" HorizontalAlignment="Center">
            <Image Source="ms-appx:///Assets/logo/pigeonlogo.png" Height="28" Stretch="Uniform" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Navigation Items -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,8">

                <Button x:Name="FlightNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Dashboard"
                        ToolTipService.ToolTip="Dashboard · Live">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE709;" FontSize="16" Foreground="{ThemeResource NavFlightBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="FlightNavLabel" Grid.Column="1" Text="Dashboard · Live" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="FlightActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="CameraNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Camera"
                        ToolTipService.ToolTip="Camera">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE714;" FontSize="16" Foreground="{ThemeResource NavCameraBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="CameraNavLabel" Grid.Column="1" Text="Camera" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="CameraActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="MapNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="MissionPlanner"
                        ToolTipService.ToolTip="Peta &amp; Misi">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE81D;" FontSize="16" Foreground="{ThemeResource NavMapBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="MapNavLabel" Grid.Column="1" Text="Peta &amp; Misi" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="MapActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="StatsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Stats"
                        ToolTipService.ToolTip="Crop Analysis">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE9D9;" FontSize="16" Foreground="{ThemeResource NavStatsBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="StatsNavLabel" Grid.Column="1" Text="Crop Analysis" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="StatsActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="EdgeModeNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="EdgeMode"
                        ToolTipService.ToolTip="Edge Mode">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE950;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="EdgeModeNavLabel" Grid.Column="1" Text="Edge Mode" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="EdgeModeActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="AISettingsNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="AISettings"
                        ToolTipService.ToolTip="AI Settings">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7C1;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="AISettingsNavLabel" Grid.Column="1" Text="AI Settings" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="AISettingsActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button x:Name="TlogNavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="NavButton_Click" Tag="Tlog"
                        ToolTipService.ToolTip="Reports">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="16" Foreground="{ThemeResource NavTlogBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="TlogNavLabel" Grid.Column="1" Text="Reports" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="TlogActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>

#if !__WASM__
                <!-- PIA AI Assistant Button -->
                <Button x:Name="PIANavButton" Style="{StaticResource SidebarNavButtonStyle}" Click="PIAButton_Click" Visibility="Collapsed"
                        ToolTipService.ToolTip="PIA AI">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7C1;" FontSize="16" Foreground="{ThemeResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock x:Name="PIANavLabel" Grid.Column="1" Text="PIA AI" FontSize="10" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource SidebarForegroundBrush}"/>
                        <Ellipse x:Name="PIAActiveDot" Grid.Column="2" Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}" Opacity="0" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
#endif

            </StackPanel>
        </ScrollViewer>

        <!-- Yolo Option -->
        <Border Grid.Row="2" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,1,0,0" Margin="6,8" Padding="8,10" Tapped="YoloOption_Tapped">
            <Grid>
                <TextBlock x:Name="YoloOptionLabel" Text="Yolo Option" FontSize="10" VerticalAlignment="Center" Foreground="{ThemeResource MutedForegroundBrush}"/>
                <!-- PulseAnimation dinonaktifkan untuk meningkatkan performance -->
                <Ellipse x:Name="YoloOptionStatusDot" HorizontalAlignment="Right" Width="10" Height="10" Fill="{ThemeResource ErrorBrush}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Row="3" BorderBrush="{ThemeResource SidebarBorderBrush}" BorderThickness="0,1,0,0" Padding="16">
            <Grid HorizontalAlignment="Center">
                <Button x:Name="ThemeToggleButton"
                        Width="56"
                        Height="28"
                        Padding="0"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="14"
                        Click="ThemeToggle_Click">
                    <Grid>
                        <Border x:Name="ThemeToggleTrack" CornerRadius="14"/>
                        <Border x:Name="ThemeToggleThumb"
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="2,2,0,0"
                                CornerRadius="12">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ThemeToggleThumbTransform"/>
                            </Border.RenderTransform>
                            <Grid>
                                <FontIcon x:Name="ThemeToggleIcon"
                                          FontSize="14"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
