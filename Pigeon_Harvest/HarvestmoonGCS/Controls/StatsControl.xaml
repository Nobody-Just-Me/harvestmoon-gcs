<UserControl x:Class="HarvestmoonGCS.Controls.StatsControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:HarvestmoonGCS.Controls"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      mc:Ignorable="d"
      d:DesignHeight="615"
      d:DesignWidth="1132"
      Background="{ThemeResource BackgroundBrush}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title and Control Buttons -->
        <Grid Grid.Row="0" Margin="10,5">
            <TextBlock Text="Statistik Data IMU"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="{ThemeResource AccentForegroundBrush}"
                       Margin="0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="5">
                 <Button x:Name="btn_start_stats"
                         Content="▶ Start"
                         Width="80"
                         Height="30"
                         Background="{ThemeResource SuccessBrush}"
                         Foreground="{ThemeResource PrimaryForegroundBrush}"
                         FontWeight="Bold"
                         Click="StartAutoUpdate_Click"/>
                 <Button x:Name="btn_stop_stats"
                         Content="⏸ Stop"
                         Width="80"
                         Height="30"
                         Background="{ThemeResource ErrorBrush}"
                         Foreground="{ThemeResource PrimaryForegroundBrush}"
                         FontWeight="Bold"
                         Click="StopAutoUpdate_Click"
                         IsEnabled="False"/>
                 <Button x:Name="btn_export_csv"
                         Content="📥 Export"
                         Width="90"
                         Height="30"
                         Background="{ThemeResource InfoBrush}"
                         Foreground="{ThemeResource PrimaryForegroundBrush}"
                         FontWeight="Bold"
                         Click="ExportCSV_Click"/>
                 <Button x:Name="btn_reset_stats"
                         Content="🔄 Reset"
                         Width="80"
                         Height="30"
                         Background="{ThemeResource SecondaryBrush}"
                         Foreground="{ThemeResource ForegroundBrush}"
                         FontWeight="Bold"
                         Click="ResetStats_Click"/>
            </StackPanel>
        </Grid>

        <!-- Yaw Chart -->
        <Border Grid.Row="1"
                Margin="10,5,10,5"
                Background="{ThemeResource CardBrush}"
                BorderBrush="{ThemeResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <!-- TODO: Re-enable when LiveChartsCore.SkiaSharpView.WinUI is available -->
                <!-- <lvc:CartesianChart x:Name="chartYaw"
                                    Background="#252526"/> -->
                <TextBlock Text="Chart placeholder - LiveChartsCore not available" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource MutedForegroundBrush}"/>
            </Grid>
        </Border>

        <!-- Pitch/Roll Chart -->
        <Border Grid.Row="2"
                Margin="10,5,10,10"
                Background="{ThemeResource CardBrush}"
                BorderBrush="{ThemeResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <!-- TODO: Re-enable when LiveChartsCore.SkiaSharpView.WinUI is available -->
                <!-- <lvc:CartesianChart x:Name="chartPitchRoll"
                                    Background="#252526"/> -->
                <TextBlock Text="Chart placeholder - LiveChartsCore not available" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource MutedForegroundBrush}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
