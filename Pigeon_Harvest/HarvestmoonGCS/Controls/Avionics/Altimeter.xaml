<UserControl x:Class="HarvestmoonGCS.Controls.Avionics.Altimeter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:SkiaSharp.Views.Windows"
             Width="150" Height="300">
    
    <Grid>
        <!-- SkiaSharp canvas for rendering the altimeter -->
        <skia:SKXamlCanvas x:Name="AltimeterCanvas"
                          PaintSurface="OnPaintSurface"/>
        
        <!-- Digital readout overlay -->
        <Border Background="#CC000000"
                BorderBrush="White"
                BorderThickness="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="10,5"
                CornerRadius="4">
            <TextBlock x:Name="AltitudeText"
                      Text="0"
                      Foreground="Lime"
                      FontWeight="Bold"
                      FontSize="18"
                      FontFamily="Consolas"/>
        </Border>
    </Grid>
</UserControl>
