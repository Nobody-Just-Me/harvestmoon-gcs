<UserControl x:Class="HarvestmoonGCS.Controls.CalibrationControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:HarvestmoonGCS.Controls"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1132"
      x:Name="CalibrationControlRoot">

    <UserControl.Resources>
        <!-- RadioButton Tab Style -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="5"
                                Margin="{TemplateBinding Margin}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#007ACC"/>
                                            <Setter Target="RootBorder.(UIElement.Shadow)">
                                                <Setter.Value>
                                                    <ThemeShadow/>
                                                </Setter.Value>
                                            </Setter>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Command Button Style -->
        <Style x:Key="CommandBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <!-- Settings Label Style -->
        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <!-- Connection Warning Overlay -->
        <Border x:Name="ConnectionWarningOverlay" 
                Visibility="Collapsed" 
                Background="#CC000000" 
                HorizontalAlignment="Stretch" 
                VerticalAlignment="Stretch" 
                Canvas.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <TextBlock Text="Koneksikan dengan wahana sebelum menggunakan fungsi ini." 
                           FontSize="24" FontWeight="Bold" Foreground="White" 
                           TextWrapping="Wrap" TextAlignment="Center"/>
                <Button x:Name="btn_confirm" Content="Konfirmasi" 
                        Click="Konfirmasi_Koneksi" 
                        Style="{StaticResource CommandBtnStyle}" 
                        BorderBrush="Yellow" FontSize="20" 
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid x:Name="func_grid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navbar (Simulated tabs) -->
            <Border Grid.Row="0" Background="#252526" Padding="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" IsChecked="True" Click="Nav_Click" Tag="Accele_calib">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconGyroscope}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Accelerometer" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="Kompass_calib">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconCompass}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Compass" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="Radio_calib">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconRadio}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Radio" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="Flight_mode">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconFlightMode}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Flight Mode" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="ServoOutput">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconServo}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Servo Output" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="EscCalib">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconESC}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="ESC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="MotorTestGrid">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconMotor}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Motor Test" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton GroupName="Nav" Style="{StaticResource NavButtonStyle}" Click="Nav_Click" Tag="Tuning">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{StaticResource IconTuning}" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Tuning" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="20">
                
                <!-- Accelerometer Calibration -->
                <Grid x:Name="Accele_calib" Visibility="Visible" 
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border1" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image1" Source="ms-appx:///Assets/icons/FLIP_UP.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text1" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border2" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image2" Source="ms-appx:///Assets/icons/KIRI.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text2" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border3" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image3" Source="ms-appx:///Assets/icons/KANAN.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text3" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <!-- Row 1 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border4" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image4" Source="ms-appx:///Assets/icons/DOWN.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text4" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border5" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image5" Source="ms-appx:///Assets/icons/UP.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text5" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="20">
                        <Border x:Name="Border6" BorderBrush="Red" BorderThickness="3" 
                                Padding="5" CornerRadius="10" Background="Black">
                            <Image x:Name="Image6" Source="ms-appx:///Assets/icons/FLIP_DOWN.png" Width="120" Height="120"/>
                        </Border>
                        <TextBlock x:Name="Text6" Text="NOT COMPLETED" 
                                   HorizontalAlignment="Center" Margin="5,10,5,0" 
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <!-- Button -->
                    <Button x:Name="AcceleButton" Grid.Row="2" Grid.ColumnSpan="3" 
                            Content="START ACCELEROMETER CALIBRATION" 
                            Style="{StaticResource CommandBtnStyle}" 
                            FontSize="18" Margin="0,20" Width="400"
                            Background="#007ACC" Click="Accele_Click" 
                            HorizontalAlignment="Center"/>

                    <!-- Extra Calibrations -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="3" 
                                Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                        <StackPanel>
                            <Button Content="Simple Accel Cal" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    Width="180" Click="Simpel_Cal_Click"/>
                            <TextBlock x:Name="CalibSimpelMessage" Text="" 
                                       Foreground="#00FF00" HorizontalAlignment="Center" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <Button Content="Calibrate Level" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    Width="180" Click="Levl_Cal_Click"/>
                            <TextBlock x:Name="LevelCalibMessage" Text="" 
                                       Foreground="#00FF00" HorizontalAlignment="Center" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Compass Calibration -->
                <Grid x:Name="Kompass_calib" Visibility="Collapsed" 
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="30">
                        <StackPanel Width="500" Spacing="15">
                            <TextBlock Text="Compass Calibration" FontSize="20" 
                                       FontWeight="Bold" HorizontalAlignment="Center" 
                                       Foreground="White"/>
                            
                            <ListView x:Name="DeviceList" Height="200" Background="#1E1E1E">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Nomer}" Grid.Column="0" 
                                                       Foreground="White" Margin="5"/>
                                            <TextBlock Text="{Binding DevID}" Grid.Column="1" 
                                                       Foreground="White" Margin="5"/>
                                            <TextBlock Text="{Binding DevType}" Grid.Column="2" 
                                                       Foreground="White" Margin="5"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Button Content="Refresh List" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    HorizontalAlignment="Center" 
                                    Click="RefreshCompassList_Click"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <Button x:Name="Start_comp" Content="Start" 
                                        Style="{StaticResource CommandBtnStyle}" 
                                        Background="#007ACC" Click="Start_comp_Click" Width="100"/>
                                <Button x:Name="Accept_comp" Content="Accept" 
                                        Style="{StaticResource CommandBtnStyle}" 
                                        Background="#228B22" Click="Accept_comp_Click" Width="100"/>
                                <Button x:Name="Cancel_comp" Content="Cancel" 
                                        Style="{StaticResource CommandBtnStyle}" 
                                        Background="#D32F2F" Click="Cancel_comp_Click" Width="100"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="Progress 1" Foreground="White"/>
                                <ProgressBar x:Name="progressBar1" Height="20" 
                                             Minimum="0" Maximum="100" Value="0"/>
                                <TextBlock Text="Progress 2" Foreground="White"/>
                                <ProgressBar x:Name="progressBar2" Height="20" 
                                             Minimum="0" Maximum="100" Value="0"/>
                            </StackPanel>
                            
                            <Button x:Name="Reboot_comp" Content="Reboot Vehicle" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    Background="#D9A300" 
                                    HorizontalAlignment="Center" 
                                    Click="Reboot_comp_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>


                <!-- Radio Calibration -->
                <Grid x:Name="Radio_calib" Visibility="Collapsed" 
                      HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="20" MinWidth="600">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="RADIO CALIBRATION" FontSize="22" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="White"/>

                            <ItemsControl Grid.Row="1" x:Name="RadioItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" 
                                                       FontWeight="SemiBold" Foreground="White"/>
                                            
                                            <ProgressBar Grid.Column="1" Value="{Binding Current}" 
                                                         Minimum="900" Maximum="2100" Height="10" 
                                                         Margin="10,0" Background="#3E3E42" Foreground="#007ACC"/>
                                                         
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" 
                                                       FontSize="12" Foreground="#AAAAAA">
                                                <Run Text="Min: "/>
                                                <Run Text="{Binding Min}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" 
                                                       FontSize="12" Foreground="#AAAAAA">
                                                <Run Text="Max: "/>
                                                <Run Text="{Binding Max}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" 
                                                       FontSize="12" FontWeight="Bold" Foreground="White">
                                                <Run Text="Curr: "/>
                                                <Run Text="{Binding Current}"/>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <Button x:Name="CalibrateRadioButton" Content="Calibrate Radio" Grid.Row="2" 
                                    Style="{StaticResource CommandBtnStyle}" Background="#007ACC" 
                                    FontSize="16" Width="200" 
                                    HorizontalAlignment="Center" Margin="0,20,0,0" 
                                    Click="CalibrateRadioButton_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Flight Mode -->
                <Grid x:Name="Flight_mode" Visibility="Collapsed" 
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="FLIGHT MODES" FontSize="22" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="White"/>
                            
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Labels -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode 1:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mode 2:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mode 3:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Mode 4:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Mode 5:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Mode 6:" 
                                           VerticalAlignment="Center" Margin="10" Foreground="White"/>

                                <!-- Dropdowns + Indicators -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode1" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode1" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode2" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode2" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode3" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode3" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode4" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode4" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode5" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode5" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox x:Name="CMB_fmode6" Width="150" Margin="5"/>
                                    <Ellipse x:Name="mode6" Width="20" Height="20" 
                                             Fill="Transparent" Stroke="Gray" StrokeThickness="2" Margin="5"/>
                                </StackPanel>

                                <!-- PWM Ranges -->
                                <TextBlock Text="PWM 0-1230" Grid.Column="2" Grid.Row="0" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                                <TextBlock Text="PWM 1231-1360" Grid.Column="2" Grid.Row="1" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                                <TextBlock Text="PWM 1361-1490" Grid.Column="2" Grid.Row="2" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                                <TextBlock Text="PWM 1491-1620" Grid.Column="2" Grid.Row="3" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                                <TextBlock Text="PWM 1621-1749" Grid.Column="2" Grid.Row="4" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                                <TextBlock Text="PWM 1750+" Grid.Column="2" Grid.Row="5" 
                                           VerticalAlignment="Center" Margin="10,0" Foreground="Gray"/>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                                        Spacing="20" Margin="0,20,0,0" Grid.Row="2">
                                <Button Content="REFRESH MODES" Style="{StaticResource CommandBtnStyle}" 
                                        Background="#E0A800" Click="RefreshModes_Click"/>
                                <Button Content="SAVE MODES" Style="{StaticResource CommandBtnStyle}" 
                                        Background="#007ACC" Click="saveMode_Click" Width="200"/>
                            </StackPanel>
                            <TextBlock x:Name="ModeStatus" Text="" Foreground="#00FF00" 
                                       Grid.Row="3" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        </Grid>
                    </Border>
                </Grid>


                <!-- Servo Output -->
                <ScrollViewer x:Name="ServoOutput" Visibility="Collapsed" 
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="10" Margin="20">
                        <StackPanel>
                            <TextBlock Text="SERVO OUTPUT" FontSize="22" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,20" Foreground="White"/>
                            
                            <!-- Servo Grid Header -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="No" Grid.Column="0" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Reversed" Grid.Column="1" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Function" Grid.Column="2" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Output" Grid.Column="3" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Min" Grid.Column="4" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Trim" Grid.Column="5" FontWeight="Bold" Foreground="White" Margin="5"/>
                                <TextBlock Text="Max" Grid.Column="6" FontWeight="Bold" Foreground="White" Margin="5"/>
                            </Grid>
                            
                            <!-- Servo Items -->
                            <ItemsControl x:Name="ServoItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5" Background="#1E1E1E" Padding="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="{Binding No}" Grid.Column="0" 
                                                       VerticalAlignment="Center" Foreground="White" Margin="5"/>
                                            <CheckBox IsChecked="{Binding Reversed, Mode=TwoWay}" 
                                                      Grid.Column="1" HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            <ComboBox x:Name="FunctionCombo" Grid.Column="2" 
                                                      SelectedValue="{Binding Function, Mode=TwoWay}" 
                                                      HorizontalAlignment="Stretch" Margin="5"/>
                                            <ProgressBar Value="{Binding Output}" Grid.Column="3" 
                                                         Minimum="1000" Maximum="2000" Height="15" 
                                                         Margin="5" Background="#3E3E42" Foreground="#007ACC"/>
                                            <muxc:NumberBox Value="{Binding Min, Mode=TwoWay}" 
                                                            Grid.Column="4" Minimum="0" Maximum="2500" 
                                                            SpinButtonPlacementMode="Compact" Margin="5"/>
                                            <muxc:NumberBox Value="{Binding Trim, Mode=TwoWay}" 
                                                            Grid.Column="5" Minimum="0" Maximum="2500" 
                                                            SpinButtonPlacementMode="Compact" Margin="5"/>
                                            <muxc:NumberBox Value="{Binding Max, Mode=TwoWay}" 
                                                            Grid.Column="6" Minimum="0" Maximum="2500" 
                                                            SpinButtonPlacementMode="Compact" Margin="5"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <Button Content="SEND SERVO PARAMETERS" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    Background="#228B22" HorizontalAlignment="Center" 
                                    Margin="0,20" Click="saveServo_Click"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <!-- ESC Calibration -->
                <Grid x:Name="EscCalib" Visibility="Collapsed" 
                      Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="30" MinWidth="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="ESC Calibration" FontWeight="Bold" FontSize="22" 
                                       Grid.Row="0" HorizontalAlignment="Center" Foreground="White"/>
                            
                            <TextBlock Text="⚠️ Pastikan motor tidak menyentuh tanah!" 
                                       Foreground="Red" FontWeight="Bold" Grid.Row="1" 
                                       HorizontalAlignment="Center" Margin="0,10"/>
                            
                            <Slider x:Name="PwmSlider" Minimum="1000" Maximum="2000" Value="1500" 
                                    Grid.Row="2" Margin="10" TickFrequency="50" 
                                    StepFrequency="50"/>
                            
                            <TextBlock x:Name="PwmValueLabel" Grid.Row="3"
                                       HorizontalAlignment="Center" FontSize="18" 
                                       FontWeight="Bold" Foreground="White">
                                <Run Text="{Binding ElementName=PwmSlider, Path=Value}"/>
                            </TextBlock>
                            
                            <ComboBox x:Name="MotorChannelComboBox" SelectedIndex="0" 
                                      Grid.Row="4" HorizontalAlignment="Center" Width="150" Margin="10">
                                <ComboBoxItem Content="Motor 1" Tag="1"/>
                                <ComboBoxItem Content="Motor 2" Tag="2"/>
                                <ComboBoxItem Content="Motor 3" Tag="3"/>
                                <ComboBoxItem Content="Motor 4" Tag="4"/>
                            </ComboBox>
                            
                            <StackPanel Grid.Row="5" Orientation="Horizontal" 
                                        HorizontalAlignment="Center" Spacing="5">
                                <Button Content="Min" Style="{StaticResource CommandBtnStyle}" 
                                        Width="90" Click="SendMinPwm_Click"/>
                                <Button Content="Mid" Style="{StaticResource CommandBtnStyle}" 
                                        Width="90" Click="SendMidPwm_Click"/>
                                <Button Content="Max" Style="{StaticResource CommandBtnStyle}" 
                                        Width="90" Click="SendMaxPwm_Click"/>
                            </StackPanel>
                            
                            <TextBlock x:Name="StatusLabel" Text="Status: Siap" 
                                       HorizontalAlignment="Center" Grid.Row="6" 
                                       Foreground="#AAAAAA" Margin="10"/>
                            
                            <Button Content="Auto Calibrate All" 
                                    Style="{StaticResource CommandBtnStyle}" 
                                    Background="#FF8C00" Grid.Row="7" 
                                    HorizontalAlignment="Center" Margin="10"
                                    Click="AutoCalibrateAllMotors"/>
                        </Grid>
                    </Border>
                </Grid>


                <!-- Motor Test Grid -->
                <Grid x:Name="MotorTestGrid" Visibility="Collapsed" 
                      Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#252526" BorderBrush="#3E3E42" 
                            BorderThickness="1" CornerRadius="5" Padding="30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Title -->
                            <TextBlock Text="MOTOR TEST" FontWeight="Bold" FontSize="22" 
                                       Grid.Row="0" HorizontalAlignment="Center" 
                                       Foreground="White" Margin="0,0,0,15"/>
                            
                            <!-- Warning -->
                            <Border Grid.Row="1" Background="#B00020" CornerRadius="3" 
                                    Padding="10,5" Margin="0,5" HorizontalAlignment="Center">
                                <TextBlock Text="⚠️ LEPASKAN SEMUA PROPELLER SEBELUM TES!" 
                                           Foreground="White" FontWeight="Bold" FontSize="14" 
                                           HorizontalAlignment="Center"/>
                            </Border>
                            
                            <!-- Throttle and Duration Controls -->
                            <Grid Grid.Row="2" Margin="10,20,10,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Throttle %" Foreground="White" 
                                               FontWeight="Bold" FontSize="14" 
                                               HorizontalAlignment="Center"/>
                                    <Slider x:Name="MotorPwmSlider" Minimum="1000" Maximum="2000" 
                                            Value="1150" TickFrequency="50" 
                                            StepFrequency="50" Margin="5"/>
                                    <TextBlock HorizontalAlignment="Center" 
                                               Foreground="Lime" FontSize="18" FontWeight="Bold">
                                        <Run Text="{Binding ElementName=MotorPwmSlider, Path=Value}"/>
                                        <Run Text=" PWM"/>
                                    </TextBlock>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Duration (sec)" Foreground="White" 
                                               FontWeight="Bold" FontSize="14" 
                                               HorizontalAlignment="Center"/>
                                    <Slider x:Name="MotorDurationSlider" Minimum="1" Maximum="5" 
                                            Value="2" TickFrequency="0.5" 
                                            StepFrequency="0.5" Margin="5"/>
                                    <TextBlock HorizontalAlignment="Center" 
                                               Foreground="Lime" FontSize="18" FontWeight="Bold">
                                        <Run Text="{Binding ElementName=MotorDurationSlider, Path=Value}"/>
                                        <Run Text=" detik"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            
                            <!-- Motor Buttons Layout -->
                            <Grid Grid.Row="3" HorizontalAlignment="Center" Margin="0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Button x:Name="MotorABtn" Grid.Row="0" Grid.Column="2" 
                                        Width="100" Height="60" Margin="5"
                                        Background="#007ACC" Style="{StaticResource CommandBtnStyle}"
                                        Click="TestMotor_Click" Tag="1">
                                    <StackPanel>
                                        <TextBlock Text="Motor A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="(CCW)" FontSize="10" 
                                                   HorizontalAlignment="Center" Foreground="#DDDDDD"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="MotorBBtn" Grid.Row="0" Grid.Column="0" 
                                        Width="100" Height="60" Margin="5"
                                        Background="#007ACC" Style="{StaticResource CommandBtnStyle}"
                                        Click="TestMotor_Click" Tag="2">
                                    <StackPanel>
                                        <TextBlock Text="Motor B" HorizontalAlignment="Center"/>
                                        <TextBlock Text="(CW)" FontSize="10" 
                                                   HorizontalAlignment="Center" Foreground="#DDDDDD"/>
                                    </StackPanel>
                                </Button>
                                
                                <Border Grid.Row="1" Grid.Column="1" 
                                        Background="#3E3E42" CornerRadius="25" 
                                        Width="50" Height="50" Margin="5">
                                    <TextBlock Text="✈" FontSize="24" Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                
                                <Button x:Name="MotorCBtn" Grid.Row="2" Grid.Column="0" 
                                        Width="100" Height="60" Margin="5"
                                        Background="#007ACC" Style="{StaticResource CommandBtnStyle}"
                                        Click="TestMotor_Click" Tag="3">
                                    <StackPanel>
                                        <TextBlock Text="Motor C" HorizontalAlignment="Center"/>
                                        <TextBlock Text="(CCW)" FontSize="10" 
                                                   HorizontalAlignment="Center" Foreground="#DDDDDD"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button x:Name="MotorDBtn" Grid.Row="2" Grid.Column="2" 
                                        Width="100" Height="60" Margin="5"
                                        Background="#007ACC" Style="{StaticResource CommandBtnStyle}"
                                        Click="TestMotor_Click" Tag="4">
                                    <StackPanel>
                                        <TextBlock Text="Motor D" HorizontalAlignment="Center"/>
                                        <TextBlock Text="(CW)" FontSize="10" 
                                                   HorizontalAlignment="Center" Foreground="#DDDDDD"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            
                            <!-- Action Buttons -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" 
                                        HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,10">
                                <Button x:Name="TestAllMotorsBtn" Content="TEST ALL SEQUENCE" 
                                        Width="180" Height="40" Style="{StaticResource CommandBtnStyle}"
                                        Background="#228B22" Click="TestAllMotors_Click"/>
                                <Button x:Name="StopAllMotorsBtn" Content="STOP ALL MOTORS" 
                                        Width="180" Height="40" Style="{StaticResource CommandBtnStyle}"
                                        Background="#B00020" Click="StopAllMotors_Click"/>
                            </StackPanel>
                            
                            <Border Grid.Row="5" Background="#1A1A1A" CornerRadius="3" 
                                    Padding="10" Margin="0,5" VerticalAlignment="Top">
                                <TextBlock x:Name="MotorTestStatus" 
                                           Text="Status: Siap - Pilih motor untuk dites" 
                                           HorizontalAlignment="Center" Foreground="Lime" FontSize="14"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>


                <!-- Tuning -->
                <ScrollViewer x:Name="Tuning" Visibility="Collapsed" 
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" Spacing="20">
                        <!-- Waypoint Settings -->
                        <Border Background="#252526" CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock Text="WAYPOINT SETTINGS" 
                                           Style="{StaticResource SettingsLabelStyle}" 
                                           Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Speed (cm/s)" Foreground="White"/>
                                        <TextBox x:Name="WP_Speed" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Radius (cm)" Foreground="White"/>
                                        <TextBox x:Name="WP_Radius" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Speed Up (cm/s^2)" Foreground="White"/>
                                        <TextBox x:Name="WP_Speedup" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Speed Dn (cm/s^2)" Foreground="White"/>
                                        <TextBox x:Name="WP_Speeddn" Width="80"/>
                                    </StackPanel>
                                    <StackPanel Margin="10">
                                        <TextBlock Text="Loiter Speed (cm/s)" Foreground="White"/>
                                        <TextBox x:Name="WP_Loiter" Width="80"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Copter Tuning -->
                        <Border x:Name="COPTER_MODE" Background="#252526" CornerRadius="5" 
                                Padding="15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="COPTER TUNING" 
                                           Style="{StaticResource SettingsLabelStyle}" 
                                           Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Rate Roll -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="5">
                                        <TextBlock Text="Rate Roll" FontWeight="Bold" 
                                                   Margin="0,0,0,5" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="RollPTextBox" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="RollITextBox" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="RollDTextBox" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="RollIMAXTextBox" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTE" Grid.Row="4" Foreground="White"/> 
                                            <TextBox x:Name="RollFLTETextBox" Grid.Row="4" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTD" Grid.Row="5" Foreground="White"/> 
                                            <TextBox x:Name="RollFLTDTextBox" Grid.Row="5" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTT" Grid.Row="6" Foreground="White"/> 
                                            <TextBox x:Name="RollFLTTTextBox" Grid.Row="6" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Rate Pitch -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                                        <TextBlock Text="Rate Pitch" FontWeight="Bold" 
                                                   Margin="0,0,0,5" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="PitchPTextBox" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="PitchITextBox" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="PitchDTextBox" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="PitchIMAXTextBox" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTE" Grid.Row="4" Foreground="White"/> 
                                            <TextBox x:Name="PitchFLTETextBox" Grid.Row="4" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTD" Grid.Row="5" Foreground="White"/> 
                                            <TextBox x:Name="PitchFLTDTextBox" Grid.Row="5" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTT" Grid.Row="6" Foreground="White"/> 
                                            <TextBox x:Name="PitchFLTTTextBox" Grid.Row="6" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Rate Yaw -->
                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="5">
                                        <TextBlock Text="Rate Yaw" FontWeight="Bold" 
                                                   Margin="0,0,0,5" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="YawPTextBox" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="YawITextBox" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="YawDTextBox" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="YawIMAXTextBox" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTE" Grid.Row="4" Foreground="White"/> 
                                            <TextBox x:Name="YawFLTETextBox" Grid.Row="4" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTD" Grid.Row="5" Foreground="White"/> 
                                            <TextBox x:Name="YawFLTDTextBox" Grid.Row="5" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="FLTT" Grid.Row="6" Foreground="White"/> 
                                            <TextBox x:Name="YawFLTTTextBox" Grid.Row="6" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" 
                                                Orientation="Horizontal" HorizontalAlignment="Center" 
                                                Spacing="20" Margin="0,20,0,0">
                                        <Button Content="REFRESH PARAMS" 
                                                Style="{StaticResource CommandBtnStyle}" 
                                                Background="#E0A800" Click="RefreshCopter_Click"/>
                                        <Button Content="SAVE COPTER TUNING" 
                                                Style="{StaticResource CommandBtnStyle}" 
                                                Background="#007ACC" Click="saveCopter_Click"/>
                                    </StackPanel>
                                    
                                    <TextBlock x:Name="CopterStatus" Text="" Foreground="#00FF00" 
                                               Grid.Row="2" Grid.ColumnSpan="3" 
                                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Plane Tuning -->
                        <Border x:Name="PLANE_MODE" Background="#252526" CornerRadius="5" 
                                Padding="15" Visibility="Visible">
                            <StackPanel>
                                <TextBlock Text="PLANE / VTOL TUNING" 
                                           Style="{StaticResource SettingsLabelStyle}" 
                                           Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <!-- Roll -->
                                    <StackPanel Width="200" Margin="10">
                                        <TextBlock Text="Roll PID" FontWeight="Bold" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="PRollPTextBox" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="PRollITextBox" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="PRollDTextBox" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="PRollIMAXTextBox" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>
                                    <!-- Pitch -->
                                    <StackPanel Width="200" Margin="10">
                                        <TextBlock Text="Pitch PID" FontWeight="Bold" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="PPitchPTextBox" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="PPitchITextBox" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="PPitchDTextBox" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="PPitchIMAXTextBox" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>
                                    <!-- Velocity XY -->
                                    <StackPanel Width="200" Margin="10">
                                        <TextBlock Text="Velocity XY" FontWeight="Bold" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="P" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="VelP" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="I" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="VelI" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="D" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="VelD" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="IMAX" Grid.Row="3" Foreground="White"/> 
                                            <TextBox x:Name="VelIMAX" Grid.Row="3" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>
                                    <!-- Limits -->
                                    <StackPanel Width="200" Margin="10">
                                        <TextBlock Text="Limits / Safety" FontWeight="Bold" Foreground="White"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Pitch Min" Grid.Row="0" Foreground="White"/> 
                                            <TextBox x:Name="PitchMin" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="Pitch Max" Grid.Row="1" Foreground="White"/> 
                                            <TextBox x:Name="PitchMax" Grid.Row="1" Grid.Column="1" Margin="2"/>
                                            <TextBlock Text="Roll Lim" Grid.Row="2" Foreground="White"/> 
                                            <TextBox x:Name="RollLimit" Grid.Row="2" Grid.Column="1" Margin="2"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                                            Spacing="20" Margin="0,20,0,0">
                                    <Button Content="REFRESH PARAMS" 
                                            Style="{StaticResource CommandBtnStyle}" 
                                            Background="#E0A800" Click="RefreshPlane_Click"/>
                                    <Button Content="SAVE QPLANE" 
                                            Style="{StaticResource CommandBtnStyle}" 
                                            Background="#007ACC" Click="saveQplane_Click"/>
                                    <Button Content="SAVE SAFETY" 
                                            Style="{StaticResource CommandBtnStyle}" 
                                            Background="#007ACC" Click="saveSafety_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="PlaneStatus" Text="" Foreground="#00FF00" 
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
