<Page x:Class="HarvestmoonGCS.Views.AIHarvestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Model" Style="{StaticResource TitleStyle}"/>

                        <TextBlock Text="ONNX model" Style="{StaticResource LabelStyle}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModelComboBox" SelectedIndex="0" SelectionChanged="ModelComboBox_SelectionChanged"/>
                            <Button Grid.Column="1" Content="Browse" Padding="12,6" Click="BrowseModelButton_Click"/>
                        </Grid>

                        <TextBlock Text="Class file" Style="{StaticResource LabelStyle}"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ClassFileTextBox" Text="classes-crop-weed.txt"/>
                            <Button Grid.Column="1" Content="Browse" Padding="12,6" Click="BrowseClassButton_Click"/>
                        </Grid>

                        <TextBlock Text="Performance mode" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="PerformanceModeComboBox" SelectedIndex="1" SelectionChanged="PerformanceModeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Fast (cepat, akurasi rendah)"/>
                            <ComboBoxItem Content="Balanced"/>
                            <ComboBoxItem Content="Accurate (lambat, akurasi tinggi)"/>
                        </ComboBox>

                        <TextBlock x:Name="ConfidenceLabelText" Text="Confidence threshold 40%" Style="{StaticResource LabelStyle}"/>
                        <Slider x:Name="ConfidenceSlider" Minimum="10" Maximum="100" Value="40" ValueChanged="RuntimeSlider_ValueChanged"/>

                        <TextBlock x:Name="NmsLabelText" Text="NMS threshold 40%" Style="{StaticResource LabelStyle}"/>
                        <Slider x:Name="NmsSlider" Minimum="10" Maximum="100" Value="40" ValueChanged="RuntimeSlider_ValueChanged"/>

                        <CheckBox Content="INT8 quantization (Android)" IsChecked="True"/>
                        <TextBlock Text="Mencegah bottleneck pada perangkat mid-range" Style="{StaticResource LabelStyle}" Margin="20,-6,0,0"/>
                        <CheckBox Content="Zero-Internet Edge AI" IsChecked="True"/>
                        <TextBlock Text="Inferensi sepenuhnya offline pada GCS lokal" Style="{StaticResource LabelStyle}" Margin="20,-6,0,0"/>
                        <Button x:Name="ApplyRuntimeButton"
                                Content="Apply Runtime Settings"
                                Background="{ThemeResource PrimaryBrush}"
                                Foreground="White"
                                Padding="14,8"
                                HorizontalAlignment="Left"
                                Click="ApplyRuntimeButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Test Inference" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Jalankan model pada sample frame sebelum dipakai di misi." Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="RunTestButton" Content="Run Test" Background="{ThemeResource PrimaryBrush}" Foreground="White" Padding="14,8" Click="RunTestButton_Click"/>
                            <Button x:Name="BenchmarkButton" Content="Benchmark FPS" Padding="14,8" Click="BenchmarkButton_Click"/>
                            <Button x:Name="UploadFrameButton" Content="Upload Frame" Padding="14,8" Click="UploadFrameButton_Click"/>
                            <Button Content="Use Camera Page" Padding="14,8" Click="UseCameraButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="SelectedFrameText"
                                   Text="Frame: sample lokal"
                                   Style="{StaticResource LabelStyle}"
                                   TextWrapping="Wrap"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TestStatusValue" Text="Ready" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Latency" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="LatencyValue" Text="-" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Detections" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="DetectionValue" Text="-" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status" Style="{StaticResource TitleStyle}"/>
                        <Grid>
                            <TextBlock Text="Model loaded" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="#332E7D32" BorderBrush="#662E7D32" BorderThickness="1" Padding="8,2" CornerRadius="5">
                                <TextBlock x:Name="RuntimeStatusText" Text="Ready" FontSize="11" Foreground="#2E7D32"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Backend" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="#331976D2" BorderBrush="#661976D2" BorderThickness="1" Padding="8,2" CornerRadius="5">
                            <TextBlock Text="YOLOv8n · OpenCV preprocessing" FontSize="11" Foreground="#1976D2"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Classes" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="{ThemeResource MutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="8,2" CornerRadius="5">
                                <TextBlock x:Name="ClassCountText" Text="2" FontSize="11" Foreground="{ThemeResource ForegroundBrush}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Class Labels" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="ClassLabelsItems">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" Background="#EEF9EE" BorderBrush="#C8E6C9" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#2E7D32"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
