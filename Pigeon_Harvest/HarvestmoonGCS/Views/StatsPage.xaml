<Page x:Class="HarvestmoonGCS.Views.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Analisis Citra UAV" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Pilih citra UAV untuk menghasilkan zona defisit air, statistik per petak, rekomendasi irigasi, dan laporan." Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="ImagePathTextBox" PlaceholderText="Path citra UAV (.jpg/.png)"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Pilih Citra" Padding="14,8" Click="BrowseImageButton_Click"/>
                            <Button Content="Run Analysis" Padding="14,8" Background="{ThemeResource PrimaryBrush}" Foreground="White" Click="RunAnalysisButton_Click"/>
                            <Button Content="Export JSON" Padding="14,8" Click="ExportJsonButton_Click"/>
                            <Button Content="Export CSV" Padding="14,8" Click="ExportCsvButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="AnalysisStatusText" Text="Belum ada analisis dijalankan." Style="{StaticResource LabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Distribusi Kondisi Lahan" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Kanopi sehat" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="HealthyDistributionText" Grid.Column="1" Text="0%" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                        </Grid>
                        <Border Height="8" Background="{ThemeResource MutedBrush}" CornerRadius="4"><Border x:Name="HealthyDistributionBar" Width="4" HorizontalAlignment="Left" Background="#2E7D32" CornerRadius="4"/></Border>

                        <Grid Margin="0,10,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Stress kuning" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="StressDistributionText" Grid.Column="1" Text="0%" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                        </Grid>
                        <Border Height="8" Background="{ThemeResource MutedBrush}" CornerRadius="4"><Border x:Name="StressDistributionBar" Width="4" HorizontalAlignment="Left" Background="#FBC02D" CornerRadius="4"/></Border>

                        <Grid Margin="0,10,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Kekeringan coklat" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="DroughtDistributionText" Grid.Column="1" Text="0%" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                        </Grid>
                        <Border Height="8" Background="{ThemeResource MutedBrush}" CornerRadius="4"><Border x:Name="DroughtDistributionBar" Width="4" HorizontalAlignment="Left" Background="#FB8C00" CornerRadius="4"/></Border>

                        <Grid Margin="0,10,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Tanah terbuka/retak" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="BareSoilDistributionText" Grid.Column="1" Text="0%" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                        </Grid>
                        <Border Height="8" Background="{ThemeResource MutedBrush}" CornerRadius="4"><Border x:Name="BareSoilDistributionBar" Width="4" HorizontalAlignment="Left" Background="#795548" CornerRadius="4"/></Border>

                        <Grid Margin="0,10,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Deteksi YOLOv8n" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="YoloDistributionText" Grid.Column="1" Text="0 box" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                        </Grid>
                        <Border Height="8" Background="{ThemeResource MutedBrush}" CornerRadius="4"><Border x:Name="YoloDistributionBar" Width="4" HorizontalAlignment="Left" Background="#1976D2" CornerRadius="4"/></Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Titik Zona Prioritas Irigasi" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <TextBlock Text="Zona ini berasal dari analisis YOLOv8n + HSV dan dipetakan ke koordinat estimasi citra UAV." Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Priority" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="Zone" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="2" Text="GPS" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="3" Text="Severity" Style="{StaticResource LabelStyle}"/>
                        </Grid>

                        <ItemsControl x:Name="PriorityZonesItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding PriorityText}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ZoneText}" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CoordinateText}" FontSize="12" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                        <Border Grid.Column="3" Padding="8,2" CornerRadius="5" Background="#33D32F2F" BorderBrush="#66D32F2F" BorderThickness="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Severity}" FontSize="11" Foreground="#D32F2F"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="PriorityZonesEmptyText" Text="Jalankan analisis untuk membuat titik zona irigasi." Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Filter" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Kategori" Style="{StaticResource LabelStyle}"/>
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Semua"/>
                            <ComboBoxItem Content="Pest"/>
                            <ComboBoxItem Content="Crop Stress"/>
                            <ComboBoxItem Content="Dry Soil"/>
                            <ComboBoxItem Content="Irrigation"/>
                            <ComboBoxItem Content="Healthy"/>
                        </ComboBox>
                        <TextBlock Text="Prioritas" Style="{StaticResource LabelStyle}"/>
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Semua"/>
                            <ComboBoxItem Content="High"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="Low"/>
                        </ComboBox>
                        <TextBlock Text="Min confidence 70%" Style="{StaticResource LabelStyle}"/>
                        <Slider Minimum="0" Maximum="100" Value="70"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Ringkasan" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0,0,4,4" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}"><StackPanel><TextBlock Text="Total deteksi" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="TotalDetectionText" Text="47" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/></StackPanel></Border>
                            <Border Grid.Column="1" Margin="4,0,0,4" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}"><StackPanel><TextBlock Text="Confidence rata" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="AverageConfidenceText" Text="86%" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/></StackPanel></Border>
                            <Border Grid.Column="0" Margin="0,4,4,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}"><StackPanel><TextBlock Text="Area terdampak" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="ImpactAreaText" Text="0.9 ha" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/></StackPanel></Border>
                            <Border Grid.Column="1" Margin="4,4,0,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}"><StackPanel><TextBlock Text="Prioritas tinggi" Style="{StaticResource LabelStyle}"/><TextBlock x:Name="HighPriorityText" Text="2" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/></StackPanel></Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Rekomendasi Aksi" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <Border Margin="0,0,0,6" Padding="8" CornerRadius="6" BorderBrush="#D32F2F" BorderThickness="3,0,0,0" Background="#FFF6F6"><TextBlock x:Name="RecommendationOneText" Text="Inspeksi sektor B3 — kluster hama terdeteksi" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/></Border>
                        <Border Margin="0,0,0,6" Padding="8" CornerRadius="6" BorderBrush="#FBC02D" BorderThickness="3,0,0,0" Background="#FFFDF5"><TextBlock x:Name="RecommendationTwoText" Text="Cek irigasi pada lahan timur" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/></Border>
                        <Border Padding="8" CornerRadius="6" BorderBrush="#1976D2" BorderThickness="3,0,0,0" Background="#F5F9FF"><TextBlock x:Name="RecommendationThreeText" Text="Aplikasi pestisida terarah pada titik prioritas" FontSize="12" Foreground="{ThemeResource ForegroundBrush}"/></Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Validasi Kelembaban Tanah" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Masukkan sampel ground-truth format: row,col,moisture%. Contoh: 0,1,28" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="GroundTruthSamplesTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="96"
                                 Text="0,0,28&#x0a;1,2,42&#x0a;2,1,31"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Validasi" Padding="14,8" Background="{ThemeResource PrimaryBrush}" Foreground="White" Click="ValidateGroundTruthButton_Click"/>
                            <Button Content="Template" Padding="14,8" Click="GroundTruthTemplateButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="ValidationStatusText" Text="Belum ada validasi." Style="{StaticResource LabelStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
