<UserControl
    x:Class="HarvestmoonGCS.Views.TlogControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HarvestmoonGCS.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="720"
    d:DesignWidth="1200">

    <Grid Background="{ThemeResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource WindowColor2}">
            <TextBlock x:Name="judul_tlog" Text="TLOG Player" HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Foreground="{ThemeResource ForegroundBrush}" FontSize="24" FontFamily="{StaticResource CommandoFont}"/>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- File Selection -->
            <Border Grid.Row="0" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="2" Padding="15" Background="{ThemeResource CardBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="lbl_file" Text="File TLOG:" Grid.Column="0" VerticalAlignment="Center" 
                                   FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBox x:Name="txt_filepath" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" 
                                 IsReadOnly="True" Padding="5" FontFamily="{StaticResource RalewayFont}"
                                 Text="{Binding FilePath, Mode=OneWay}"/>
                        <Button x:Name="btn_open_file" Content="Buka File" Grid.Column="2" Padding="15,5" 
                                Command="{Binding OpenFileCommand}" FontFamily="{StaticResource RalewayFont}" 
                                FontWeight="Bold" Background="{ThemeResource InfoBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderThickness="0"/>
                    </Grid>

                    <!-- Log Info -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                            <TextBlock x:Name="lbl_duration" Text="Durasi:" FontFamily="{StaticResource RalewayFont}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="val_duration" Text="{Binding TotalDuration, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,30,0">
                            <TextBlock x:Name="lbl_packets" Text="Total Paket:" FontFamily="{StaticResource RalewayFont}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="val_packets" Text="{Binding TotalPackets, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="lbl_start_time" Text="Waktu Mulai:" FontFamily="{StaticResource RalewayFont}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="val_start_time" Text="{Binding StartTime, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Playback Info Display -->
            <Border Grid.Row="2" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="2" Background="{ThemeResource CardBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lbl_playback_info" Text="Informasi Playback" Grid.Row="0" 
                               HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" 
                               FontFamily="{StaticResource RalewayFont}" Margin="0,10,0,5"/>

                    <TextBlock x:Name="txt_playback_status" Grid.Row="1" Margin="20" TextWrapping="Wrap" 
                               VerticalAlignment="Top" FontFamily="{StaticResource RalewayFont}"
                               Text="{Binding PlaybackStatus, Mode=OneWay}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Playback Controls -->
        <Grid Grid.Row="2" Background="{ThemeResource SecondaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Timeline -->
            <Grid Grid.Row="0" Margin="20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Time Display -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock x:Name="val_current_time" Text="{Binding CurrentTime, Mode=OneWay}" HorizontalAlignment="Left" 
                               FontFamily="Consolas" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="/ " FontFamily="Consolas" FontSize="16"/>
                        <TextBlock x:Name="val_total_time" Text="{Binding TotalDuration, Mode=OneWay}" FontFamily="Consolas" FontSize="16"/>
                    </StackPanel>
                </Grid>

                <!-- Timeline Slider -->
                <Slider x:Name="slider_timeline" Grid.Row="1" Minimum="0" Maximum="100" 
                        Value="{Binding Progress, Mode=TwoWay}"
                        PointerPressed="Slider_PointerPressed"
                        PointerReleased="Slider_PointerReleased"
                        IsEnabled="{Binding IsFileLoaded, Mode=OneWay}" Height="30" VerticalAlignment="Center"/>
            </Grid>

            <!-- Control Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button x:Name="btn_play" Content="▶ Play" Padding="20,8" Margin="5" Command="{Binding PlayCommand}" 
                        IsEnabled="{Binding CanPlay, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" 
                        FontWeight="Bold" Background="{ThemeResource SuccessBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderThickness="0" FontSize="14"/>
                <Button x:Name="btn_pause" Content="⏸ Pause" Padding="20,8" Margin="5" Command="{Binding PauseCommand}" 
                        IsEnabled="{Binding CanPause, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" 
                        FontWeight="Bold" Background="{ThemeResource WarningBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderThickness="0" FontSize="14"/>
                <Button x:Name="btn_stop" Content="⏹ Stop" Padding="20,8" Margin="5" Command="{Binding StopCommand}" 
                        IsEnabled="{Binding CanStop, Mode=OneWay}" FontFamily="{StaticResource RalewayFont}" 
                        FontWeight="Bold" Background="{ThemeResource ErrorBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderThickness="0" FontSize="14"/>

                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_speed" Text="Kecepatan:" VerticalAlignment="Center" 
                               FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" Margin="0,0,5,0"/>
                    <ComboBox x:Name="cb_speed" Width="80" Margin="5,0" VerticalAlignment="Center" 
                              SelectedIndex="{Binding SpeedIndex, Mode=TwoWay}"
                              IsEnabled="{Binding IsFileLoaded, Mode=OneWay}"
                              FontFamily="{StaticResource RalewayFont}">
                        <ComboBoxItem Content="0.5x"/>
                        <ComboBoxItem Content="1x"/>
                        <ComboBoxItem Content="2x"/>
                        <ComboBoxItem Content="5x"/>
                        <ComboBoxItem Content="10x"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
