<ContentDialog
    x:Class="HarvestmoonGCS.Views.ConnectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    BorderThickness="0"
    CornerRadius="16"
    x:Name="RootDialog">

    <ContentDialog.Resources>
        <LinearGradientBrush x:Key="IdleHeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2563EB" Offset="0"/>
            <GradientStop Color="#9333EA" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="ConnectingHeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3B82F6" Offset="0"/>
            <GradientStop Color="#22D3EE" Offset="0.5"/>
            <GradientStop Color="#3B82F6" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveTabButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush20}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource PrimaryBrush}"/>
        </Style>
    </ContentDialog.Resources>

    <Grid Background="{ThemeResource CardBrush}" 
          BorderBrush="{ThemeResource BorderBrush}" 
          BorderThickness="1"
          CornerRadius="16"
          Width="448"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header accent line -->
        <Rectangle x:Name="HeaderAccentLine" 
                   Height="4" 
                   Grid.Row="0" 
                   Fill="{StaticResource IdleHeaderGradient}" 
                   HorizontalAlignment="Stretch"/>

        <Grid Grid.Row="1" Padding="24">
            <StackPanel Spacing="24">
                <!-- Title Section -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border x:Name="TitleIconBorder"
                            Width="36" Height="36" 
                            CornerRadius="10" 
                            Background="{ThemeResource PrimaryBrush20}" 
                            BorderBrush="{ThemeResource PrimaryBrush}" 
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <FontIcon x:Name="TitleIcon" 
                                  Glyph="{StaticResource IconPlug}" 
                                  FontSize="18" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource PrimaryBrush}"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="MAVLink Connection" 
                                   FontWeight="Bold" 
                                   FontSize="16"
                                   Foreground="{ThemeResource ForegroundBrush}"/>
                        <TextBlock x:Name="StatusSubtitle" 
                                   Text="Configure &amp; connect to your UAV" 
                                   FontSize="12" 
                                   Foreground="{ThemeResource MutedForegroundBrush}"/>
                    </StackPanel>
                    
                    <Button Grid.Column="2" 
                            FontSize="14"
                            Padding="0"
                            Width="32" Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{ThemeResource MutedForegroundBrush}"
                            Click="CancelButton_Click">
                        <FontIcon Glyph="{StaticResource IconClose}" FontSize="12"/>
                    </Button>
                </Grid>

                <!-- Connection Type Tabs -->
                <!-- Connecting progress -->
                <StackPanel x:Name="ConnectingProgressPanel" Spacing="8" Visibility="Collapsed">
                    <ProgressBar x:Name="ConnectProgressBar" 
                                 Height="4" 
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="{ThemeResource PrimaryBrush}"
                                 Background="{ThemeResource MutedBrush}"/>
                    <Grid>
                        <TextBlock Text="Establishing link..." FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="ProgressPercentage" Text="0%" FontSize="10" HorizontalAlignment="Right" Foreground="{ThemeResource MutedForegroundBrush}"/>
                    </Grid>
                </StackPanel>

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="UdpTab" Grid.Column="0" Style="{StaticResource ActiveTabButtonStyle}" Click="TypeTab_Click" Tag="UDP">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="{StaticResource IconSatellite}" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="UDP" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="TcpTab" Grid.Column="1" Style="{StaticResource TabButtonStyle}" Click="TypeTab_Click" Tag="TCP">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="{StaticResource IconNavigation}" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="TCP" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="SerialTab" Grid.Column="2" Style="{StaticResource TabButtonStyle}" Click="TypeTab_Click" Tag="Serial">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <FontIcon Glyph="{StaticResource IconPlug}" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="SERIAL" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Form Fields -->
                <StackPanel x:Name="FormFieldsStack" Spacing="16">
                    <!-- Host/IP Section (Visible for UDP/TCP) -->
                    <StackPanel x:Name="NetworkFields" Spacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="HOST / IP ADDRESS" 
                                       FontSize="10" 
                                       FontWeight="Bold" 
                                       Foreground="{ThemeResource MutedForegroundBrush}"/>
                            <TextBox x:Name="HostTextBox" 
                                     Text="127.0.0.1" 
                                     PlaceholderText="127.0.0.1"
                                     Background="{ThemeResource BackgroundBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}"
                                     FontSize="14"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="PORT" 
                                       FontSize="10" 
                                       FontWeight="Bold" 
                                       Foreground="{ThemeResource MutedForegroundBrush}"/>
                            <TextBox x:Name="PortTextBox" 
                                     Text="14550" 
                                     PlaceholderText="14550"
                                     Background="{ThemeResource BackgroundBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}"
                                     FontSize="14"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Serial Section (Visible for Serial) -->
                    <StackPanel x:Name="SerialFields" Spacing="8" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SERIAL PORT" 
                                           FontSize="10" 
                                           FontWeight="Bold" 
                                           Foreground="{ThemeResource MutedForegroundBrush}"/>
                                <Button Grid.Column="1"
                                        x:Name="RefreshPortsButton"
                                        Content="Refresh"
                                        FontSize="10"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        CornerRadius="6"
                                        Background="{ThemeResource MutedBrush}"
                                        Foreground="{ThemeResource MutedForegroundBrush}"
                                        BorderThickness="0"
                                        Click="RefreshPortsButton_Click" />
                            </Grid>
                            <ComboBox x:Name="SerialPortComboBox" 
                                      HorizontalAlignment="Stretch"
                                      Background="{ThemeResource BackgroundBrush}"
                                      BorderBrush="{ThemeResource BorderBrush}"
                                      FontSize="14"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="BAUD RATE" 
                                       FontSize="10" 
                                       FontWeight="Bold" 
                                       Foreground="{ThemeResource MutedForegroundBrush}"/>
                            <ComboBox x:Name="BaudRateComboBox" 
                                      HorizontalAlignment="Stretch"
                                      Background="{ThemeResource BackgroundBrush}"
                                      BorderBrush="{ThemeResource BorderBrush}"
                                      FontSize="14"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True">
                                <x:Int32>9600</x:Int32>
                                <x:Int32>19200</x:Int32>
                                <x:Int32>38400</x:Int32>
                                <x:Int32>57600</x:Int32>
                                <x:Int32>115200</x:Int32>
                                <x:Int32>230400</x:Int32>
                                <x:Int32>460800</x:Int32>
                                <x:Int32>921600</x:Int32>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Quick Presets -->
                <StackPanel x:Name="PresetsPanel" Spacing="8">
                    <TextBlock Text="QUICK PRESETS" 
                               FontSize="10" 
                               FontWeight="Bold" 
                               Foreground="{ThemeResource MutedForegroundBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="SITL" FontSize="10" FontWeight="Bold" Padding="10,4" CornerRadius="6" Background="{ThemeResource MutedBrush}" Foreground="{ThemeResource MutedForegroundBrush}" BorderThickness="0" Click="Preset_Click" Tag="SITL"/>
                        <Button Content="GCS RELAY" FontSize="10" FontWeight="Bold" Padding="10,4" CornerRadius="6" Background="{ThemeResource MutedBrush}" Foreground="{ThemeResource MutedForegroundBrush}" BorderThickness="0" Click="Preset_Click" Tag="GCS"/>
                        <Button Content="TELEMETRY" FontSize="10" FontWeight="Bold" Padding="10,4" CornerRadius="6" Background="{ThemeResource MutedBrush}" Foreground="{ThemeResource MutedForegroundBrush}" BorderThickness="0" Click="Preset_Click" Tag="TELEMETRY"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="CancelButton" 
                            Grid.Column="0" 
                            HorizontalAlignment="Stretch"
                            Padding="16,10"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource BorderBrush}"
                            Background="Transparent"
                            Foreground="{ThemeResource MutedForegroundBrush}"
                            Click="CancelButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="{StaticResource IconClose}" FontSize="14"/>
                            <TextBlock Text="Cancel" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                            
                    <Button x:Name="ConnectButton" 
                            Grid.Column="1" 
                            HorizontalAlignment="Stretch"
                            Padding="16,10"
                            CornerRadius="12"
                            Background="{ThemeResource PrimaryBrush}"
                            Foreground="{ThemeResource PrimaryForegroundBrush}"
                            Click="ConnectButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock x:Name="ConnectButtonText" Text="Connect" FontWeight="SemiBold"/>
                            <FontIcon x:Name="ConnectButtonIcon" Glyph="{StaticResource IconPlug}" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>
