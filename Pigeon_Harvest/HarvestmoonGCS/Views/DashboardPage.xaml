<Page
    x:Class="HarvestmoonGCS.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:HarvestmoonGCS.Controls"
    mc:Ignorable="d"
    Background="#F5FBF6">

    <Page.Resources>
        <!-- Card container (matching ui harvest Card: rounded-2xl border border-emerald-100) -->
        <Style x:Key="HarvestCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1E7D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <!-- Card header bar -->
        <Style x:Key="HarvestCardHeaderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5F3E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Pill styles per tone -->
        <Style x:Key="PillSuccessStyle" TargetType="Border">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillInfoStyle" TargetType="Border">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillCriticalStyle" TargetType="Border">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillWarningStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFBEB"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>

        <!-- HUD pill (dark) for video overlay -->
        <Style x:Key="HudPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#8C000000"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Outline button -->
        <Style x:Key="HarvestOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#166534"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="HarvestPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Hud action button -->
        <Style x:Key="HudActionButton" TargetType="Button">
            <Setter Property="Background" Value="#8C000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="16,14,16,20" ColumnSpacing="12" RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- ================ LEFT COLUMN ================ -->
            <StackPanel Grid.Column="0" Spacing="12">

                <!-- === Live Monitoring Card === -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8F4;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Live Monitoring · YOLO Crop Detection"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Button x:Name="StartDemoButton" Style="{StaticResource HarvestPrimaryButton}" Padding="10,5" Click="StartDemoButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE768;" FontSize="11"/>
                                            <TextBlock Text="Start Detection"/>
                                        </StackPanel>
                                    </Button>
                                    <Border x:Name="AiStatusPill" Style="{StaticResource PillSuccessStyle}">
                                        <TextBlock x:Name="AiStatusText" Text="AI ON" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Style="{StaticResource PillInfoStyle}">
                                        <TextBlock x:Name="DetectionCountText" Text="0 det" FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Body -->
                        <Grid Grid.Row="1" Padding="8,8,8,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <!-- === Live Video with overlays === -->
                            <Border Grid.Column="0" CornerRadius="10" Background="#0F1F14" BorderBrush="#163021" BorderThickness="1">
                                <Grid Height="260" x:Name="VideoRoot">
                                    <!-- Actual live video (YOLO overlays drawn by VideoStreamControl) -->
                                    <controls:VideoStreamControl x:Name="DashboardVideoStream"/>

                                    <!-- Vegetation overlay (color wash) -->
                                    <Rectangle x:Name="VegetationOverlayLayer" Opacity="0.32" IsHitTestVisible="False">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#8C2E7D32" Offset="0"/>
                                                <GradientStop Color="#55FBC02D" Offset="0.55"/>
                                                <GradientStop Color="#66D32F2F" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Grid overlay -->
                                    <Canvas x:Name="GridOverlayCanvas" IsHitTestVisible="False" Opacity="0.3" Visibility="Collapsed"/>

                                    <!-- Heatmap overlay (radial gradients) -->
                                    <Grid x:Name="HeatmapOverlayLayer" Visibility="Collapsed" IsHitTestVisible="False">
                                        <Ellipse Width="260" Height="260" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="120,60,0,0" Opacity="0.45">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFF0000" Offset="0"/>
                                                    <GradientStop Color="#00FF0000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="220" Height="220" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,140,0" Opacity="0.45">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFFB400" Offset="0"/>
                                                    <GradientStop Color="#00FFB400" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>

                                    <!-- Top HUD bar -->
                                    <Grid VerticalAlignment="Top" Margin="12" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Ellipse Width="6" Height="6" Fill="#EF4444" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="RecStatusText" Text="REC" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <TextBlock x:Name="FpsHudText" Text="YOLOv8 · standby" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <TextBlock x:Name="ConfAvgText" Text="Conf avg 0%" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource HudPillStyle}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE707;" FontSize="11" Foreground="White"/>
                                                <TextBlock x:Name="GpsHudText" Text="-6.91124, 107.61152" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>


                                    <!-- Bottom HUD bar -->
                                    <Grid VerticalAlignment="Bottom" Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <Border Style="{StaticResource HudPillStyle}" HorizontalAlignment="Left">
                                                <TextBlock x:Name="AltSpdHudText" Text="ALT 0 m · SPD 0 m/s" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}" HorizontalAlignment="Left">
                                                <TextBlock x:Name="HdgModeText" Text="HDG 0° · MODE STANDBY" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" Visibility="Collapsed">
                                            <Button x:Name="RecordButton" Style="{StaticResource HudActionButton}" Click="RecordButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon x:Name="RecordIcon" Glyph="&#xE71A;" FontSize="12"/>
                                                    <TextBlock x:Name="RecordLabel" Text="Stop"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource HudActionButton}" Click="SnapshotButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE722;" FontSize="12"/>
                                                    <TextBlock Text="Snapshot"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource HudActionButton}" Click="PauseAiButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon x:Name="PauseAiIcon" Glyph="&#xE769;" FontSize="12"/>
                                                    <TextBlock x:Name="PauseAiLabel" Text="Pause AI"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- IMU HUD (top-right below top bar) -->
                                    <StackPanel x:Name="ImuHudPanel" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0" Spacing="2">
                                        <Border Width="48" Height="48" CornerRadius="24" Background="#66000000" BorderBrush="#30FFFFFF" BorderThickness="1">
                                            <Grid>
                                                <Grid x:Name="ImuRotationGrid" RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <RotateTransform x:Name="ImuRollTransform" Angle="0"/>
                                                    </Grid.RenderTransform>
                                                    <Grid x:Name="ImuPitchGrid">
                                                        <Grid.RenderTransform>
                                                            <TranslateTransform x:Name="ImuPitchTransform" Y="0"/>
                                                        </Grid.RenderTransform>
                                                        <Rectangle Height="24" VerticalAlignment="Top" Fill="#4FC3F7"/>
                                                        <Rectangle Height="24" VerticalAlignment="Bottom" Fill="#8D6E63"/>
                                                    </Grid>
                                                </Grid>
                                                <Rectangle Width="16" Height="1" Fill="#FACC15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Border Background="#99000000" CornerRadius="5" Padding="4,1" HorizontalAlignment="Center">
                                            <TextBlock x:Name="ImuLabelText" Text="P-5° R0° Y45°" Foreground="White" FontSize="8"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- === Right side: Map + Detections stacked === -->
                            <Grid Grid.Column="1" RowSpacing="8" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="125"/>
                                    <RowDefinition Height="125"/>
                                </Grid.RowDefinitions>

                                <!-- Live Map -->
                                <Border Grid.Row="0" BorderBrush="#D1E7D5" BorderThickness="1" CornerRadius="10" Padding="8" Background="#FCFFFC">
                                    <StackPanel Spacing="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Live Map · UAV" FontSize="11" Foreground="#4F6B5C"/>
                                            <Border Grid.Column="1" Style="{StaticResource PillInfoStyle}" Padding="6,2">
                                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE707;" FontSize="9" Foreground="#1D4ED8"/>
                                                    <TextBlock x:Name="HeadingPillText" Text="HDG 0°" FontSize="10" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Border Height="88" CornerRadius="6" BorderBrush="#CAE3D1" BorderThickness="1" Background="#EAF4EC">
                                            <controls:SkiaMapControl x:Name="DashboardMapControl"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Live Detections list -->
                                <Border Grid.Row="1" BorderBrush="#D1E7D5" BorderThickness="1" CornerRadius="10" Padding="8" Background="#FCFFFC">
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="DetectionsListTitle" Text="Live Detections (0)" FontSize="11" Foreground="#4F6B5C"/>
                                        <ScrollViewer Height="88" VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="DetectionsListStack" Spacing="4">
                                                <TextBlock x:Name="DetectionsEmptyText" Text="No detections above threshold." FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- === Recommendations + Export Card (full width) === -->
                <!-- Hidden controls — kept for code-behind compatibility -->
                <StackPanel Visibility="Collapsed">
                    <ToggleSwitch x:Name="YoloToggleSwitch" IsOn="True" Toggled="YoloToggle_Toggled"/>
                    <ToggleSwitch x:Name="VegToggleSwitch" IsOn="True" Toggled="VegToggle_Toggled"/>
                    <ToggleSwitch x:Name="ImuToggleSwitch" IsOn="True" Toggled="ImuToggle_Toggled"/>
                    <Slider x:Name="ConfThresholdSlider" Minimum="10" Maximum="95" Value="40" ValueChanged="ConfThresholdSlider_ValueChanged"/>
                    <TextBlock x:Name="ConfThresholdValue" Text="40%"/>
                    <!-- Readiness checklist items — kept for code-behind compatibility -->
                    <StackPanel x:Name="ReadinessChecklistPanel" Spacing="2">
                        <TextBlock x:Name="ReadyTelemetryText" Text="○ Telemetry connected" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyGpsText" Text="○ GPS fix" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyBatteryText" Text="○ Battery" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyCameraText" Text="○ Camera active" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyYoloText" Text="○ YOLO ready" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyGeofenceText" Text="○ Geofence loaded" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyWaypointText" Text="○ Waypoints loaded" FontSize="11" Foreground="#64766B"/>
                        <TextBlock x:Name="ReadyRecorderText" Text="○ Recorder ready" FontSize="11" Foreground="#64766B"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Recommendations + Export -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Recommendations &amp; Report Export" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Row="1" Padding="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Hidden mission metadata — kept for code-behind/export compatibility -->
                                <StackPanel Grid.Row="0" Spacing="6">
                                    <StackPanel x:Name="MissionMetadataPanel" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Mission ID" FontSize="12" Foreground="#64766B"/>
                                        <TextBlock Grid.Column="1" x:Name="MissionIdText" Text="MH-20260501-014" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Operator" FontSize="12" Foreground="#64766B"/>
                                        <TextBlock Grid.Column="1" Text="Operator Satu" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Started" FontSize="12" Foreground="#64766B"/>
                                        <TextBlock Grid.Column="1" x:Name="MissionStartedText" Text="--:--:--" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Detections" FontSize="12" Foreground="#64766B"/>
                                        <TextBlock Grid.Column="1" x:Name="MissionDetectionsText" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Telemetry log" FontSize="12" Foreground="#64766B"/>
                                        <TextBlock Grid.Column="1" x:Name="MissionFramesText" Text="0 frames" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                    </Grid>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE946;" FontSize="12" Foreground="#2E7D32"/>
                                            <TextBlock Text="Recommended Action" FontSize="12" FontWeight="SemiBold" Foreground="#4F6B5C"/>
                                        </StackPanel>
                                        <TextBlock Text="Inspect yellow and orange zones first, then verify bare-soil gaps before irrigation, replanting, or targeted treatment." FontSize="11" Foreground="#64766B" TextWrapping="Wrap"/>
                                        <TextBlock Text="Use RGB detection as field-screening evidence. Confirm pest or disease symptoms with ground scouting before applying chemicals." FontSize="11" Foreground="#64766B" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Grid ColumnSpacing="6" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource HarvestOutlineButton}" Click="ExportPdfButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                                <TextBlock Text="PDF"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Style="{StaticResource HarvestOutlineButton}" Click="ExportCsvButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                                <TextBlock Text="CSV"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource HarvestOutlineButton}" Click="ExportJsonButton_Click" HorizontalAlignment="Stretch">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                                <TextBlock Text="JSON"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <!-- Right: operational notes -->
                                <Border Grid.Row="1" BorderBrush="#E5F3E8" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                    <StackPanel Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="#F59E0B"/>
                                            <TextBlock Text="Operational Notes" FontSize="12" FontWeight="SemiBold" Foreground="#4F6B5C"/>
                                        </StackPanel>
                                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="AlertsStack" Spacing="6"/>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                </Border>

                <!-- Field Report & Recommendations (moved from right column) -->
                <Border x:Name="FarmerReportCard" Style="{StaticResource HarvestCardStyle}" Visibility="Visible">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9EC;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Field Report &amp; Recommendations" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                                <Border Grid.Column="1" x:Name="FarmerReportStatusPill" Style="{StaticResource PillSuccessStyle}">
                                    <TextBlock x:Name="FarmerReportStatusText" Text="Standby" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Field Health Index (FHI)" FontSize="11" Foreground="#64766B"/>
                                    <TextBlock x:Name="FarmerFhiLabel" Text="Waiting for detection data..." FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="26" Width="52" Height="52" Background="#ECFDF5" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="FarmerFhiScore" Text="--" FontSize="18" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <Border Height="1" Background="#E5F3E8"/>
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#4F6B5C"/>
                                    <TextBlock Text="Action Recommendations" FontSize="11" FontWeight="SemiBold" Foreground="#4F6B5C"/>
                                </StackPanel>
                                <StackPanel x:Name="FarmerRecommendationsStack" Spacing="5"/>
                            </StackPanel>
                            <Border Height="1" Background="#E5F3E8"/>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE748;" FontSize="11" Foreground="#4F6B5C"/>
                                    <TextBlock Text="Next Survey" FontSize="11" FontWeight="SemiBold" Foreground="#4F6B5C"/>
                                </StackPanel>
                                <TextBlock x:Name="FarmerNextActionText" Text="Waiting for detection data to generate field analysis..." FontSize="11" Foreground="#64766B" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock x:Name="FarmerReportTimestamp" Text="Not updated yet" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- ================ RIGHT COLUMN ================ -->
            <StackPanel Grid.Column="1" Spacing="12">

                <!-- MAVLink Telemetry -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="MAVLink Telemetry" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                                <Border Grid.Column="1" x:Name="MavLinkStatusPill" Style="{StaticResource PillSuccessStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE701;" FontSize="10" Foreground="#065F46"/>
                                        <TextBlock x:Name="MavLinkStatusText" Text="UDP 14550" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE9A9;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Altitude" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryAltitudeText" Text="0 m" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE9A3;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Airspeed" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetrySpeedText" Text="0 m/s" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE81D;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Heading" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryHeadingText" Text="0°" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE704;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="GPS sats" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryGpsText" Text="0 · HDOP --" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE83E;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Battery" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryBatteryText" Text="0% · --" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE709;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Flight Mode" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryModeText" Text="STANDBY" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="#E5F3E8" Margin="0,10,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mission Progress" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="MissionProgressText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </Grid>
                            <ProgressBar x:Name="MissionProgressBar" Minimum="0" Maximum="100" Value="0" Height="8" Foreground="#2E7D32" Background="#ECFDF5"/>
                            <Grid ColumnSpacing="6" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="WP" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="WaypointProgressText" Text="0/0" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="Elapsed" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MissionElapsedText" Text="00:00" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="ETA" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MissionEtaText" Text="--:--" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Analysis Summary -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8F4;" FontSize="14" Foreground="#2E7D32"/>
                                <TextBlock Text="Analysis Summary" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="4">
                            <!-- Lush Green -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                        <TextBlock Text="🌿" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Lush Green" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummaryHealthyCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummaryHealthyBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#2E7D32" Background="#ECFDF5"/>
                            </StackPanel>
                            <!-- Well Irrigated (legacy hidden; v5 datasheet uses 4 classes) -->
                            <StackPanel Spacing="2" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#E0F7FA" Margin="0,0,8,0">
                                        <TextBlock Text="💧" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Well Irrigated" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummaryWellIrrigatedCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#0288D1" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummaryWellIrrigatedBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#0288D1" Background="#E0F7FA"/>
                            </StackPanel>
                            <!-- Inconsistent Growth -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#FFFBEB" Margin="0,0,8,0">
                                        <TextBlock Text="🟡" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Inconsistent Growth" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummaryStressCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#B26B00" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummaryStressBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#FBC02D" Background="#FFFBEB"/>
                            </StackPanel>
                            <!-- Soil Issues (legacy hidden; v5 datasheet uses Bare Soil / Gap) -->
                            <StackPanel Spacing="2" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#EFEBE9" Margin="0,0,8,0">
                                        <TextBlock Text="🟤" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Soil Issues" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummarySoilIssuesCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#5D4037" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummarySoilIssuesBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#795548" Background="#EFEBE9"/>
                            </StackPanel>
                            <!-- Drought / Severe Stress -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#FFF3E0" Margin="0,0,8,0">
                                        <TextBlock Text="🟠" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Drought/Severe Stress" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummaryDiseaseCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#E65100" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummaryDiseaseBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#F57C00" Background="#FFF3E0"/>
                            </StackPanel>
                            <!-- Bare Soil / Gap -->
                            <StackPanel Spacing="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#EFEBE9" Margin="0,0,8,0">
                                        <TextBlock Text="🟤" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Bare Soil / Gap" FontSize="12" Foreground="#0F3024" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" x:Name="SummaryPestCount" Text="0%" FontSize="13" FontWeight="SemiBold" Foreground="#5D4037" VerticalAlignment="Center"/>
                                </Grid>
                                <ProgressBar x:Name="SummaryPestBar" Minimum="0" Maximum="100" Value="0" Height="5" Foreground="#795548" Background="#EFEBE9"/>
                            </StackPanel>

                            <Border Height="1" Background="#E5F3E8" Margin="0,8,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Dominant" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="SummaryDominantPill" Style="{StaticResource PillSuccessStyle}">
                                    <TextBlock x:Name="SummaryDominantText" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="#065F46"/>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Priority" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="SummaryPriorityPill" Style="{StaticResource PillCriticalStyle}">
                                    <TextBlock x:Name="SummaryPriorityText" Text="Standby" FontSize="11" FontWeight="SemiBold" Foreground="#B91C1C"/>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Confidence avg" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="SummaryConfidenceText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </Grid>
                            <Button Style="{StaticResource HarvestOutlineButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="GoCropAnalysisButton_Click">
                                <TextBlock Text="View Crop Analysis Details"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Edge Offline Mode (compact inline card) -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid Padding="12,8" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="14" Foreground="#2E7D32" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <TextBlock x:Name="OfflineModeText" Text="Running offline · AI local model active" FontSize="11" FontWeight="SemiBold" Foreground="#065F46"/>
                            <TextBlock x:Name="ModelRuntimeText" Text="Model: bundled-auto" FontSize="10" Foreground="#64766B"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="RecorderRuntimeText" Text="Recorder: standby" FontSize="10" Foreground="#64766B" HorizontalAlignment="Right"/>
                            <Border Background="#ECFDF5" CornerRadius="5" Padding="6,2" HorizontalAlignment="Right">
                                <TextBlock Text="No Cloud" FontSize="10" Foreground="#065F46" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
