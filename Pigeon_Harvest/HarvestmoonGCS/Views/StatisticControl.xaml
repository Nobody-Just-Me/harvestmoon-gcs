<UserControl
    x:Class="HarvestmoonGCS.Views.StatisticControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HarvestmoonGCS.Views"
    xmlns:controls="using:HarvestmoonGCS.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="615"
    d:DesignWidth="1132">

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,10,15,0" 
                    Spacing="5">
            <Button x:Name="btn_start_stats" 
                    Content="▶ Start" 
                    Width="80" Height="30"
                    Background="#FF28A745" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="StartAutoUpdate_Click"/>
            <Button x:Name="btn_stop_stats" 
                    Content="⏸ Stop" 
                    Width="80" Height="30"
                    Background="#FFDC3545" 
                    Foreground="White" 
                    FontWeight="Bold"  
                    Click="StopAutoUpdate_Click" 
                    IsEnabled="False"/>
            <Button x:Name="btn_export_csv" 
                    Content="📥 Export" 
                    Width="90" Height="30"
                    Background="#FF17A2B8" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="ExportCSV_Click"/>
            <Button x:Name="btn_reset_stats" 
                    Content="🔄 Reset" 
                    Width="80" Height="30"
                    Background="#FF6C757D" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Click="ResetStats_Click"/>
        </StackPanel>

        <!-- Yaw Chart -->
        <controls:SkiaChartControl x:Name="yawChart" 
                                   Grid.Row="1" 
                                   Margin="10"/>
        
        <!-- Pitch & Roll Chart -->
        <controls:SkiaChartControl x:Name="pitchRollChart" 
                                   Grid.Row="2" 
                                   Margin="10,5,10,10"/>
    </Grid>
</UserControl>
