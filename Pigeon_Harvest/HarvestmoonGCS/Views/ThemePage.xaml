<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HarvestmoonGCS.Views.ThemePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource DarkBackgroundColor}">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">
            <!-- Header -->
            <TextBlock Text="Theme &amp; Appearance"
                      Style="{StaticResource HeaderTextStyle}"
                      Margin="0,0,0,10"/>

            <!-- Theme Selection -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Theme Mode"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <RadioButton x:Name="LightThemeRadio"
                                Content="Light Theme"
                                GroupName="Theme"
                                Style="{StaticResource StandardRadioButtonStyle}"
                                Checked="ThemeRadio_Checked"/>
                    
                    <RadioButton x:Name="DarkThemeRadio"
                                Content="Dark Theme"
                                GroupName="Theme"
                                IsChecked="True"
                                Style="{StaticResource StandardRadioButtonStyle}"
                                Checked="ThemeRadio_Checked"/>
                    
                    <RadioButton x:Name="SystemThemeRadio"
                                Content="System Default"
                                GroupName="Theme"
                                Style="{StaticResource StandardRadioButtonStyle}"
                                Checked="ThemeRadio_Checked"/>
                </StackPanel>
            </Border>

            <!-- Accessibility -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Accessibility"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <CheckBox x:Name="HighContrastCheckBox"
                             Content="High Contrast Mode"
                             Style="{StaticResource StandardCheckBoxStyle}"
                             Checked="HighContrastCheckBox_Changed"
                             Unchecked="HighContrastCheckBox_Changed"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="Font Size"
                                  Style="{StaticResource LabelTextStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Slider x:Name="FontSizeSlider"
                                   Grid.Column="0"
                                   Minimum="0.8"
                                   Maximum="2.0"
                                   Value="1.0"
                                   StepFrequency="0.1"
                                   Style="{StaticResource StandardSliderStyle}"
                                   ValueChanged="FontSizeSlider_ValueChanged"/>
                            
                            <TextBlock x:Name="FontSizeText"
                                      Grid.Column="1"
                                      Text="100%"
                                      Style="{StaticResource BodyTextStyle}"
                                      Margin="12,0,0,0"
                                      VerticalAlignment="Center"
                                      MinWidth="50"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Animations -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Animations"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <CheckBox x:Name="AnimationsCheckBox"
                             Content="Enable UI Animations"
                             IsChecked="True"
                             Style="{StaticResource StandardCheckBoxStyle}"
                             Checked="AnimationsCheckBox_Changed"
                             Unchecked="AnimationsCheckBox_Changed"/>
                    
                    <TextBlock Text="Disable animations to improve performance on slower devices"
                              Style="{StaticResource CaptionTextStyle}"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Custom Colors -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Custom Colors"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="Primary Color"
                                  Style="{StaticResource LabelTextStyle}"
                                  VerticalAlignment="Center"/>
                        <TextBox x:Name="PrimaryColorTextBox"
                                Grid.Row="0" Grid.Column="1"
                                Text="#A32CC4"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Margin="8,4"/>
                        <Border Grid.Row="0" Grid.Column="2"
                               x:Name="PrimaryColorPreview"
                               Width="40" Height="40"
                               Background="#A32CC4"
                               CornerRadius="4"
                               BorderBrush="{ThemeResource BorderColor}"
                               BorderThickness="1"
                               Margin="8,4"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="Secondary Color"
                                  Style="{StaticResource LabelTextStyle}"
                                  VerticalAlignment="Center"/>
                        <TextBox x:Name="SecondaryColorTextBox"
                                Grid.Row="1" Grid.Column="1"
                                Text="#00CED1"
                                Style="{StaticResource StandardTextBoxStyle}"
                                Margin="8,4"/>
                        <Border Grid.Row="1" Grid.Column="2"
                               x:Name="SecondaryColorPreview"
                               Width="40" Height="40"
                               Background="#00CED1"
                               CornerRadius="4"
                               BorderBrush="{ThemeResource BorderColor}"
                               BorderThickness="1"
                               Margin="8,4"/>
                    </Grid>
                    
                    <Button Content="Apply Custom Colors"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Click="ApplyCustomColors_Click"
                           HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Layout Management -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Layout Management"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <ComboBox x:Name="LayoutComboBox"
                             Header="Saved Layouts"
                             Style="{StaticResource StandardComboBoxStyle}"
                             SelectionChanged="LayoutComboBox_SelectionChanged"
                             HorizontalAlignment="Stretch"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save Current Layout"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="SaveLayout_Click"/>
                        
                        <Button Content="Delete Layout"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="DeleteLayout_Click"/>
                        
                        <Button Content="Reset to Default"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="ResetLayout_Click"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Layout"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="ExportLayout_Click"/>
                        
                        <Button Content="Import Layout"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="ImportLayout_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Reset All -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Reset"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Button Content="Reset All Theme Settings"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Click="ResetTheme_Click"
                           HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="This will reset all theme and layout settings to defaults"
                              Style="{StaticResource CaptionTextStyle}"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Preview -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Preview"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Border Background="{ThemeResource LightBackgroundColor}"
                           BorderBrush="{ThemeResource BorderColor}"
                           BorderThickness="1"
                           CornerRadius="4"
                           Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Sample Header"
                                      Style="{StaticResource HeaderTextStyle}"/>
                            <TextBlock Text="Sample body text with current theme applied"
                                      Style="{StaticResource BodyTextStyle}"/>
                            <Button Content="Sample Button"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
