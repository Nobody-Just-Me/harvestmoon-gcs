<Page x:Class="HarvestmoonGCS.Views.EdgeModePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
            <Setter Property="CharacterSpacing" Value="50"/>
        </Style>
        <Style x:Key="ValueLargeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="SmallLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10,12,12">
        <StackPanel Spacing="8">

            <!-- ═══ STATUS BAR (compact single row) ═══ -->
            <Border Style="{StaticResource CardStyle}" Background="#0D065F46" Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- dot + status -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse x:Name="EdgeStatusDot" Width="8" Height="8" Fill="#22C55E"/>
                        <TextBlock x:Name="EdgeStatusText" Text="Edge AI · Active" FontSize="12" FontWeight="SemiBold" Foreground="#22C55E" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- model name -->
                    <TextBlock Grid.Column="1" x:Name="ModelNameText" Text="yolov8n-agri.onnx" FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" VerticalAlignment="Center" Margin="12,0"/>

                    <!-- Offline badge -->
                    <Border Grid.Column="2" Padding="6,3" CornerRadius="5" Background="#1022C55E" BorderBrush="#2822C55E" BorderThickness="1" Margin="0,0,6,0">
                        <TextBlock Text="Offline" FontSize="10" Foreground="#22C55E" FontWeight="SemiBold"/>
                    </Border>
                    <!-- ONNX badge -->
                    <Border Grid.Column="3" Padding="6,3" CornerRadius="5" Background="#10F59E0B" BorderBrush="#28F59E0B" BorderThickness="1">
                        <TextBlock Text="ONNX" FontSize="10" Foreground="#F59E0B" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ ROW 1: Performance metrics + YOLO config (2 col) ═══ -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Inference Performance (compact) -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="INFERENCE" Style="{StaticResource SectionLabelStyle}"/>

                        <!-- 3 metrics inline -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="6,6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="FPS" Style="{StaticResource SmallLabelStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FpsValueText" Text="—" Style="{StaticResource ValueLargeStyle}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="6,6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="ms" Style="{StaticResource SmallLabelStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="LatencyValueText" Text="—" Style="{StaticResource ValueLargeStyle}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="6,6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="Det" Style="{StaticResource SmallLabelStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="DetectionsValueText" Text="—" Style="{StaticResource ValueLargeStyle}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- FPS progress bar -->
                        <StackPanel Spacing="3">
                            <Grid>
                                <TextBlock Text="Target 15 FPS" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                <TextBlock x:Name="FpsTargetText" Text="0%" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="4" CornerRadius="2" Background="{ThemeResource InputBrush}">
                                <Border x:Name="FpsProgressBar" Height="4" CornerRadius="2" Background="#22C55E" HorizontalAlignment="Left" Width="0"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- YOLO Model Config (compact) -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="7">
                        <TextBlock Text="MODEL CONFIG" Style="{StaticResource SectionLabelStyle}"/>

                        <ComboBox x:Name="ModelCombo" HorizontalAlignment="Stretch" FontSize="11" SelectedIndex="0" Height="32">
                            <ComboBoxItem Content="yolov8n-agri.onnx"/>
                            <ComboBoxItem Content="yolov8n-rice.onnx"/>
                            <ComboBoxItem Content="yolov8n-custom.onnx"/>
                        </ComboBox>

                        <!-- Conf threshold -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Conf" FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="ConfThresholdSlider" Minimum="10" Maximum="95" Value="40" VerticalAlignment="Center" ValueChanged="ConfThreshold_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="ConfThresholdLabel" Text="40%" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource ForegroundBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- NMS threshold -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NMS" FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="NmsThresholdSlider" Minimum="10" Maximum="90" Value="45" VerticalAlignment="Center" ValueChanged="NmsThreshold_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="NmsThresholdLabel" Text="45%" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{ThemeResource ForegroundBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="Apply" FontSize="11" Padding="10,5" CornerRadius="6"
                                    Background="{ThemeResource PrimaryBrush}" Foreground="White"
                                    Click="ApplyModel_Click"/>
                            <Button Content="Browse…" FontSize="11" Padding="10,5" CornerRadius="6"
                                    Background="Transparent" Foreground="{ThemeResource ForegroundBrush}"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                                    Click="BrowseModel_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ ROW 2: Feature toggles + Runtime env (2 col) ═══ -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Edge AI Feature Toggles -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="EDGE AI FEATURES" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4"/>

                        <!-- Each toggle row: compact -->
                        <Border CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="YOLO Detection" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource ForegroundBrush}"/>
                                    <TextBlock Text="Bounding box overlay on live feed" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="YoloToggle" Grid.Column="1" IsOn="True" Toggled="YoloToggle_Toggled" VerticalAlignment="Center" Margin="0" MinWidth="0"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="Vegetation Overlay" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource ForegroundBrush}"/>
                                    <TextBlock Text="OpenCV VARI/ExG color transform" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="VegToggle" Grid.Column="1" IsOn="True" Toggled="VegToggle_Toggled" VerticalAlignment="Center" Margin="0" MinWidth="0"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="IMU Telemetry Overlay" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource ForegroundBrush}"/>
                                    <TextBlock Text="Attitude · altitude · airspeed on frame" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="ImuToggle" Grid.Column="1" IsOn="True" Toggled="ImuToggle_Toggled" VerticalAlignment="Center" Margin="0" MinWidth="0"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="6" Background="{ThemeResource InputBrush}" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="1">
                                    <TextBlock Text="INT8 Quantization" FontSize="11" FontWeight="Medium" Foreground="{ThemeResource ForegroundBrush}"/>
                                    <TextBlock Text="Reduces bottleneck on Android devices" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="Int8Toggle" Grid.Column="1" IsOn="True" Toggled="Int8Toggle_Toggled" VerticalAlignment="Center" Margin="0" MinWidth="0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Runtime info + Transport (stacked) -->
                <StackPanel Grid.Column="1" Spacing="8">

                    <!-- Runtime Environment -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="RUNTIME" Style="{StaticResource SectionLabelStyle}"/>
                            <Grid ColumnSpacing="8" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Platform" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock x:Name="PlatformText" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="Runtime" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock Text="ONNX Runtime" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Provider" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock x:Name="ExecutionProviderText" Text="—" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Format" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock Text=".onnx" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Network" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock Text="None" FontSize="11" FontWeight="SemiBold" Foreground="#22C55E"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1">
                                    <TextBlock Text="Codebase" Style="{StaticResource SmallLabelStyle}"/>
                                    <TextBlock Text="Uno Platform" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Grid>
                            <Button Content="Refresh" FontSize="10" Padding="8,4" CornerRadius="5"
                                    Background="Transparent" Foreground="{ThemeResource ForegroundBrush}"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                                    HorizontalAlignment="Stretch" Click="RefreshStatus_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- MAVLink Transport (compact) -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="5">
                            <TextBlock Text="MAVLINK TRANSPORT" Style="{StaticResource SectionLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <RadioButton x:Name="UdpRadio" Content="UDP" GroupName="Transport" IsChecked="True" FontSize="11"/>
                                <RadioButton x:Name="TcpRadio" Content="TCP" GroupName="Transport" FontSize="11"/>
                                <RadioButton x:Name="SerialRadio" Content="Serial" GroupName="Transport" FontSize="11"/>
                            </StackPanel>
                            <TextBlock x:Name="TransportStatusText" Text="UDP · 14550 · Listening" FontSize="10" Foreground="#22C55E" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
