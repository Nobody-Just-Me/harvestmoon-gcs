<UserControl x:Class="Pigeon_WPF_cs.Custom_UserControls.Calibration"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Pigeon_WPF_cs.Custom_UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="632" d:DesignWidth="1132">
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Styles.xaml -->
            <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="LightGray"/>
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Style>

            <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="Black"/>
                <Setter Property="Margin" Value="5"/>
            </Style>

        </ResourceDictionary>

    </UserControl.Resources>
    <Grid>
        <!-- informasi di panel desain -->
        <d:TextBox TextWrapping="Wrap" Width="750" TextAlignment="Center" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,10" FontWeight="Bold" FontStyle="Italic" Background="#FFFFFF00">
            <d:TextBox.Text>
                Jika berbeda dengan tampilan saat run, lihat di bagian bawah (XAML).
                Text ini tidak akan muncul saat run. Sembunyikan text ini melalui XAML.
            </d:TextBox.Text>
            <!-- uncomment untuk menyembunyikan saat mendesain -->
            <!--<d:TextBox.Visibility>Collapsed</d:TextBox.Visibility>-->
        </d:TextBox>

        <!-- Defer interaksi sebelum terkoneksi wahana -->
        <StackPanel Background="#7F000000" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <TextBox BorderThickness="0" TextAlignment="Center" FontSize="30" Padding="20,10" FontWeight="Bold" FontStyle="Italic" Background="Transparent" Foreground="White">
                <TextBox.Text>
                    Koneksikan dengan wahana sebelum menggunakan fungsi ini.
                </TextBox.Text>
            </TextBox>
            <Button Click="Konfirmasi_Koneksi" BorderThickness="2" BorderBrush="Yellow" Content="Konfirmasi" HorizontalAlignment="Center" FontSize="20" Margin="15" Padding="15,5"/>

            <!-- sembunyikan saat mendesain -->
            <d:StackPanel.Visibility>Hidden</d:StackPanel.Visibility>
        </StackPanel>

        <Grid x:Name="func_grid" Panel.ZIndex="-1" Background="DarkGray">

            <!-- Defer interaksi sebelum terkoneksi wahana -->
            <Grid.IsEnabled>false</Grid.IsEnabled>
            <Grid.Effect>
                <BlurEffect>
                    <BlurEffect.Radius>15</BlurEffect.Radius>
                    <!-- un-blur saat mendesain -->
                    <d:BlurEffect.Radius>0</d:BlurEffect.Radius>
                </BlurEffect>
            </Grid.Effect>
            <!-- enable saat mendesain -->
            <d:Grid.IsEnabled>true</d:Grid.IsEnabled>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navbar -->
            <UniformGrid Grid.Row="0" Columns="7" Background="LightGray">
                <Button x:Name="AccelerometerButton" Content="Accelerometer" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="CompassButton" Content="Compass" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="FlightButton" Content="Flight Mode" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="ServoOutputButton" Content="Servo Output" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="SettingButton" Content="Setting" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="EscCalibButton" Content="ESC" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
                <Button x:Name="MotorTestButton" Content="Motor Test" Margin="10" Padding="10" FontSize="15" Click="Button_Click"/>
            </UniformGrid>

            <!-- 2x3 Image Grid -->
            <Grid x:Name="Accele_calib" Margin="0,30,0,0" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Placeholder for images and text with border -->
                <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
                    <Border x:Name="Border1" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/FLIP_UP.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text1" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                    <Border x:Name="Border2" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/KIRI.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text2" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center">
                    <Border x:Name="Border3" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/KANAN.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text3" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                    <Border x:Name="Border4" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/DOWN.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text4" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center">
                    <Border x:Name="Border5" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/UP.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text5" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                    <Border x:Name="Border6" BorderBrush="red" BorderThickness="2" Padding="5" Background="Black">
                        <Image Source="/PIGEON GCS;component/Resources/icons/FLIP_DOWN.png" Width="150" Height="150"/>
                    </Border>
                    <TextBlock x:Name="Text6" Text="NOT COMPLETED" HorizontalAlignment="Center" Margin="5"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center">
                    <Button x:Name="AcceleButton" Content="START" HorizontalAlignment="Center" Margin="8" FontSize="20" Width="200" Height="50" Background="Green" Foreground="White" Click="Accele_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <UniformGrid Grid.Row="3" Columns="2" Grid.Column="1" HorizontalAlignment="Center">
                    <Button Content="Simple Accel Cal" Foreground="Black" Background="DeepSkyBlue" Width="150" Height="50" FontSize="18" Margin="0,20,10,0" Click="Simpel_Cal_Click"/>
                    <Button Content="Calibrate Level" Foreground="Black" Background="DeepSkyBlue" Width="150" Height="50" FontSize="18" Margin="10,20,0,0" Click="Levl_Cal_Click"/>
                    <TextBlock x:Name="CalibSimpelMessage" Text="" Foreground="Green" FontWeight="Bold" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LevelCalibMessage" Text="" Foreground="Green" FontWeight="Bold" Margin="0,8,0,0" HorizontalAlignment="Center"/>

                </UniformGrid>

            </Grid>
            <Grid x:Name="Kompass_calib" Background="DarkGray" Grid.Row="1" Margin="100,80,100,80" Visibility="Collapsed">
                <Border BorderBrush="White" BorderThickness="2" CornerRadius="5" Margin="300,10,300,10">
                    <Grid Background="Black" HorizontalAlignment="Center" VerticalAlignment="Top" Width="350" Margin="0,38,0,0" Height="244">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Outline for the grid -->
                        <Border BorderBrush="White" BorderThickness="2" CornerRadius="5">
                            <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="        NOMOR" Width="100" Margin="5" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="          DEV ID" Width="100" Margin="5" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Text="           TYPE" Width="100" Margin="5" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid Row -->
                        <DataGrid x:Name="DeviceList" AutoGenerateColumns="False" Grid.Row="1" Margin="5" HeadersVisibility="None" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nomer" Binding="{Binding Nomer}" Width="100"/>
                                <DataGridTextColumn Header="Dev ID" Binding="{Binding DevID}" Width="100"/>
                                <DataGridTextColumn Header="Dev Type" Binding="{Binding DevType}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="Refresh Compass List" Background="GreenYellow" FontSize="15" Width="150" Grid.Row="2" Margin="0,10,0,10" Click="RefreshCompassList_Click" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                            <Button x:Name="Start_comp" Content="Start" Background="GreenYellow" Width="100" Margin="0,0,10,0" Click="Start_comp_Click"/>
                            <Button x:Name="Accept_comp" Content="Accept" Background="GreenYellow" Width="100"  Margin="0,0,10,0" Click="Accept_comp_Click"/>
                            <Button x:Name="Cancel_comp" Content="Cancel" Background="Red" Width="100"  Click="Cancel_comp_Click"/>
                        </StackPanel>

                        <ProgressBar x:Name="progressBar1" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350" Height="20" Minimum="0" Maximum="100" Value="0" />
                        <ProgressBar x:Name="progressBar2" Grid.Row="5" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350" Height="20" Minimum="0" Maximum="100" Value="0" Margin="0,10,0,0" />
                        <Button x:Name="Reboot_comp" Content="Reboot" Grid.Row="6" Background="Yellow" Width="100" Margin="0,15,0,0" Click="Reboot_comp_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="Flight_mode" Background="DarkGray" Grid.Row="1"  Visibility="Hidden" RenderTransformOrigin="0.504,0.51">
                <Border BorderBrush="White" BorderThickness="2" CornerRadius="5" Margin="340,30,340,193">
                    <Grid Background="LightGray" HorizontalAlignment="Center" VerticalAlignment="Top" Width="450" Margin="0,0,5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Rectangle x:Name="mode1" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" />

                        <Rectangle x:Name="mode2" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="2" />

                        <Rectangle x:Name="mode3" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="3" />

                        <Rectangle x:Name="mode4" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="4" />

                        <Rectangle x:Name="mode5" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="5" />

                        <Rectangle x:Name="mode6" Width="170" Height="42" Fill="Transparent" Stroke="Black" StrokeThickness="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Grid.Row="6" />

                        <TextBlock Text="FLIGHT MODE" Foreground="Black" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Grid.ColumnSpan="3" HorizontalAlignment="Center" Margin="96,10,0,25" Width="177" />
                        <TextBlock Text="Flight Mode 1:" Foreground="Black" Grid.Column="0" Grid.Row="1" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode1" Width="150" Grid.Column="1" Grid.Row="1" Margin="10">
                        </ComboBox>

                        <TextBlock Text="Flight Mode 2:" Foreground="Black" Grid.Column="0" Grid.Row="2" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode2" Width="150" Grid.Column="1" Grid.Row="2" Margin="10">
                        </ComboBox>

                        <TextBlock Text="Flight Mode 3:" Foreground="Black" Grid.Column="0" Grid.Row="3" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode3" Width="150" Grid.Column="1" Grid.Row="3" Margin="10">
                        </ComboBox>

                        <TextBlock Text="Flight Mode 4:" Foreground="Black" Grid.Column="0" Grid.Row="4" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode4" Width="150" Grid.Column="1" Grid.Row="4" Margin="10">
                        </ComboBox>

                        <TextBlock Text="Flight Mode 5:" Foreground="Black" Grid.Column="0" Grid.Row="5" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode5" Width="150" Grid.Column="1" Grid.Row="5" Margin="10">
                        </ComboBox>

                        <TextBlock Text="Flight Mode 6:" Foreground="Black" Grid.Column="0" Grid.Row="6" Margin="10" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CMB_fmode6" Width="150" Grid.Column="1" Grid.Row="6" Margin="10">
                        </ComboBox>

                        <TextBlock Text="RC PWM OUTPUT 0 - 1230" Grid.Column="2" Grid.Row="1" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="1,0,0,0"/>
                        <TextBlock Text="RC PWM OUTPUT 1231 - 1360" Grid.Column="1" Grid.Row="2" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="170,0,0,0" Grid.ColumnSpan="2"/>
                        <TextBlock Text="RC PWM OUTPUT 1361 - 1490" Grid.Column="2" Grid.Row="3" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="RC PWM OUTPUT 1491 - 1620" Grid.Column="2" Grid.Row="4" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="RC PWM OUTPUT 1621 - 1749" Grid.Column="2" Grid.Row="5" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="RC PWM OUTPUT 1750+ " Grid.Column="1" Grid.Row="6" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="170,0,0,0"/>
                        <Button Content="SAVE" Foreground="Black" Background="CornflowerBlue" Grid.Column="1" Margin="86,70,150,-47" Grid.Row="6" Grid.ColumnSpan="2" FontSize="17" Click="saveMode_Click"/>
                    </Grid>
                </Border>
            </Grid>



            <!-- Servo Output Grid (replaced with consistent 7-column layout: No | Reverse | Function | Output | Min | Trim | Max) -->
            <Grid x:Name="ServoOutput" Grid.Row="1" Margin="20" Visibility="Collapsed">
                <Border BorderBrush="Gray" BorderThickness="2" CornerRadius="5" Padding="10">
                    <Grid Background="DarkGray">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <!-- No -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Reverse -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Function -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Output (progress) -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Min -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Trim -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Max -->
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <!-- header + 16 servo rows + send button row -->
                            <RowDefinition Height="Auto"/>
                            <!-- header -->
                            <RowDefinition Height="Auto"/>
                            <!-- 1 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 2 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 3 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 4 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 5 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 6 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 7 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 8 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 9 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 10 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 11 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 12 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 13 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 14 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 15 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 16 -->
                            <RowDefinition Height="Auto"/>
                            <!-- send button -->
                        </Grid.RowDefinitions>

                        <!-- Headers -->
                        <TextBlock Text="No" Grid.Column="0" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Reverse" Grid.Column="1" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Function" Grid.Column="2" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Output" Grid.Column="3" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Min" Grid.Column="4" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Trim" Grid.Column="5" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="Max" Grid.Column="6" Grid.Row="0" Foreground="White" FontWeight="Bold" Padding="5"/>


                        <TextBlock Text="1" Grid.Column="0" Grid.Row="1" Foreground="Black" VerticalAlignment="Center" Margin="10,0,0,0" />
                        <CheckBox x:Name="Reverse1" Grid.Column="1" Grid.Row="1" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function1" Grid.Column="2" Grid.Row="1" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="1" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo1" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min1" Grid.Column="4" Grid.Row="1" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim1" Grid.Column="5" Grid.Row="1" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max1" Grid.Column="6" Grid.Row="1" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 2 -->
                        <TextBlock Text="2" Grid.Column="0" Grid.Row="2" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse2" Grid.Column="1" Grid.Row="2" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function2" Grid.Column="2" Grid.Row="2" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="2" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo2" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min2" Grid.Column="4" Grid.Row="2" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim2" Grid.Column="5" Grid.Row="2" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max2" Grid.Column="6" Grid.Row="2" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 3 -->
                        <TextBlock Text="3" Grid.Column="0" Grid.Row="3" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse3" Grid.Column="1" Grid.Row="3" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function3" Grid.Column="2" Grid.Row="3" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="3" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo3" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min3" Grid.Column="4" Grid.Row="3" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim3" Grid.Column="5" Grid.Row="3" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max3" Grid.Column="6" Grid.Row="3" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 4 -->
                        <TextBlock Text="4" Grid.Column="0" Grid.Row="4" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse4" Grid.Column="1" Grid.Row="4" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function4" Grid.Column="2" Grid.Row="4" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="4" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo4" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min4" Grid.Column="4" Grid.Row="4" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim4" Grid.Column="5" Grid.Row="4" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max4" Grid.Column="6" Grid.Row="4" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 5 -->
                        <TextBlock Text="5" Grid.Column="0" Grid.Row="5" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse5" Grid.Column="1" Grid.Row="5" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function5" Grid.Column="2" Grid.Row="5" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="5" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo5" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min5" Grid.Column="4" Grid.Row="5" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim5" Grid.Column="5" Grid.Row="5" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max5" Grid.Column="6" Grid.Row="5" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 6 -->
                        <TextBlock Text="6" Grid.Column="0" Grid.Row="6" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse6" Grid.Column="1" Grid.Row="6" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function6" Grid.Column="2" Grid.Row="6" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="6" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo6" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min6" Grid.Column="4" Grid.Row="6" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim6" Grid.Column="5" Grid.Row="6" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max6" Grid.Column="6" Grid.Row="6" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 7 -->
                        <TextBlock Text="7" Grid.Column="0" Grid.Row="7" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse7" Grid.Column="1" Grid.Row="7" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function7" Grid.Column="2" Grid.Row="7" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="7" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo7" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min7" Grid.Column="4" Grid.Row="7" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim7" Grid.Column="5" Grid.Row="7" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max7" Grid.Column="6" Grid.Row="7" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 8 -->
                        <TextBlock Text="8" Grid.Column="0" Grid.Row="8" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse8" Grid.Column="1" Grid.Row="8" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function8" Grid.Column="2" Grid.Row="8" Width="120" Margin="5" Background="LightGray"/>
