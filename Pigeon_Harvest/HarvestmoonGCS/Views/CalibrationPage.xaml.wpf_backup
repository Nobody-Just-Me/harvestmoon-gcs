                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min8" Grid.Column="4" Grid.Row="8" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim8" Grid.Column="5" Grid.Row="8" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max8" Grid.Column="6" Grid.Row="8" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 9 -->
                        <TextBlock Text="9" Grid.Column="0" Grid.Row="9" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse9" Grid.Column="1" Grid.Row="9" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function9" Grid.Column="2" Grid.Row="9" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="9" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo9" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min9" Grid.Column="4" Grid.Row="9" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim9" Grid.Column="5" Grid.Row="9" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max9" Grid.Column="6" Grid.Row="9" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 10 -->
                        <TextBlock Text="10" Grid.Column="0" Grid.Row="10" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse10" Grid.Column="1" Grid.Row="10" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function10" Grid.Column="2" Grid.Row="10" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="10" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo10" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min10" Grid.Column="4" Grid.Row="10" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim10" Grid.Column="5" Grid.Row="10" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max10" Grid.Column="6" Grid.Row="10" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 11 -->
                        <TextBlock Text="11" Grid.Column="0" Grid.Row="11" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse11" Grid.Column="1" Grid.Row="11" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function11" Grid.Column="2" Grid.Row="11" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="11" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo11" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min11" Grid.Column="4" Grid.Row="11" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim11" Grid.Column="5" Grid.Row="11" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max11" Grid.Column="6" Grid.Row="11" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 12 -->
                        <TextBlock Text="12" Grid.Column="0" Grid.Row="12" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse12" Grid.Column="1" Grid.Row="12" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function12" Grid.Column="2" Grid.Row="12" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="12" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo12" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min12" Grid.Column="4" Grid.Row="12" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim12" Grid.Column="5" Grid.Row="12" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max12" Grid.Column="6" Grid.Row="12" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 13 -->
                        <TextBlock Text="13" Grid.Column="0" Grid.Row="13" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse13" Grid.Column="1" Grid.Row="13" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function13" Grid.Column="2" Grid.Row="13" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="13" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo13" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min13" Grid.Column="4" Grid.Row="13" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim13" Grid.Column="5" Grid.Row="13" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max13" Grid.Column="6" Grid.Row="13" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 14 -->
                        <TextBlock Text="14" Grid.Column="0" Grid.Row="14" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse14" Grid.Column="1" Grid.Row="14" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function14" Grid.Column="2" Grid.Row="14" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="14" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo14" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min14" Grid.Column="4" Grid.Row="14" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim14" Grid.Column="5" Grid.Row="14" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max14" Grid.Column="6" Grid.Row="14" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 15 -->
                        <TextBlock Text="15" Grid.Column="0" Grid.Row="15" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse15" Grid.Column="1" Grid.Row="15" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function15" Grid.Column="2" Grid.Row="15" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="15" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo15" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min15" Grid.Column="4" Grid.Row="15" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim15" Grid.Column="5" Grid.Row="15" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max15" Grid.Column="6" Grid.Row="15" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- Row 16 -->
                        <TextBlock Text="16" Grid.Column="0" Grid.Row="16" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <CheckBox x:Name="Reverse16" Grid.Column="1" Grid.Row="16" Margin="5" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Function16" Grid.Column="2" Grid.Row="16" Width="120" Margin="5" Background="LightGray"/>
                        <StackPanel Orientation="Horizontal" Grid.Column="3" Grid.Row="16" Margin="0,2,0,2">
                            <ProgressBar x:Name="pb_servo16" Width="70" Height="18" Minimum="0" Maximum="100" Margin="6,0,0,0" Value="0"/>
                        </StackPanel>
                        <xctk:IntegerUpDown x:Name="Min16" Grid.Column="4" Grid.Row="16" Minimum="0" Maximum="2000" Value="1100" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Trim16" Grid.Column="5" Grid.Row="16" Minimum="0" Maximum="2000" Value="1500" Margin="5" Width="60" Background="LightGray"/>
                        <xctk:IntegerUpDown x:Name="Max16" Grid.Column="6" Grid.Row="16" Minimum="0" Maximum="2000" Value="1900" Margin="5" Width="60" Background="LightGray"/>

                        <!-- SEND button -->
                        <Button Content="SEND" Foreground="Black" Width="100" Margin="0,10,0,0" Background="CornflowerBlue" Grid.Column="2" Grid.Row="17" Grid.ColumnSpan="3" FontSize="15" Click="saveServo_Click" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>



            <!-- Setting Grid -->
            <Grid x:Name="Setting" Grid.Row="1" Margin="20" Visibility="Visible">
                <Grid Background="DarkGray">
                    <Grid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="FontSize" Value="14"/>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                        <Style x:Key="ArrowButtonStyle" TargetType="Button">
                            <Setter Property="Width" Value="20"/>
                            <Setter Property="Height" Value="20"/>
                            <Setter Property="Margin" Value="0,0,5,0"/>
                        </Style>
                    </Grid.Resources>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <!-- WAYPOINT Section -->
                        <Border BorderBrush="Black" BorderThickness="2" Height="93" Margin="0,-19,-11,19">
                            <StackPanel Height="101">
                                <TextBlock Text="WAYPOINT" FontWeight="Bold" FontSize="18" Width="1056" Height="40" RenderTransformOrigin="0.502,0.799" />
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Speed -->
                                    <Border BorderBrush="White" BorderThickness="2" Margin="22,-17,22,27">
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <TextBlock Text="Speed" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="WP_Speed" Width="70" Margin="0,0,5,0" Height="30"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="White" Width="160" BorderThickness="2" Margin="0,-17,54,27" Grid.Column="1">
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <TextBlock Text="Radius" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="WP_Radius" Width="70" Margin="0,0,5,0" Height="30"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Speed Up -->
                                    <Border BorderBrush="White" BorderThickness="2" Margin="184,-17,55,27" Grid.Column="1" Grid.ColumnSpan="2">
                                        <StackPanel Margin="5" Orientation="Horizontal">
                                            <TextBlock Text="Speed Up" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="WP_Speedup" Width="70" Margin="0,0,5,0" Height="30"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="White" BorderThickness="2" Margin="183,-17,53,27" Grid.Column="2" Grid.ColumnSpan="2">
                                        <StackPanel Margin="5,5,-5,5" Orientation="Horizontal">
                                            <TextBlock Text="Speed Dn" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="WP_Speeddn" Width="70" Margin="0,0,5,0" Height="30"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="White" BorderThickness="2" Margin="184,-17,45,27" Grid.Column="3" Grid.ColumnSpan="2">
                                        <StackPanel Margin="5,5,-9,5" Orientation="Horizontal">
                                            <TextBlock Text="Loiter Speed" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBox x:Name="WP_Loiter"  Width="60" Margin="0,0,5,0" Height="30"/>
                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- COPTER Section -->
                        <Border x:Name="COPTER_MODE" BorderBrush="Black" BorderThickness="2" Margin="22,10,13,0" Grid.Row="1" Visibility="Collapsed">
                            <StackPanel Margin="8,0,-8,0">
                                <TextBlock Text="COPTER" FontWeight="Bold" FontSize="20" Margin="10"/>

                                <!-- tuning -->
                                <Border BorderBrush="Black" BorderThickness="2" Width="980" Height="334" Margin="0,0,0,0">
                                    <StackPanel Width="1022" RenderTransformOrigin="0.503,0.806" Margin="1,0,1,-160">
                                        <TextBlock Text="TUNING" FontWeight="Bold" FontSize="16" Width="1002" Height="38"/>
                                        <Grid Margin="5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="97*"/>
                                                <RowDefinition Height="67*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180*"/>
                                                <ColumnDefinition Width="180*"/>
                                                <ColumnDefinition Width="180*"/>
                                                <ColumnDefinition Width="20*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="180*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Rate Roll -->
                                            <Border Margin="10,-7,5,0" BorderBrush="White" BorderThickness="2" Grid.Column="0"  Grid.RowSpan="2">
                                                <StackPanel Height="245" VerticalAlignment="Center">
                                                    <TextBlock Text="Rate Roll" Margin="5" FontWeight="Bold"/>
                                                    <Grid Height="210">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="RollPTextBox" Width="75" Margin="2" Text="0.1500"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="RollITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="RollDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="RollIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="RollFLTETextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="RollFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="RollFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>


                                            <!-- Rate Pitch -->
                                            <Border Margin="5,-7,5,0" BorderBrush="White" BorderThickness="2" Grid.Column="1" Grid.RowSpan="2">
                                                <StackPanel Margin="0,0,0,8">
                                                    <TextBlock Text="Rate Pitch" Margin="5" FontWeight="Bold"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="PitchPTextBox" Width="75" Margin="2" Text="0.1500" />

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="PitchITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="PitchDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="PitchIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="PitchFLTETextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="PitchFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="PitchFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="5,-7,5,0" BorderBrush="White" BorderThickness="2" Grid.Column="2" Grid.RowSpan="2">
                                                <StackPanel>
                                                    <TextBlock Text="Rate Yaw" Margin="5" FontWeight="Bold" Height="17"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>




                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="YawPTextBox" Width="75" Margin="2" Text="0.1500"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="YawITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="YawDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="YawIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="YawFLTETextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="YawFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="YawFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>
                                                        <Button Content="SAVE" Foreground="Black" Background="CornflowerBlue" Margin="-195,139,172,-130" Grid.Row="3" FontSize="17" Click="saveCopter_Click"/>

                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>


                        <Border x:Name="PLANE_MODE" BorderBrush="Black" BorderThickness="2" Margin="0,20,-11,0" Visibility="Visible" Grid.Row="1">
                            <StackPanel Margin="8,0,-8,0">
                                <TextBlock Text="PLANE" FontWeight="Bold" FontSize="20" Height="38" Margin="5,10,0,0" />
                                <Border BorderBrush="Black" BorderThickness="2" Width="1051" Height="379">
                                    <StackPanel Width="1022" RenderTransformOrigin="0.503,0.806" Margin="1,0,-75,6">
                                        <TextBlock Text="TUNING" FontWeight="Bold" FontSize="18" Width="1100" Height="32" Margin="0,5,0,0" />
                                        <Grid Margin="5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="97*"/>
                                                <RowDefinition Height="67*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="101*"/>
                                                <ColumnDefinition Width="5*"/>
                                                <ColumnDefinition Width="96*"/>
                                                <ColumnDefinition Width="101*"/>
                                                <ColumnDefinition Width="11*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="101*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Rate Roll -->
                                            <Border Margin="-44,-7,56,0" BorderBrush="White" BorderThickness="2" Grid.Column="0" Height="265" VerticalAlignment="Top">
                                                <StackPanel Height="312" VerticalAlignment="Top">
                                                    <TextBlock Text="Rate Roll" Margin="5" FontWeight="Bold" Height="30" Width="190"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="PRollPTextBox" Width="75" Margin="2"  Text="0.1500"/>
                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="PRollITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="PRollDTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="PRollIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTE -->
                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="PRollFLTETextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTD -->
                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="PRollFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTT -->
                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="PRollFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>


                                            <!-- Rate Pitch -->
                                            <Border Margin="164,-7,48,0" BorderBrush="White" BorderThickness="2" Grid.ColumnSpan="3" Height="258" VerticalAlignment="Top">
                                                <StackPanel Height="312" VerticalAlignment="Top" >
                                                    <TextBlock Text="Rate Pitch" Margin="5" FontWeight="Bold" Height="27" Width="197"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>


                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="PPitchPTextBox" Width="75" Margin="2" Text="0.1500"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="PPitchITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="PPitchDTextBox" Width="75" Margin="5" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="PPitchIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>


                                                        <!-- FLTE -->
                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="PPitchFLTETextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTD -->
                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="PPitchFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTT -->
                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="PPitchFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="159,-7,39,0" BorderBrush="White" BorderThickness="2" Grid.Column="2" Grid.ColumnSpan="2" Height="265" VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Rate Yaw" Margin="5" FontWeight="Bold" Height="31" Width="200"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>

                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="PYawPTextBox" Width="75" Margin="2" Text="0.1500"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="PYawITextBox" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="PYawDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="PYawIMAXTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>


                                                        <!-- FLTE -->
                                                        <TextBlock Text="FLTE" Margin="5" Grid.Row="4"/>
                                                        <DockPanel Grid.Row="4" Grid.Column="1">
                                                            <TextBox x:Name="PYawFLTETextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTD -->
                                                        <TextBlock Text="FLTD" Margin="5" Grid.Row="5"/>
                                                        <DockPanel Grid.Row="5" Grid.Column="1">
                                                            <TextBox x:Name="PYawFLTDTextBox" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- FLTT -->
                                                        <TextBlock Text="FLTT" Margin="5" Grid.Row="6"/>
                                                        <DockPanel Grid.Row="6" Grid.Column="1">
                                                            <TextBox x:Name="PYawFLTTTextBox" Width="75" Margin="2" Text="0.0040"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Velocity XY(Vel to Accel -->
                                            <Border Margin="178,-7,34,0" BorderBrush="White" BorderThickness="2" Grid.Column="3" Grid.ColumnSpan="3" Height="168" VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Velocity XY(Vel to Accel)" Margin="5" FontWeight="Bold" Height="31" Width="182"/>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>

                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />

                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="P" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="VelP"  Width="75" Margin="2" Text="0.1500"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="I" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="VelI" Width="75" Margin="2" Text="0.1000"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="D" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="VelD" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>

                                                        <!-- IMAX -->
                                                        <TextBlock Text="IMAX" Margin="5" Grid.Row="3"/>
                                                        <DockPanel Grid.Row="3" Grid.Column="1">
                                                            <TextBox x:Name="VelIMAX" Width="75" Margin="2" Text="0.0040"/>

                                                        </DockPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="161,-7,33,0" BorderBrush="White" BorderThickness="2" Grid.Column="5" Grid.ColumnSpan="2" Height="200" VerticalAlignment="Top">
                                                <StackPanel>
                                                    <TextBlock Text="Safety" Margin="5" FontWeight="Bold" Height="27" Width="177"/>
                                                    <Grid Height="148">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- P -->
                                                        <TextBlock Text="Pitch Min" Margin="5" Grid.Row="0"/>
                                                        <DockPanel Grid.Row="0" Grid.Column="1">
                                                            <TextBox x:Name="PitchMin" Width="75" Margin="2" Text="0"/>

                                                        </DockPanel>

                                                        <!-- I -->
                                                        <TextBlock Text="Pitch Max" Margin="5" Grid.Row="1"/>
                                                        <DockPanel Grid.Row="1" Grid.Column="1">
                                                            <TextBox x:Name="PitchMax" Width="75" Margin="2" Text="0"/>

                                                        </DockPanel>

                                                        <!-- D -->
                                                        <TextBlock Text="Roll" Margin="5" Grid.Row="2"/>
                                                        <DockPanel Grid.Row="2" Grid.Column="1">
                                                            <TextBox x:Name="RollLimit" Width="75" Margin="2" Text="0"/>
                                                        </DockPanel>

                                                        <Button Content="SEND" Foreground="Black" Background="CornflowerBlue" Grid.Row="3" FontSize="17" Click="saveSafety_Click" Grid.ColumnSpan="2" Margin="46,5,33,-5"/>



                                                        <Button Content="SEND" Foreground="Black" Background="CornflowerBlue" Margin="-458,174,441,-150" Grid.Row="2" FontSize="17" Click="saveQplane_Click"/>

                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Halaman ESC Calibration -->
            <Grid x:Name="EscCalib" Grid.Row="1" Margin="20" Visibility="Collapsed">
                <Border BorderBrush="Gray" BorderThickness="2" CornerRadius="5" Padding="10">
                    <Grid Background="DarkGray">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="ESC Calibration" FontWeight="Bold" FontSize="20" Grid.Row="0" HorizontalAlignment="Center"/>

                        <TextBlock Text="Pastikan motor tidak menyentuh tanah!" Foreground="Red" Grid.Row="1" HorizontalAlignment="Center"/>

                        <Slider x:Name="PwmSlider" Minimum="1000" Maximum="2000" Value="1500" Grid.Row="2" Margin="10" TickFrequency="50" IsSnapToTickEnabled="True"/>

                        <TextBlock x:Name="PwmValueLabel" Text="{Binding ElementName=PwmSlider, Path=Value, StringFormat={}{0:N0}}" 
                                   HorizontalAlignment="Center" Grid.Row="3"/>

                        <ComboBox x:Name="MotorChannelComboBox" SelectedIndex="0" Grid.Row="4" HorizontalAlignment="Center" Width="120" Margin="5">
                            <ComboBoxItem Content="Motor 1" Tag="1"/>
                            <ComboBoxItem Content="Motor 2" Tag="2"/>
                            <ComboBoxItem Content="Motor 3" Tag="3"/>
                            <ComboBoxItem Content="Motor 4" Tag="4"/>
                        </ComboBox>

                        <UniformGrid Grid.Row="5" Columns="3" HorizontalAlignment="Center" Margin="10">
                            <Button Content="Min" Width="100" Click="SendMinPwm_Click"/>
                            <Button Content="Mid" Width="100" Click="SendMidPwm_Click"/>
                            <Button Content="Max" Width="100" Click="SendMaxPwm_Click"/>
                        </UniformGrid>

                        <TextBlock x:Name="StatusLabel" Text="Status: Siap" HorizontalAlignment="Center" Grid.Row="6"/>

                        <Button Content="Auto Calibrate" Width="150" Grid.Row="7" HorizontalAlignment="Center" VerticalAlignment="Center" Click="AutoCalibrateAllMotors"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Motor Test Grid - Mission Planner Style -->
            <Grid x:Name="MotorTestGrid" Grid.Row="1" Margin="20" Visibility="Collapsed">
                <Border BorderBrush="White" BorderThickness="2" CornerRadius="5" Padding="15">
                    <Grid Background="#FF2D2D30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Title -->
                        <TextBlock Text="MOTOR TEST" FontWeight="Bold" FontSize="22" Grid.Row="0" 
                                   HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,5"/>

                        <!-- Warning -->
                        <Border Grid.Row="1" Background="#FFCC0000" CornerRadius="3" Padding="10,5" Margin="0,5" HorizontalAlignment="Center">
                            <TextBlock Text="⚠️ LEPASKAN SEMUA PROPELLER SEBELUM TES!" 
                                       Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Throttle and Duration Controls -->
                        <Grid Grid.Row="2" Margin="10,15,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Throttle Control -->
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Throttle %" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                <Slider x:Name="MotorPwmSlider" Minimum="1000" Maximum="2000" Value="1150" 
                                        TickFrequency="50" IsSnapToTickEnabled="True" Margin="5"/>
                                <TextBlock x:Name="ThrottlePercentDisplay" 
                                           Text="{Binding ElementName=MotorPwmSlider, Path=Value, StringFormat={}{0:N0} PWM}"
                                           Foreground="Lime" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Duration Control -->
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Duration (sec)" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                <Slider x:Name="MotorDurationSlider" Minimum="1" Maximum="5" Value="2" 
                                        TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="5"/>
                                <TextBlock Text="{Binding ElementName=MotorDurationSlider, Path=Value, StringFormat={}{0:F1} detik}" 
                                           Foreground="Lime" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Motor Buttons Layout (Quadcopter X-frame style) -->
                        <Grid Grid.Row="3" HorizontalAlignment="Center" Margin="0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Motor A (Front Right) -->
                            <Button x:Name="MotorABtn" Grid.Row="0" Grid.Column="2" 
                                    Width="100" Height="60" Margin="5"
                                    Background="#FF1E90FF" Foreground="White" FontWeight="Bold" FontSize="16"
                                    Click="TestMotor_Click" Tag="1">
                                <StackPanel>
                                    <TextBlock Text="Motor A" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(CCW)" FontSize="10" HorizontalAlignment="Center" Foreground="LightGray"/>
                                </StackPanel>
                            </Button>

                            <!-- Motor B (Front Left) -->
                            <Button x:Name="MotorBBtn" Grid.Row="0" Grid.Column="0" 
                                    Width="100" Height="60" Margin="5"
                                    Background="#FF1E90FF" Foreground="White" FontWeight="Bold" FontSize="16"
                                    Click="TestMotor_Click" Tag="2">
                                <StackPanel>
                                    <TextBlock Text="Motor B" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(CW)" FontSize="10" HorizontalAlignment="Center" Foreground="LightGray"/>
                                </StackPanel>
                            </Button>

                            <!-- Center indicator (Drone body) -->
                            <Border Grid.Row="1" Grid.Column="1" 
                                    Background="#FF404040" CornerRadius="25" 
                                    Width="50" Height="50" Margin="5">
                                <TextBlock Text="✈" FontSize="24" Foreground="White" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Motor C (Rear Left) -->
                            <Button x:Name="MotorCBtn" Grid.Row="2" Grid.Column="0" 
                                    Width="100" Height="60" Margin="5"
                                    Background="#FF1E90FF" Foreground="White" FontWeight="Bold" FontSize="16"
                                    Click="TestMotor_Click" Tag="3">
                                <StackPanel>
                                    <TextBlock Text="Motor C" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(CCW)" FontSize="10" HorizontalAlignment="Center" Foreground="LightGray"/>
                                </StackPanel>
                            </Button>

                            <!-- Motor D (Rear Right) -->
                            <Button x:Name="MotorDBtn" Grid.Row="2" Grid.Column="2" 
                                    Width="100" Height="60" Margin="5"
                                    Background="#FF1E90FF" Foreground="White" FontWeight="Bold" FontSize="16"
                                    Click="TestMotor_Click" Tag="4">
                                <StackPanel>
                                    <TextBlock Text="Motor D" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(CW)" FontSize="10" HorizontalAlignment="Center" Foreground="LightGray"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Action Buttons -->
                        <UniformGrid Grid.Row="4" Columns="2" HorizontalAlignment="Center" Margin="0,15,0,10">
                            <Button x:Name="TestAllMotorsBtn" Content="TEST ALL (A→B→C→D)" 
                                    Width="180" Height="40" Margin="5"
                                    Background="#FF228B22" Foreground="White" FontWeight="Bold" FontSize="13"
                                    Click="TestAllMotors_Click"/>
                            <Button x:Name="StopAllMotorsBtn" Content="STOP ALL MOTORS" 
                                    Width="180" Height="40" Margin="5"
                                    Background="#FFDC143C" Foreground="White" FontWeight="Bold" FontSize="13"
                                    Click="StopAllMotors_Click"/>
                        </UniformGrid>

                        <!-- Status -->
                        <Border Grid.Row="5" Background="#FF1A1A1A" CornerRadius="3" Padding="10" Margin="0,5" VerticalAlignment="Top">
                            <TextBlock x:Name="MotorTestStatus" Text="Status: Siap - Pilih motor untuk dites" 
                                       HorizontalAlignment="Center" Foreground="#FF00FF00" FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

