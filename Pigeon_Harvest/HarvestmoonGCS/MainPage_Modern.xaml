<Page x:Class="HarvestmoonGCS.MainPage_Modern"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:HarvestmoonGCS"
      xmlns:controls="using:HarvestmoonGCS.Controls"
      xmlns:piacontrols="using:HarvestmoonGCS.Views.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="RootHost">
        <Grid x:Name="RootLayout">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="Auto"/>
                <ColumnDefinition x:Name="ContentColumn" Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:ModernSidebar x:Name="Sidebar" Grid.Column="0"
                                    NavigationRequested="Sidebar_NavigationRequested"/>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:ModernTopBar x:Name="TopBar" Grid.Row="0"
                                       ExitClicked="TopBar_ExitClicked"
                                       ConnectClicked="TopBar_ConnectClicked"/>

                <!-- Frame tanpa animasi untuk performance lebih baik -->
                <Frame x:Name="ContentFrame" Grid.Row="1" />
            </Grid>

            <!-- Loading Overlay -->
            <controls:LoadingIndicator x:Name="MainLoadingIndicator" 
                                      Grid.ColumnSpan="2"
                                      IsLoading="False" 
                                      LoadingText="Loading..."/>

            <Border x:Name="ObservabilityOverlay"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,64,16,0"
                    MinWidth="140"
                    MaxWidth="440"
                    MaxHeight="360"
                    Padding="12"
                    Background="{ThemeResource CardBrush80}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Canvas.ZIndex="50"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ObservabilityText"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{ThemeResource ForegroundBrush}"
                               Text="Waiting for telemetry..."
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>

#if !__WASM__
            <!-- PIA Panel Overlay -->
            <piacontrols:PIAPanel x:Name="PIAPanelOverlay"
                                  Grid.Column="1"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Stretch"
                                  Canvas.ZIndex="100"
                                  Visibility="Collapsed"/>
#endif
        </Grid>
    </Grid>
</Page>
