# Pigeon Uno QuadPlane 4+1 SITL preset.
# 4 lift motors in quad X layout plus the normal ArduPlane forward motor.

SYSID_THISMAV 1
ARMING_CHECK 0
LOG_DISARMED 1

Q_ENABLE 1
Q_FRAME_CLASS 1
Q_FRAME_TYPE 1
Q_TILT_ENABLE 0
Q_TAILSIT_ENABLE 0
Q_TRANSITION_MS 5000
Q_ASSIST_SPEED 0
Q_RTL_MODE 1

SERVO9_FUNCTION 0
SERVO9_MIN 1000
SERVO9_TRIM 1100
SERVO9_MAX 2000

WP_RADIUS 15
NAVL1_PERIOD 18
TECS_SPDWEIGHT 1.0

SIM_SPEEDUP 1
