<UserControl x:Class="Pigeon_Uno.Controls.Avionics.TurnCoordinator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:SkiaSharp.Views.Windows"
             Width="200" Height="200">
    
    <Grid>
        <!-- SkiaSharp canvas for rendering the turn coordinator -->
        <skia:SKXamlCanvas x:Name="TurnCanvas"
                          PaintSurface="OnPaintSurface"/>
        
        <!-- Digital readout overlay -->
        <Border Background="#CC000000"
                BorderBrush="White"
                BorderThickness="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Padding="8,4"
                Margin="0,0,0,10"
                CornerRadius="4">
            <TextBlock x:Name="TurnRateText"
                      Text="0.0°/s"
                      Foreground="Lime"
                      FontWeight="Bold"
                      FontSize="14"
                      FontFamily="Consolas"/>
        </Border>
    </Grid>
</UserControl>
