<UserControl x:Class="Pigeon_Uno.Controls.SkiaMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:skia="using:SkiaSharp.Views.Windows"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="MapContainer" Background="#FF2C3E50">
        <!-- SkiaSharp Canvas for map rendering -->
        <skia:SKXamlCanvas x:Name="mapCanvas" 
                          PaintSurface="OnPaintSurface"
                          PointerPressed="OnPointerPressed"
                          PointerMoved="OnPointerMoved"
                          PointerReleased="OnPointerReleased"
                          PointerWheelChanged="OnPointerWheelChanged"/>
        
        <!-- Waypoint Overlay Canvas -->
        <Canvas x:Name="waypointOverlay" 
                Background="Transparent"
                IsHitTestVisible="False"/>
        
        <!-- Map controls overlay -->
        <StackPanel x:Name="MapControlsPanel" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="btnZoomIn" 
                    Content="+" 
                    Width="40" 
                    Height="40" 
                    FontSize="20"
                    Background="#CC2C3E50"
                    Foreground="White"
                    Margin="0,0,0,5"
                    Click="BtnZoomIn_Click"/>
            <Button x:Name="btnZoomOut" 
                    Content="-" 
                    Width="40" 
                    Height="40" 
                    FontSize="20"
                    Background="#CC2C3E50"
                    Foreground="White"
                    Margin="0,0,0,5"
                    Click="BtnZoomOut_Click"/>
            <Button x:Name="btnCenterMap" 
                    Content="⊙" 
                    Width="40" 
                    Height="40" 
                    FontSize="20"
                    Background="#CC2C3E50"
                    Foreground="White"
                    Click="BtnCenterMap_Click"
                    ToolTipService.ToolTip="Center on vehicle"/>
        </StackPanel>
        
        <!-- Coordinates display - HIDDEN -->
        <Border Background="#CC000000" 
                Padding="10,5" 
                CornerRadius="5"
                HorizontalAlignment="Left" 
                VerticalAlignment="Bottom" 
                Margin="10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="txtMapCoordinates" 
                          Text="Lat: -7.2754, Lon: 112.7947" 
                          Foreground="White" 
                          FontSize="12"
                          FontFamily="Consolas"/>
                <TextBlock x:Name="txtMapZoom" 
                          Text="Zoom: 15" 
                          Foreground="#FFBDC3C7" 
                          FontSize="10"
                          FontFamily="Consolas"
                          Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Loading indicator -->
        <Grid x:Name="loadingPanel" Background="#80000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressRing IsActive="True" Width="50" Height="50" Foreground="White"/>
                <TextBlock Text="Loading map tiles..." 
                          Foreground="White" 
                          FontSize="14" 
                          Margin="0,10,0,0"
                          HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
