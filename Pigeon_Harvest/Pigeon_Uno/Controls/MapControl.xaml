<UserControl x:Class="Pigeon_Uno.Controls.MapControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="using:Pigeon_Uno.Controls"
      xmlns:controls="using:Pigeon_Uno.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="632" d:DesignWidth="1132" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{ThemeResource BackgroundBrush}">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="CustomButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid HorizontalAlignment="Stretch" Margin="0" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Grid.Row="1">
            <!-- SkiaSharp Map Control with OpenStreetMap -->
            <controls:SkiaMapControl x:Name="mapControl"
                                     Margin="2.5,0,2.5,2.5"
                                     DoubleTapped="MapControl_DoubleTapped"/>
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,15,15,0" Orientation="Horizontal">
                <Border x:Name="follow_wahana_border" Background="{ThemeResource PrimaryBrush}" CornerRadius="16" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0" BorderThickness="1">
                    <Button Style="{StaticResource CustomButton}" ToolTipService.ToolTip="Pusatkan pada Wahana" BorderBrush="{x:Null}" Background="{x:Null}" Margin="0" Click="FollowVehicle_Click">
                        <Image Source="ms-appx:///Assets/icons/ikon-wahana-pesawat-3.png" RenderTransformOrigin="0.5,0.5"/>
                    </Button>
                </Border>
                <TextBlock x:Name="follow_wahana_label" Text="Klik untuk mengikuti Wahana >>" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{ThemeResource ForegroundBrush}" Visibility="Collapsed" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
        <TextBlock x:Name="judul_map" Text="Map View" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="36" FontFamily="Century Gothic" FontWeight="Bold" Foreground="{ThemeResource AccentForegroundBrush}" Margin="0" Padding="10,5" Height="54" Width="318" Grid.ColumnSpan="2"/>

        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="462,10,0,0" Orientation="Horizontal">
            <TextBlock x:Name="peta" Text="Pilih Peta:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="cb_map_type" SelectionChanged="ChooseMap" SelectedIndex="0" Width="180">
                <ComboBoxItem Content="ArcGIS Topografi"/>
                <ComboBoxItem Content="ArcGIS Imagery"/>
                <ComboBoxItem Content="ArcGIS Streetmap"/>
                <ComboBoxItem Content="Google Map"/>
                <ComboBoxItem Content="Google Satellite"/>
                <ComboBoxItem Content="Google Terrain"/>
                <ComboBoxItem Content="Google Hybrid"/>
            </ComboBox>
            <TextBlock Text="WP RADIUS:" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
            <TextBox x:Name="tb_radius" Text="2" Width="60" FontSize="15" Margin="0,0,5,0" VerticalAlignment="Center"
                     Background="{ThemeResource InputBrush}" Foreground="{ThemeResource ForegroundBrush}"/>
            <TextBlock Text="Command" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="SemiBold"/>
            <Button BorderBrush="{x:Null}" Width="30" Height="30" Click="SendWaypointCommand" Margin="0" Background="Transparent" Padding="2">
                <Image Source="ms-appx:///Assets/icons/icons8-email-send-80.png" Margin="0"/>
            </Button>
            <TextBlock Text="Total Distance:" VerticalAlignment="Center" Margin="15,0,5,0" FontWeight="SemiBold"/>
            <TextBlock x:Name="tb_total_distance" Text="0.00 km" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold" Foreground="{ThemeResource AccentForegroundBrush}"/>
        </StackPanel>

        
        <Button x:Name="btn_geofence_toggle" Grid.Row="1"
                Content="🔲 Geofence" 
                Width="90" Height="26"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,14,57,0"
                Background="{ThemeResource InfoBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}"
                FontWeight="Bold" FontSize="11"
                Click="ToggleGeofencePanel_Click"
                ToolTipService.ToolTip="Buka/Tutup panel geofencing" Grid.Column="1"/>

        
        <Border x:Name="geofence_panel" Grid.Row="1" Grid.ColumnSpan="2" 
                Background="{ThemeResource CardBrush95}" CornerRadius="8" 
                HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0,40,15,0" Padding="12"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="⬡ GEOFENCE SETTINGS" Foreground="{ThemeResource ForegroundBrush}" FontWeight="Bold" FontSize="12"/>
                    <Border x:Name="geofence_status_border" Background="{ThemeResource SecondaryBrush}" CornerRadius="3" 
                            Margin="10,0,0,0" Padding="6,2">
                        <TextBlock x:Name="geofence_status_text" Text="Inactive" Foreground="{ThemeResource ForegroundBrush}" 
                                   FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>

                <!-- Type, Radius, and Altitude Row -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Type:" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Padding="0,0,5,0"/>
                    <ComboBox x:Name="cb_geofence_type" Width="80" Height="24" SelectedIndex="0" FontSize="11"
                              SelectionChanged="GeofenceType_SelectionChanged">
                        <ComboBoxItem Content="Circular"/>
                        <ComboBoxItem Content="Polygon"/>
                    </ComboBox>
<TextBlock Text="Radius:" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Margin="8,0,3,0"/>
                     <TextBox x:Name="tb_geofence_radius" Text="500" Width="45" Height="22" FontSize="11"
                              Background="{ThemeResource InputBrush}" Foreground="{ThemeResource ForegroundBrush}"
                              ToolTipService.ToolTip="Radius dalam meter"
                              TextChanged="GeofenceRadius_TextChanged"/>
                     <TextBlock Text="m" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Padding="2,0,0,0"/>
                     <TextBlock Text="Max Alt:" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Margin="8,0,3,0"/>
                     <TextBox x:Name="tb_geofence_altitude" Text="100" Width="45" Height="22" FontSize="11"
                              Background="{ThemeResource InputBrush}" Foreground="{ThemeResource ForegroundBrush}"
                              ToolTipService.ToolTip="Altitude maksimum dalam meter"
                              TextChanged="GeofenceAltitude_TextChanged"/>
                    <TextBlock Text="m" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Padding="2,0,0,0"/>
                </StackPanel>

                <!-- Coordinate Input -->
                <Border Grid.Row="2" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="4" 
                        Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="📍 Set Center by Coordinates:" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="10" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
<TextBlock Text="Lat:" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Padding="0,0,3,0" FontSize="11"/>
                             <TextBox x:Name="tb_geofence_lat" Text="" Width="100" Height="22" FontSize="11"
                                      Background="{ThemeResource InputBrush}" Foreground="{ThemeResource ForegroundBrush}"
                                      ToolTipService.ToolTip="Latitude (contoh: -7.2754)"/>
                             <TextBlock Text="Lon:" Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" Margin="8,0,3,0" FontSize="11"/>
                             <TextBox x:Name="tb_geofence_lon" Text="" Width="100" Height="22" FontSize="11"
                                      Background="{ThemeResource InputBrush}" Foreground="{ThemeResource ForegroundBrush}"
                                      ToolTipService.ToolTip="Longitude (contoh: 112.7947)"/>
                            <Button x:Name="btn_set_center" Content="Set" Width="40" Height="22" Margin="8,0,0,0"
                                    Background="{ThemeResource InfoBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" FontSize="10" FontWeight="Bold"
                                    Click="SetGeofenceCenter_Click" ToolTipService.ToolTip="Set center geofence dari koordinat"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Polygon Points List -->
                <Border x:Name="geofence_points_border" Grid.Row="3" 
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="4" 
                        Padding="6" Margin="0,0,0,8" Visibility="Collapsed" MaxHeight="120">
                    <StackPanel>
                        <TextBlock Text="📐 Polygon Vertices:" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="10" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="80">
                            <ItemsControl x:Name="geofence_points_list">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource AccentBrush}" CornerRadius="2" Margin="0,1" Padding="4,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="10" Foreground="{ThemeResource InfoBrush}" FontWeight="Bold" Text="{Binding Index}"/>
                                                <TextBlock FontSize="10" Foreground="{ThemeResource ForegroundBrush}" Text=" | Lat: "/>
                                                <TextBlock FontSize="10" Foreground="{ThemeResource SuccessBrush}">
                                                    <Run Text="{Binding LatFormatted}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="{ThemeResource ForegroundBrush}" Text=" | Lon: "/>
                                                <TextBlock FontSize="10" Foreground="{ThemeResource SuccessBrush}">
                                                    <Run Text="{Binding LonFormatted}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton x:Name="btn_geofence_mode" Content="✏ Draw" 
                                  Width="60" Height="24"
                                  Background="{ThemeResource SecondaryBrush}" Foreground="{ThemeResource ForegroundBrush}" FontSize="10"
                                  Click="ToggleGeofenceMode_Click"
                                  ToolTipService.ToolTip="Aktifkan mode menggambar di peta"/>
                    <Button x:Name="btn_complete_geofence" Content="✓" 
                            Width="28" Height="24" Margin="5,0,0,0"
                            Background="{ThemeResource SuccessBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" FontWeight="Bold"
                            Click="CompleteGeofence_Click" Visibility="Collapsed"
                            ToolTipService.ToolTip="Selesaikan polygon"/>
                    <Button x:Name="btn_send_geofence" Content="📤 Send" 
                            Width="55" Height="24" Margin="5,0,0,0"
                            Background="{ThemeResource SuccessBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" FontSize="10"
                            Click="SendGeofence_Click" IsEnabled="False"
                            ToolTipService.ToolTip="Kirim ke wahana"/>
                    <Button x:Name="btn_clear_geofence" Content="✕" 
                            Width="28" Height="24" Margin="5,0,0,0"
                            Background="{ThemeResource ErrorBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" FontWeight="Bold"
                            Click="ClearGeofence_Click" IsEnabled="False"
                            ToolTipService.ToolTip="Hapus geofence"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 🔸 Waypoint Dock Panel (Status Bar) -->
        <StackPanel x:Name="wp_dock" Grid.Row="1" Margin="0,0,0,1" Height="25" VerticalAlignment="Bottom" Width="911" HorizontalAlignment="Left" Grid.ColumnSpan="2" Orientation="Vertical">
            <Grid Height="28" Width="550">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="0*"/>
                </Grid.ColumnDefinitions>
                <Polygon Points="0,22.5 20,0 100,0 120,22.5" Fill="{ThemeResource BackgroundBrush80}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="70,0,0,0"/>
                <Button x:Name="wp_dock_btn" Content="Markers ▲" Padding="2" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{x:Null}" BorderBrush="{x:Null}" Foreground="{ThemeResource ForegroundBrush}" Click="ToggleWPDock" Margin="99,0,0,0"/>
                <Button x:Name="reset_mark" Content="Reset" Margin="411,0,0,-2" Click="ResetMarkers_Click" Background="{ThemeResource ButtonBackgroundColor}" FontFamily="{StaticResource RalewayFont}" Foreground="{ThemeResource PrimaryTextColor}" BorderBrush="{ThemeResource BorderColor}" Height="30" Width="40" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <Button x:Name="Undo" Content="Undo" Margin="331,0,0,-2" Click="Undo_Click" Background="{ThemeResource ButtonBackgroundColor}" FontFamily="{StaticResource RalewayFont}" Foreground="{ThemeResource PrimaryTextColor}" BorderBrush="{ThemeResource BorderColor}" Height="30" Width="40" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <Button x:Name="Redo" Content="Redo" Margin="371,-1,0,-1" Click="Redo_Click" Background="{ThemeResource ButtonBackgroundColor}" FontFamily="{StaticResource RalewayFont}" Foreground="{ThemeResource PrimaryTextColor}" BorderBrush="{ThemeResource BorderColor}" Height="30" Width="40" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <Button x:Name="Import" Content="Import" Margin="499,0,0,-2" Click="ImportWaypoints_Click" Background="{ThemeResource ButtonBackgroundColor}" FontFamily="{StaticResource RalewayFont}" Foreground="{ThemeResource PrimaryTextColor}" BorderBrush="{ThemeResource BorderColor}" Height="30" Width="50" HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <Button x:Name="Export" Content="Export"  Margin="265,0,50,0" Click="ExportWaypoints_Click" Background="{ThemeResource ButtonBackgroundColor}" FontFamily="{StaticResource RalewayFont}" Foreground="{ThemeResource PrimaryTextColor}" BorderBrush="{ThemeResource BorderColor}"  Height="30" Width="50" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>
            <Border BorderBrush="{ThemeResource BorderColor}" BorderThickness="0,0,0,1" Margin="0" Background="{ThemeResource BackgroundBrush80}" CornerRadius="5,5,0,0">
                <ScrollViewer Margin="0,5,5,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="wp_dock_stack">
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
