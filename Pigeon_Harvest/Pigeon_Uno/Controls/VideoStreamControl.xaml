<UserControl x:Class="Pigeon_Uno.Controls.VideoStreamControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:SkiaSharp.Views.Windows">
    
    <Grid>
        <!-- Background image (logo) - shown when not streaming -->
        <Image x:Name="BackgroundImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Visibility="Visible" />
        
        <!-- SkiaSharp canvas for video rendering -->
        <skia:SKXamlCanvas x:Name="VideoCanvas"
                          PaintSurface="OnPaintSurface"
                          Background="Transparent"
                          Visibility="Collapsed" />
        
        <!-- Overlay for status messages -->
        <Grid x:Name="OverlayGrid"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Visibility="Collapsed">
            <StackPanel Spacing="10">
                <TextBlock x:Name="StatusText"
                          Text="No video stream"
                          Foreground="White"
                          FontSize="16"
                          HorizontalAlignment="Center"
                          TextAlignment="Center" />
                
                <ProgressRing x:Name="LoadingRing"
                             IsActive="False"
                             Foreground="White"
                             Width="40"
                             Height="40"
                             HorizontalAlignment="Center"
                             Visibility="Collapsed" />
            </StackPanel>
        </Grid>
        
        <!-- FPS counter (debug) -->
        <TextBlock x:Name="FpsCounter"
                  Text="FPS: 0"
                  Foreground="Yellow"
                  FontSize="12"
                  Margin="10"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Right"
                  Visibility="Collapsed" />
    </Grid>
</UserControl>
