<UserControl x:Class="Pigeon_Uno.Controls.LoRaControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="using:Pigeon_Uno.Controls"
      xmlns:converters="using:Pigeon_Uno.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200">
    <UserControl.Resources>
        <converters:BoolToStatusColorConverter x:Key="StatusColorConverter"/>
    </UserControl.Resources>
    <Grid Background="{ThemeResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.ColumnSpan="2" Background="{ThemeResource CardBrush}" Padding="15,10">
            <Grid>
                <TextBlock Text="📡 LoRa Relay Network" FontSize="28" FontWeight="Bold" 
                           Foreground="{ThemeResource ForegroundBrush}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="tb_status" Text="{Binding StatusText, Mode=OneWay}" Foreground="{ThemeResource MutedForegroundBrush}" 
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <ComboBox x:Name="cb_ports" Width="100" FontSize="12" Margin="0,0,10,0"
                              ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort, Mode=TwoWay}"/>
                    <Button x:Name="btn_connect" Content="{Binding ConnectionButtonText, Mode=OneWay}" Width="80" Height="30" 
                            FontSize="14" Click="ToggleConnection"
                            Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderBrush="{x:Null}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Panel - Node List -->
        <Border Grid.Row="1" Background="{ThemeResource CardBrush}" Margin="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10">
                    <TextBlock Text="NODES" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="12" 
                               FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <ItemsControl x:Name="ic_nodes" ItemsSource="{Binding Nodes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource SecondaryBrush}" CornerRadius="8" 
                                        Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Status indicator -->
                                        <Ellipse Width="12" Height="12" 
                                                 Fill="{Binding IsOnline, Converter={StaticResource StatusColorConverter}}"
                                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        
                                        <!-- Node name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                                   Foreground="{ThemeResource ForegroundBrush}" FontSize="16" FontWeight="Bold"/>
                                        
                                        <!-- Battery -->
                                        <TextBlock Grid.Column="2" Text="{Binding BatteryPercent, Mode=OneWay}" 
                                                   Foreground="{ThemeResource SuccessBrush}" FontSize="14" FontWeight="Bold"/>
                                        
                                        <!-- Signal -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="RSSI: " Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding RSSI, Mode=OneWay}" 
                                                       Foreground="{ThemeResource ForegroundBrush}" FontSize="11"/>
                                            <TextBlock Text=" dBm  |  SNR: " Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding SNR, Mode=OneWay}" 
                                                       Foreground="{ThemeResource ForegroundBrush}" FontSize="11"/>
                                            <TextBlock Text=" dB" Foreground="{ThemeResource ForegroundBrush}" FontSize="11"/>
                                        </StackPanel>
                                        
                                        <!-- GPS -->
                                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="📍 " Foreground="{ThemeResource WarningBrush}" FontSize="11"/>
                                            <TextBlock Text="{Binding LocationString}" 
                                                       Foreground="{ThemeResource InfoBrush}" FontSize="11"/>
                                        </StackPanel>
                                        
                                        <!-- Sensors -->
                                        <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="🌡️ " FontSize="11"/>
                                            <TextBlock Text="{Binding Temperature, Mode=OneWay}" 
                                                       Foreground="{ThemeResource WarningBrush}" FontSize="11"/>
                                            <TextBlock Text="  💧 " FontSize="11"/>
                                            <TextBlock Text="{Binding Humidity, Mode=OneWay}" 
                                                       Foreground="{ThemeResource InfoBrush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Statistics -->
                    <Border Background="{ThemeResource SecondaryBrush}" CornerRadius="8" Padding="12" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="STATISTICS" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11" 
                                       FontWeight="Bold" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="Packets:" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock x:Name="tb_packets" Grid.Column="1" Text="{Binding PacketCount, Mode=OneWay}" 
                                           Foreground="{ThemeResource ForegroundBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                
                                <TextBlock Grid.Row="1" Text="Online:" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock x:Name="tb_online" Grid.Row="1" Grid.Column="1" Text="{Binding OnlineNodesText, Mode=OneWay}" 
                                           Foreground="{ThemeResource SuccessBrush}" FontSize="11" HorizontalAlignment="Right"/>
                                
                                <TextBlock Grid.Row="2" Text="Last Update:" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="11"/>
                                <TextBlock x:Name="tb_lastupdate" Grid.Row="2" Grid.Column="1" Text="{Binding LastUpdateText, Mode=OneWay}" 
                                           Foreground="{ThemeResource ForegroundBrush}" FontSize="11" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Panel - Map/Info Area -->
        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBrush}" Margin="5" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Topology Diagram -->
                <Border Background="{ThemeResource SecondaryBrush}" Margin="15" Padding="20" CornerRadius="8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="RELAY TOPOLOGY" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="12" 
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Node 3 -->
                            <StackPanel>
                                <Ellipse x:Name="node3_indicator" Width="50" Height="50" 
                                         Fill="{Binding Node3Status, Converter={StaticResource StatusColorConverter}}"
                                         Stroke="{ThemeResource BorderBrush}" StrokeThickness="2"/>
                                <TextBlock Text="Node 3" Foreground="{ThemeResource ForegroundBrush}" FontSize="10" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                <TextBlock Text="(End)" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="9" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Arrow -->
                            <TextBlock Text="  ───▶  " Foreground="{ThemeResource MutedForegroundBrush}" FontSize="16" 
                                       VerticalAlignment="Center" Margin="10,0"/>
                            
                            <!-- Node 2 -->
                            <StackPanel>
                                <Ellipse x:Name="node2_indicator" Width="50" Height="50" 
                                         Fill="{Binding Node2Status, Converter={StaticResource StatusColorConverter}}"
                                         Stroke="{ThemeResource BorderBrush}" StrokeThickness="2"/>
                                <TextBlock Text="Node 2" Foreground="{ThemeResource ForegroundBrush}" FontSize="10" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                <TextBlock Text="(Relay)" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="9" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Arrow -->
                            <TextBlock Text="  ───▶  " Foreground="{ThemeResource MutedForegroundBrush}" FontSize="16" 
                                       VerticalAlignment="Center" Margin="10,0"/>
                            
                            <!-- Node 1 -->
                            <StackPanel>
                                <Ellipse x:Name="node1_indicator" Width="50" Height="50" 
                                         Fill="{Binding Node1Status, Converter={StaticResource StatusColorConverter}}"
                                         Stroke="{ThemeResource BorderBrush}" StrokeThickness="2"/>
                                <TextBlock Text="Node 1" Foreground="{ThemeResource ForegroundBrush}" FontSize="10" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                <TextBlock Text="(Gateway)" Foreground="{ThemeResource MutedForegroundBrush}" FontSize="9" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Arrow to GCS -->
                            <TextBlock Text="  ───▶  " Foreground="{ThemeResource InfoBrush}" FontSize="16" 
                                       VerticalAlignment="Center" Margin="10,0"/>
                            
                            <!-- GCS -->
                            <StackPanel>
                                <Border Width="60" Height="50" Background="{ThemeResource PrimaryBrush}" 
                                        CornerRadius="5" BorderBrush="{ThemeResource InfoBrush}" BorderThickness="2">
                                    <TextBlock Text="📡" FontSize="24" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="GCS" Foreground="{ThemeResource ForegroundBrush}" FontSize="10" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Info/Logs Area -->
                <Border Grid.Row="1" Background="{ThemeResource SecondaryBrush}" Margin="15,0,15,15" 
                        Padding="15" CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="EVENT LOG" Foreground="{ThemeResource MutedForegroundBrush}" 
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="tb_log" Background="Transparent" Foreground="{ThemeResource SuccessBrush}" 
                                     FontFamily="Consolas" FontSize="11" BorderBrush="{x:Null}"
                                     IsReadOnly="True" TextWrapping="Wrap" 
                                     Text="{Binding EventLog, Mode=OneWay}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
