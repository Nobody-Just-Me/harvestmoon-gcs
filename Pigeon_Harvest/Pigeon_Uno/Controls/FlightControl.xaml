<UserControl x:Class="Pigeon_Uno.Controls.FlightControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="using:Pigeon_Uno.Controls"
      xmlns:controls="using:Pigeon_Uno.Controls.Avionics"
      xmlns:map="using:Pigeon_Uno.Controls"
      mc:Ignorable="d"
      d:DesignHeight="825" d:DesignWidth="1505"
      Background="{ThemeResource BackgroundBrush}">
    <UserControl.Resources>
        <x:String x:Key="String1">N/A</x:String>
    </UserControl.Resources>
    <Grid Background="{ThemeResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="500*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="618*"/>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="301*"/>
            <ColumnDefinition Width="317*"/>
        </Grid.ColumnDefinitions>

        <!-- Title with Vehicle Icon -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
            <Image x:Name="img_vehicle_icon" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,10,0"
                   Source="ms-appx:///Assets/icons/ikon-wahana-pesawat-1.png"/>
            <TextBlock x:Name="judul_flight" Text="Flight View" VerticalAlignment="Center"
                       FontSize="36" FontFamily="Century Gothic" FontWeight="Bold" Foreground="{ThemeResource AccentForegroundBrush}"
                       Height="54"/>
        </StackPanel>

        <!-- Connection Bar with Signal Strength and Flight Time -->
        <Border VerticalAlignment="Center" Background="{ThemeResource CardBrush}" Padding="0"
                CornerRadius="4" Grid.ColumnSpan="4" Margin="402,0,0,0" HorizontalAlignment="Left" Width="1100" Height="36">
            <StackPanel Orientation="Horizontal" Margin="8,0,8,0" VerticalAlignment="Center" Height="34">
                <TextBlock Text="Connection :" HorizontalAlignment="Left" Margin="0" VerticalAlignment="Center" Padding="0"
                           FontSize="14" FontWeight="Bold" Width="85"/>
                <ComboBox x:Name="cb_ports" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Center"
                          Width="80" SelectedIndex="0" FontSize="12"/>
                <ComboBox x:Name="tb_bauds" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Center"
                          Width="90" SelectedIndex="0" FontSize="12">
                    <ComboBoxItem Content="BAUDRATE"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="19200"/>
                    <ComboBoxItem Content="57600"/>
                    <ComboBoxItem Content="115200"/>
                    <ComboBoxItem Content="128000"/>
                </ComboBox>
                <TextBlock Text="IP :" FontWeight="Bold" Background="{ThemeResource SecondaryBrush}" Margin="8,0,0,0"
                           Padding="5,0" VerticalAlignment="Center" FontSize="12"/>
                <TextBox x:Name="serverIP" Height="22" Margin="2,0,0,0" VerticalAlignment="Center"
                         Width="100" Text="192.168.1.1" FontSize="12"/>
                <TextBlock Text="Port :" FontWeight="Bold" Background="{ThemeResource SecondaryBrush}" Margin="5,0,0,0"
                           Padding="5,0" VerticalAlignment="Center" FontSize="12"/>
                <TextBox x:Name="udpPort" Height="22" Margin="2,0,0,0" VerticalAlignment="Center"
                         Width="50" Text="14550" FontSize="12"/>
                <Button x:Name="btn_conn" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Margin="0,0,0,0" Padding="0"
                        HorizontalContentAlignment="Left" Width="140" Height="26">
                    <StackPanel Orientation="Horizontal">
                        <Image x:Name="img_conn" Margin="5,0" HorizontalAlignment="Left" Width="20"
                               Source="ms-appx:///Assets/icons/icons8-disconnected-80.png"/>
                        <TextBlock x:Name="ind_conn_status" Text="Disconnected" Padding="0" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14" Width="110"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- MAP AREA with GPS Info Overlay -->
        <Grid x:Name="pnl_gps_info" Grid.Row="1" Grid.RowSpan="2" Margin="0,0,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <!-- Map Control -->
            <map:SkiaMapControl x:Name="mapControl" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.ColumnSpan="2"/>
            
            <!-- ARM/DISARM Button -->
            <StackPanel Margin="8,10,0,0" Background="Transparent" Height="30" VerticalAlignment="Top" Width="60" HorizontalAlignment="Left" Orientation="Horizontal">
                <Button x:Name="btn_arm_disarm" Content="ARM"
                        Width="60" Height="30" FontSize="14" FontWeight="Bold" Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="15"/>
            </StackPanel>
            
            <!-- HDOP Display -->
            <Grid Margin="2.5,0,2.5,2.5" Background="{ThemeResource CardBrush}" Height="25" VerticalAlignment="Top" Width="100" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="HDOP" VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Consolas" FontSize="16" FontWeight="Bold"/>
                <TextBox x:Name="tb_hdop" Grid.Column="1" Text="N/A" VerticalContentAlignment="Center" Margin="0,0,5,0" FontSize="20" FontWeight="Bold" 
                         FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
            </Grid>
            
            <!-- SATS Display -->
            <Grid Margin="2.5,0,0,2.5" Grid.Column="1" Background="{ThemeResource CardBrush}" VerticalAlignment="Top" Height="25" Width="100" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="SATS" FontFamily="Consolas" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontWeight="Bold"/>
                <TextBox x:Name="tb_sats" Grid.Column="1" Text="N/A" VerticalContentAlignment="Center" Margin="0,0,5,0" FontSize="20" FontWeight="Bold" 
                         FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
            </Grid>
            
            <!-- LAT Display -->
            <Grid Margin="2.5,0,2.5,2.5" Background="{ThemeResource CardBrush}" Height="30" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="LAT" VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Consolas" FontSize="16"/>
                <TextBox x:Name="tb_lat" Grid.Column="1" Text="N/A" VerticalContentAlignment="Center" Margin="0,0,5,0" FontSize="24" FontWeight="Bold" 
                         FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
            </Grid>
            
            <!-- LON Display -->
            <Grid Margin="2.5,0,0,2.5" Grid.Column="1" Background="{ThemeResource CardBrush}" VerticalAlignment="Bottom" Height="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="LON" FontFamily="Consolas" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16"/>
                <TextBox x:Name="tb_longt" Grid.Column="1" Text="N/A" VerticalContentAlignment="Center" Margin="0,0,5,0" FontSize="24" FontWeight="Bold" 
                         FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
            </Grid>
            
            <!-- Map Controls Overlay -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10" Grid.ColumnSpan="2">
                <ToggleButton x:Name="btn_follow_wahana" Content="📍 Follow" Width="100" Height="30" Click="ToggleFollowWahana_Click"/>
                <ComboBox x:Name="cb_flight_map_type" Width="150" Margin="5,0,0,0" SelectedIndex="1" SelectionChanged="FlightMapType_SelectionChanged">
                    <ComboBoxItem Content="OpenStreetMap"/>
                    <ComboBoxItem Content="Google Satellite"/>
                    <ComboBoxItem Content="Google Hybrid"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Telemetry & Instruments - EXACT MATCH TO AVALONIA -->
        <ScrollViewer x:Name="pnl_telemetry" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Margin="2,0,2,3" VerticalScrollBarVisibility="Hidden">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Telemetry Data Grid -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Flight Mode -->
                    <TextBlock x:Name="lbl_fmode" Grid.Row="0" Background="{ThemeResource SecondaryBrush}" Text="FLIGHT MODE" Padding="0,5" Margin="0" FontSize="30" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" TextAlignment="Center" VerticalAlignment="Center"/>
                    
                    <!-- HEADING -->
                    <Grid Grid.Row="1" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <TextBlock Text="HEADING" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontFamily="Consolas" HorizontalAlignment="Left"/>
                        <TextBox x:Name="tb_yaw" Text="N/A" VerticalContentAlignment="Center" Margin="0,2,10,2" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                    
                    <!-- PITCH -->
                    <Grid Grid.Row="2" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <TextBlock Text="PITCH" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontFamily="Consolas" HorizontalAlignment="Left"/>
                        <TextBox x:Name="tb_pitch" Text="N/A" VerticalContentAlignment="Center" Margin="0,2,10,2" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                    
                    <!-- ROLL -->
                    <Grid Grid.Row="3" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <TextBlock Text="ROLL" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontFamily="Consolas" HorizontalAlignment="Left"/>
                        <TextBox x:Name="tb_roll" Text="N/A" VerticalContentAlignment="Center" Margin="0,2,10,2" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                    
                    <!-- SPEED -->
                    <Grid Grid.Row="4" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <StackPanel VerticalAlignment="Center" Margin="10,0,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="SPEED" FontSize="16" FontFamily="Consolas"/>
                            <TextBlock Text="(GPS / IMU)" FontSize="11" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBox x:Name="tb_airspeed" Text="N/A" VerticalContentAlignment="Center" Margin="0,5,10,5" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                    
                    <!-- ALTITUDE -->
                    <Grid Grid.Row="5" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <StackPanel VerticalAlignment="Center" Margin="10,0,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="ALTITUDE" FontSize="16" FontFamily="Consolas"/>
                            <TextBlock Text="(GPS / ALTM)" FontSize="11" FontFamily="Consolas"/>
                        </StackPanel>
                        <TextBox x:Name="tb_alti" Text="N/A" VerticalContentAlignment="Center" Margin="0,5,10,5" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                    
                    <!-- BAROMETERS -->
                    <Grid Grid.Row="6" Background="{ThemeResource CardBrush}" Margin="0,5,0,0">
                        <TextBlock Text="BAROMETERS" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" FontFamily="Consolas" HorizontalAlignment="Left"/>
                        <TextBox x:Name="tb_baro" Text="N/A" VerticalContentAlignment="Center" Margin="0,5,10,5" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Background="{x:Null}" BorderBrush="{x:Null}" IsReadOnly="True" TextAlignment="Right"/>
                    </Grid>
                </Grid>

                <!-- Avionics Instruments -->
                <Grid Grid.Row="1" Background="{ThemeResource CardBrush}" VerticalAlignment="Bottom" Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <controls:AttitudeIndicator x:Name="ind_attitude" Grid.Row="0" Margin="5" Height="250" Width="254" HorizontalAlignment="Center"/>
                    
                    <Grid x:Name="avInst" Grid.Row="1" Margin="5">
                        <controls:HeadingIndicator x:Name="ind_heading" Width="105" Height="105" Margin="0" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
                        <StackPanel Margin="10,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <TextBlock Text="Thr" FontWeight="Bold" Margin="0,4,0,2" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="pb_rc_throttle" Width="25" Height="70" Minimum="0" Maximum="100">
                                <ProgressBar.RenderTransform>
                                    <RotateTransform Angle="-90" CenterX="12.5" CenterY="35"/>
                                </ProgressBar.RenderTransform>
                            </ProgressBar>
                        </StackPanel>
                        <controls:AirspeedIndicator x:Name="ind_airspeed_indicator" Width="105" Height="105" Margin="0" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Stream Panel -->
        <Grid x:Name="stream_panel" Grid.Row="1" Grid.Column="2" Margin="2,0,3,2" Background="{ThemeResource CardBrush}" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,2">
                <ComboBox x:Name="out_stream" Margin="0,0,5,0" Width="280" FontSize="14">
                    <ComboBoxItem Content="Loiter"/>
                    <ComboBoxItem Content="Land"/>
                    <ComboBoxItem Content="Take Off"/>
                    <ComboBoxItem Content="Start Mission"/>
                    <ComboBoxItem Content="Get Param"/>
                    <ComboBoxItem Content="Stabilize"/>
                </ComboBox>
                <Button x:Name="btn_send_command" Margin="-1,0,0,0" Width="30" Click="OnSendCommand">
                    <!-- Icon placeholder -->
                    <Image Margin="0,1,0,0"/>
                </Button>
                <Button x:Name="stream_panel_read_btn" Content="READ" HorizontalAlignment="Right" Padding="10,0" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Margin="5,0,0,0" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
            <TextBox Text="" x:Name="in_stream" Grid.Row="1" Margin="5" FontSize="14" IsReadOnly="True" TextWrapping="Wrap"/>
        </Grid>

        <!-- Camera Panel -->
        <Grid x:Name="pnl_camera" Grid.Column="2" Margin="2,3,3,3" Grid.Row="2" Background="{ThemeResource CardBrush}" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4*"/>
            </Grid.RowDefinitions>

            <!-- Camera display + placeholder -->
            <Border Margin="2" BorderBrush="Transparent" BorderThickness="1" Grid.Row="0">
                <Border.Background>
                    <ImageBrush ImageSource="ms-appx:///Assets/logo/dirgantara.png" Stretch="Uniform"/>
                </Border.Background>
                <Image x:Name="liveCam" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Buttons: Ambil Gambar, Ambil Vidio, YOLO, vegetation, export, expand -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0">
                <Button x:Name="btn_take_picture" Content="Ambil Gambar" FontSize="14" BorderBrush="Transparent"
                        Margin="0,0,5,0" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Padding="3,2" Height="22" Width="103"/>
                <Button x:Name="btn_record" Content="Ambil Vidio" FontSize="14" BorderBrush="Transparent"
                        Margin="5,0,5,0" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Padding="3,2" Height="22" Width="103"/>
                <Button x:Name="btn_yolo" Content="YOLO" FontSize="12" BorderBrush="Transparent"
                        Margin="5,0,0,0" Background="#FFFFB347" Padding="8,2" Height="22"
                        ToolTipService.ToolTip="YOLOv8n Object Detection"/>
                <Button x:Name="btn_vegetation" Content="🌾" FontSize="14" BorderBrush="Transparent"
                        Margin="5,0,0,0" Background="#FF90EE90" Padding="8,2" Height="22" Width="40"
                        ToolTipService.ToolTip="Vegetation Stress Detection"/>
                <Button x:Name="btn_export_veg" Content="📥" FontSize="14" BorderBrush="Transparent"
                        Margin="2,0,0,0" Background="{ThemeResource InfoBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Padding="4,2" Height="22" Width="30"
                        ToolTipService.ToolTip="Export GPS Waypoints" Visibility="Collapsed"/>
                <Button x:Name="btn_expand_view" Content="⛶" FontSize="14" BorderBrush="Transparent"
                        Margin="10,0,0,0" Background="{ThemeResource WarningBrush}" Foreground="{ThemeResource ForegroundBrush}" Padding="6,2" Height="22" Width="32"
                        ToolTipService.ToolTip="Expand/Collapse View (F11)"/>
            </StackPanel>

            <!-- YOLO/Vegetation stats (WPF: tb_green_percentage, tb_object_count, tb_yolo_stats, pnl_vegetation_stats) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,2,0,0">
                <TextBlock x:Name="tb_green_percentage" Foreground="Yellow" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="tb_object_count" Foreground="Yellow" FontSize="18" FontWeight="Bold" Margin="5,0,0,0"/>
            </StackPanel>
            <TextBlock x:Name="tb_yolo_stats" Foreground="Cyan" FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,35,10,0" Padding="5,2"/>

            <!-- Vegetation Analysis Panel (WPF: pnl_vegetation_stats) -->
            <Border x:Name="pnl_vegetation_stats" Grid.Row="2" Visibility="Collapsed" Background="{ThemeResource BackgroundBrush80}"
                    CornerRadius="5" Padding="8" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,5,0,0">
                <StackPanel>
                    <TextBlock Text="🌾 VEGETATION ANALYSIS" Foreground="{ThemeResource ForegroundBrush}" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅ Sehat: " Foreground="LightGreen" FontSize="11"/>
                        <TextBlock x:Name="tb_veg_healthy" Text="0%" Foreground="LightGreen" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠️ Stress: " Foreground="Orange" FontSize="11"/>
                        <TextBlock x:Name="tb_veg_stressed" Text="0%" Foreground="Orange" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🟤 Tanah: " Foreground="#FFCD853F" FontSize="11"/>
                        <TextBlock x:Name="tb_veg_soil" Text="0%" Foreground="#FFCD853F" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                         <TextBlock Text="📍 GPS Tags: " Foreground="{ThemeResource InfoBrush}" FontSize="11"/>
                         <TextBlock x:Name="tb_veg_waypoints" Text="0" Foreground="{ThemeResource InfoBrush}" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Camera controls (WPF: Kamera :, cb_cam_source, cb_cams, tb_network_cam_url, Refresh, Start Stream, zoom) -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,2,0,0" VerticalAlignment="Top" Height="30">
                <TextBlock Text="Kamera :" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" FontFamily="Consolas" Padding="5,0"/>
                <ComboBox x:Name="cb_cam_source" Margin="0,0,5,0" VerticalAlignment="Center" Width="80" FontSize="12" SelectedIndex="0" SelectionChanged="CamSourceSelection_Changed">
                    <ComboBoxItem Content="Local"/>
                    <ComboBoxItem Content="Network"/>
                </ComboBox>
                <ComboBox x:Name="cb_cams" Margin="0,0,5,0" VerticalAlignment="Center" Width="220" FontSize="14">
                    <ComboBoxItem Content="(Refresh untuk daftar kamera)"/>
                </ComboBox>
                <TextBox x:Name="tb_network_cam_url" Visibility="Collapsed" VerticalAlignment="Center" Width="220"
                         FontSize="12" Text="rtsp://192.168.144.25:8554/main.264" Margin="0"/>
                 <Button x:Name="btn_refreshcam" Content="Refresh" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderBrush="{x:Null}"
                         VerticalAlignment="Center" Padding="5" Margin="5,0"/>
                 <Button x:Name="btn_livestream" Content="Start Stream" FontSize="14" BorderBrush="{x:Null}"
                         Margin="0,0,0,0" Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" Padding="10,5" Width="100"/>
                <Button x:Name="btn_zoom_in" Content="＋" Width="28" Height="28" FontSize="16" Margin="4,0,0,0"
                        Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderBrush="Transparent" Click="BtnZoomIn_Click"/>
                <Button x:Name="btn_zoom_out" Content="－" Width="28" Height="28" FontSize="16" Margin="2,0,0,0"
                        Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderBrush="Transparent" Click="BtnZoomOut_Click"/>
                <Button x:Name="btn_reset_zoom" Content="Reset" Width="42" Height="28" FontSize="14" Margin="2,0,0,0"
                        Background="{ThemeResource PrimaryBrush}" Foreground="{ThemeResource PrimaryForegroundBrush}" BorderBrush="Transparent" Click="ResetZoom_Click"/>
            </StackPanel>

            <!-- Screenshot list (WPF: WrapPanel screenshot_List) -->
            <ScrollViewer Grid.Row="3" Margin="5,36,5,5" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Background="{ThemeResource CardBrush}">
                <ItemsControl x:Name="screenshot_List">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Margin="10,10,10,10"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
