<Page x:Class="Pigeon_Uno.Views.ReportsHarvestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Riwayat Misi" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <TextBox x:Name="SearchBox" PlaceholderText="Cari misi…" Margin="0,0,0,8" TextChanged="SearchBox_TextChanged"/>

                        <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MissionItemsPanel" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border x:Name="DetailCard" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <Grid>
                        <StackPanel x:Name="DetailContentPanel">
                            <TextBlock x:Name="DetailTitleText" Text="Detail" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Margin="0,0,4,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Tanggal" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="DetailDateText" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Margin="4,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Durasi" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="DetailDurationText" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Margin="4,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Deteksi" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="DetailDetectionText" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Margin="4,0,0,0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Prioritas" Style="{StaticResource LabelStyle}"/>
                                        <Border x:Name="DetailPriorityBadge" Background="#332E7D32" BorderBrush="#664CAF50" BorderThickness="1" CornerRadius="5" Padding="8,2" HorizontalAlignment="Left">
                                            <TextBlock x:Name="DetailPriorityText" Text="-" FontSize="13" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="DetailLocationText" Text="Lokasi: -" FontSize="13" Foreground="{ThemeResource ForegroundBrush}" Margin="0,0,0,8"/>

                            <Border Height="220" CornerRadius="10" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Background="#EEF7EF">
                                <Grid>
                                    <Rectangle Opacity="0.26">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Offset="0" Color="#00000000"/>
                                                <GradientStop Offset="0.5" Color="#332E7D32"/>
                                                <GradientStop Offset="1" Color="#00000000"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle Opacity="0.22">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#00000000"/>
                                                <GradientStop Offset="0.5" Color="#334CAF50"/>
                                                <GradientStop Offset="1" Color="#00000000"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="8,2" CornerRadius="999" Background="#334CAF50" BorderBrush="#664CAF50" BorderThickness="1">
                                        <TextBlock Text="Map snapshot" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                    </Border>

                                    <TextBlock x:Name="MapPreviewText" Text="Map preview" FontSize="12" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="EmptyDetailPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="Detail" Style="{StaticResource TitleStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pilih misi untuk melihat detail." Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Catatan Operator" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <TextBox x:Name="OperatorNoteTextBox" AcceptsReturn="True" TextWrapping="Wrap" Height="90" TextChanged="OperatorNoteTextBox_TextChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Export Report" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="PDF" Padding="14,8" Background="{ThemeResource SecondaryBrush}" Click="ExportAction_Click"/>
                            <Button Content="CSV" Padding="14,8" Background="{ThemeResource SecondaryBrush}" Click="ExportAction_Click"/>
                            <Button Content="JSON" Padding="14,8" Background="{ThemeResource SecondaryBrush}" Click="ExportAction_Click"/>
                            <Button Content="Bagikan" Padding="14,8" Click="ExportAction_Click"/>
                            <Button Content="Kirim ke Koperasi" Padding="14,8" Background="{ThemeResource PrimaryBrush}" Foreground="White" Click="ExportAction_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="ActionFeedbackBorder" Margin="0,10,0,0" Padding="10" CornerRadius="8" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Background="#151A2530" Visibility="Collapsed">
                    <TextBlock x:Name="ActionFeedbackText" Foreground="{ThemeResource ForegroundBrush}" FontSize="12"/>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
