<UserControl x:Class="Pigeon_Uno.Views.Controls.PIAPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:Pigeon_Uno.Core.Models.AI"
             xmlns:converters="using:Pigeon_Uno.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="400"
             x:Name="rootPanel">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="FontIcon">
            <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}"/>
        </Style>
        <!-- Urgency-based message styles -->
        <Style x:Key="NormalMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush80}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="WarningMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource WarningBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource WarningBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CriticalMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource ErrorBrush20}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SuccessMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SuccessBrush20}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource SuccessBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="UserMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12,12,4,12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Quick command button style -->
        <Style x:Key="QuickCommandStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBrush80}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- Header action button style -->
        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="PanelRoot" Width="400" HorizontalAlignment="Right" Background="{ThemeResource BackgroundBrush}">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="400"/>
        </Grid.RenderTransform>

        <!-- Left border accent -->
        <Border BorderBrush="{ThemeResource PrimaryBrush20}" BorderThickness="1,0,0,0" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: HEADER -->
                <Border Grid.Row="0" Padding="16,14" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1" Background="{ThemeResource CardBrush95}">
                    <Grid>
                        <!-- Top gradient line -->
                        <Border Height="1" VerticalAlignment="Top" Margin="-16,-14,-16,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="{ThemeResource PrimaryColor}" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- PIA Orb -->
                            <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,12,0">
                                <Ellipse x:Name="OuterRing" Width="48" Height="48" Stroke="#4D3B82F6" StrokeThickness="2">
                                </Ellipse>
                                <Ellipse x:Name="InnerRing" Width="36" Height="36" Stroke="#803B82F6" StrokeThickness="1">
                                </Ellipse>
                                <!-- Main orb -->
                                <Ellipse x:Name="MainOrb" Width="32" Height="32">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop x:Name="OrbColorStart" Color="#2563EB"/>
                                            <GradientStop x:Name="OrbColorMid" Color="#06B6D4"/>
                                            <GradientStop x:Name="OrbColorEnd" Color="#1D4ED8"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Highlight -->
                                <Ellipse Width="8" Height="4" Fill="#4DFFFFFF" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,6,0,0"/>
                                <!-- Icon -->
                                <FontIcon x:Name="OrbIcon" Glyph="&#xE7C1;" FontSize="14" Foreground="{ThemeResource PrimaryForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Title and status -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="PIA" FontWeight="Bold" FontSize="14" Foreground="{ThemeResource ForegroundBrush}" CharacterSpacing="150"/>
                                    <TextBlock x:Name="SpeakingIndicator" Text="speaking" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource SuccessBrush}" Visibility="Collapsed"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <Ellipse x:Name="ConnectionDot" Width="6" Height="6">
                                        <Ellipse.Fill>
                                            <SolidColorBrush x:Name="ConnectionDotColor" Color="{ThemeResource SuccessColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock x:Name="ConnectionStatus" Text="MAVLink Connected" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource SuccessBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                <Button x:Name="btnSettings" Style="{StaticResource HeaderActionButtonStyle}" ToolTipService.ToolTip="Settings" Click="Settings_Click">
                                    <FontIcon Glyph="&#xE713;" FontSize="13" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </Button>
                                <Button x:Name="btnMute" Style="{StaticResource HeaderActionButtonStyle}" ToolTipService.ToolTip="Toggle Sound" Click="Mute_Click">
                                    <FontIcon x:Name="MuteIcon" Glyph="&#xE767;" FontSize="13" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </Button>
                                <Button x:Name="btnVoice" Style="{StaticResource HeaderActionButtonStyle}" ToolTipService.ToolTip="Toggle Voice Command" Click="Voice_Click">
                                    <FontIcon x:Name="VoiceIcon" Glyph="&#xE720;" FontSize="13" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </Button>
                                <Button x:Name="btnClear" Style="{StaticResource HeaderActionButtonStyle}" ToolTipService.ToolTip="Clear History" Click="Clear_Click">
                                    <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </Button>
                                <Button x:Name="btnClose" Style="{StaticResource HeaderActionButtonStyle}" ToolTipService.ToolTip="Close" Click="Close_Click">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Row 1: HEALTH STATUS BAR -->
                <Border Grid.Row="1" Padding="12,8" Background="{ThemeResource MutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Health bar -->
                        <Border Grid.Column="0" CornerRadius="4" Height="6" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="HealthBarColor" Color="#10B981"/>
                            </Border.Background>
                        </Border>

                        <!-- Health badge -->
                        <Border Grid.Column="1" CornerRadius="4" Padding="8,4">
                            <Border.Background>
                                <SolidColorBrush x:Name="HealthBadgeColor" Color="#10B981"/>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="HealthIcon" Glyph="&#xE7BA;" FontSize="12" Foreground="White"/>
                                <TextBlock x:Name="HealthLabel" Text="ALL SYSTEMS NOMINAL" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="White" CharacterSpacing="50"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Row 2: MESSAGE LIST -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12,12">
                    <StackPanel>
                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Voice Command" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                                <TextBlock x:Name="VoiceStatusText" Text="voice idle" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" Margin="0,2,0,0"/>
                                <TextBlock x:Name="VoiceCommandText" Text="-" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,2,0,0"/>
                                <TextBlock x:Name="VoiceAvailabilityText" Text="voice diagnostic" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock x:Name="VoiceConfidenceText" Grid.Column="1" Text="0%" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="System Readiness" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="SystemReadinessText" Text="AI:unknown | Voice:unknown | Telemetry:unknown | MAVLink:unknown | Fallback:unknown" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock x:Name="ProviderDiagnosticText" Text="provider diagnostic belum tersedia." FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="AI Insight" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="InsightStatusText" Text="UNKNOWN" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="InsightSummaryText" Text="Belum ada analisis." FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Battery Forecast" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="BatteryForecastText" Text="Belum ada prediksi baterai." FontSize="10" Foreground="{ThemeResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Research Validation" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="ValidationSummaryText" Text="Belum ada metrik validasi." FontSize="10" Foreground="{ThemeResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Button x:Name="ExportResearchJsonButton" Content="Export JSON" Click="ExportResearchJson_Click"/>
                                <Button x:Name="ExportResearchCsvButton" Content="Export CSV" Click="ExportResearchCsv_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="ResearchExportStatusText" Text="Belum ada export report." FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Session Summary" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="SessionSummaryText" Text="Belum ada ringkasan sesi." FontSize="10" Foreground="{ThemeResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Performance" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="PerformanceScoreText" Text="0.0 (Grade -)" FontSize="11" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="PerformanceFeedbackText" Text="Belum ada skor performa." FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            <TextBlock Text="Trend (Last 12)" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,8,0,4"/>
                            <Border Height="80" Background="{ThemeResource MutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6">
                                <ItemsControl x:Name="PerformanceTrendChart">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="22" Margin="1,0,1,0" VerticalAlignment="Bottom">
                                                <Border Height="{Binding BarHeight}" Width="10" CornerRadius="3,3,0,0"
                                                        Background="{ThemeResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Grade}" FontSize="8" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <TextBlock x:Name="PerformanceTrendEmptyText" Text="Trend belum tersedia." FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Maintenance" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <TextBlock x:Name="MaintenanceStatusText" Text="Belum ada jadwal maintenance." FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,2,0,6"/>
                            <ItemsControl x:Name="MaintenanceList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource MutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Component}" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource ForegroundBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Summary}" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding DueText}" FontSize="9" Foreground="{ThemeResource ForegroundBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button x:Name="ViewMaintenanceScheduleButton"
                                    Content="Lihat Jadwal Lengkap"
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Left"
                                    Click="ViewMaintenanceSchedule_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBrush95}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Recent Anomalies" FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" CharacterSpacing="80"/>
                            <ItemsControl x:Name="AnomaliesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="{ThemeResource ForegroundBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <ItemsControl x:Name="MessagesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- User message (right-aligned) -->
                                    <Border x:Name="UserMessageBorder" Style="{StaticResource UserMessageStyle}" 
                                            HorizontalAlignment="Right" MaxWidth="352"
                                            Visibility="{Binding IsUserMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Content}" FontSize="12" Foreground="White" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding TimestampText}" FontSize="9" FontFamily="Consolas" Foreground="#99FFFFFF" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Assistant message (left-aligned) with urgency styling -->
                                    <Border x:Name="AssistantMessageBorder" HorizontalAlignment="Left" MaxWidth="352"
                                            Visibility="{Binding IsAssistantMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="12"/>
                                                <Setter Property="Padding" Value="12,10"/>
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                                <Setter Property="BorderThickness" Value="4,0,0,0"/>
                                            </Style>
                                        </Border.Style>
                                        <Border.Background>
                                            <SolidColorBrush x:Name="MsgBg" Color="{Binding BackgroundColor}"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush x:Name="MsgBorder" Color="{Binding BorderColor}"/>
                                        </Border.BorderBrush>
                                        <StackPanel>
                                            <TextBlock x:Name="MsgContent" Text="{Binding Content}" FontSize="12" Foreground="{Binding TextColor}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding TimestampText}" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Thinking indicator -->
                    <Border x:Name="ThinkingBubble" HorizontalAlignment="Left" Visibility="Collapsed" Margin="0,0,0,8">
                        <Border.Background>
                            <SolidColorBrush Color="{ThemeResource CardColor80}"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{ThemeResource PrimaryColor}"/>
                        </Border.BorderBrush>
                        <Border CornerRadius="12" Padding="16,12" BorderThickness="4,0,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="Dot1Transform" Y="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="Dot2Transform" Y="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource PrimaryBrush}">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="Dot3Transform" Y="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <TextBlock Text="menganalisa..." FontSize="10" FontFamily="Consolas" Foreground="{ThemeResource PrimaryBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- Scroll anchor -->
                    <Border x:Name="ScrollAnchor" Height="0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Row 3: QUICK COMMANDS -->
                <Border Grid.Row="3" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Toggle button -->
                        <Button x:Name="btnToggleQuick" Grid.Row="0" Background="Transparent" BorderThickness="0" Padding="16,8" Click="ToggleQuickCommands_Click">
                            <Grid>
                                <TextBlock Text="Perintah Cepat" FontSize="10" Foreground="{ThemeResource MutedForegroundBrush}" FontWeight="Bold" CharacterSpacing="100"/>
                                <FontIcon x:Name="QuickToggleIcon" Glyph="&#xE70D;" FontSize="12" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>

                        <!-- Quick commands grid -->
                        <Grid x:Name="QuickCommandsPanel" Grid.Row="1" Padding="12,0,12,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource QuickCommandStyle}" Margin="0,0,3,3" Click="QuickCommand_Click" Tag="status lengkap drone">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE7C1;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Status" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource QuickCommandStyle}" Margin="3,0,3,3" Click="QuickCommand_Click" Tag="cek baterai">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Battery" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource QuickCommandStyle}" Margin="3,0,3,3" Click="QuickCommand_Click" Tag="status GPS">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE701;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="GPS" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource QuickCommandStyle}" Margin="3,0,0,3" Click="QuickCommand_Click" Tag="analisis keamanan misi">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Analysis" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource QuickCommandStyle}" Margin="0,3,3,0" Click="QuickCommand_Click" Tag="takeoff">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE724;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Takeoff" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource QuickCommandStyle}" Margin="3,3,3,0" Click="QuickCommand_Click" Tag="landing sekarang">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Land" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource QuickCommandStyle}" Margin="3,3,3,0" Click="QuickCommand_Click" Tag="return to launch">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="RTL" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource QuickCommandStyle}" Margin="3,3,0,0" Click="QuickCommand_Click" Tag="arm drone">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="ARM" FontSize="9" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Row 4: INPUT AREA -->
                <Border Grid.Row="4" Padding="12,8,12,16" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0" Background="{ThemeResource CardBrush95}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Input box with send button -->
                        <Grid Grid.Row="0" CornerRadius="12" Padding="12,8" BorderThickness="1" Background="{ThemeResource InputBrush}">
                            <Grid BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="InputBox" Grid.Column="0" 
                                         PlaceholderText="Tanya PIA..."
                                         FontSize="12" FontFamily="Consolas"
                                         Foreground="{ThemeResource ForegroundBrush}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,2"
                                         TextChanged="InputBox_TextChanged"
                                         KeyDown="InputBox_KeyDown"/>

                                <Button x:Name="btnSend" Grid.Column="1" Width="28" Height="28" CornerRadius="6" 
                                        Padding="0" Background="{ThemeResource PrimaryBrush}" BorderThickness="0"
                                        IsEnabled="False" Click="Send_Click">
                                    <FontIcon Glyph="&#xE724;" FontSize="12" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Grid>

                        <!-- Status bar -->
                        <Grid Grid.Row="1" Margin="4,6,4,0">
                            <TextBlock Text="Enter kirim · Esc batal" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}"/>
                            <TextBlock x:Name="StatusText" Text="ready" FontSize="9" FontFamily="Consolas" Foreground="{ThemeResource MutedForegroundBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
