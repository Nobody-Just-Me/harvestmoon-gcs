<Page
    x:Class="Pigeon_Uno.Views.ParameterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Pigeon_Uno.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Page.Resources>
        <converters:ModifiedBackgroundConverter x:Key="ModifiedBackgroundConverter"/>
        <converters:ModifiedForegroundConverter x:Key="ModifiedForegroundConverter"/>
    </Page.Resources>

    <Grid x:Name="ParameterRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border x:Name="ParameterHeaderBorder" Grid.Row="0" Background="{ThemeResource CardBrush}" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Parameter Editor" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="{ThemeResource ForegroundBrush}"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Not connected" 
                               FontSize="12" 
                               Foreground="{ThemeResource MutedForegroundBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel x:Name="ParameterActionPanel" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button x:Name="RefreshButton"
                            Content="Refresh All"
                            Click="RefreshButton_Click"
                            Background="{ThemeResource SuccessBrush}"
                            Foreground="{ThemeResource PrimaryForegroundBrush}"
                            Padding="12,6"
                            CornerRadius="4"/>
                    <Button x:Name="ImportButton"
                            Content="Import"
                            Click="ImportButton_Click"
                            Background="{ThemeResource PrimaryBrush}"
                            Foreground="{ThemeResource PrimaryForegroundBrush}"
                            Padding="12,6"
                            CornerRadius="4"/>
                    <Button x:Name="ExportButton"
                            Content="Export"
                            Click="ExportButton_Click"
                            Background="{ThemeResource AccentBrush}"
                            Foreground="{ThemeResource PrimaryForegroundBrush}"
                            Padding="12,6"
                            CornerRadius="4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search and Filter Bar -->
        <Border x:Name="ParameterFilterBorder" Grid.Row="1" Background="{ThemeResource MutedBrush}" Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         PlaceholderText="Search parameters..."
                         TextChanged="SearchTextBox_TextChanged"
                         Padding="8"
                         CornerRadius="4"
                         Background="{ThemeResource CardBrush}"/>
                
                <CheckBox x:Name="ShowModifiedCheckBox"
                          Grid.Column="1"
                          Content="Modified"
                          Checked="ShowModifiedCheckBox_Changed"
                          Unchecked="ShowModifiedCheckBox_Changed"
                          Foreground="{ThemeResource ForegroundBrush}"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"/>
                
                <TextBlock x:Name="CountTextBlock"
                           Grid.Column="2"
                           Text="0 / 0 parameters"
                           Foreground="{ThemeResource ForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="14"/>
            </Grid>
        </Border>

        <!-- Parameter List -->
        <Border Grid.Row="2" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Margin="6">
            <Grid>
                <ListView x:Name="ParameterListView"
                          SelectionMode="Single"
                          SelectionChanged="ParameterListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="6" Background="{Binding IsModified, Converter={StaticResource ModifiedBackgroundConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource ForegroundBrush}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding Group}" 
                                               FontSize="11"
                                               Foreground="{ThemeResource MutedForegroundBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding IsModified, Converter={StaticResource ModifiedForegroundConverter}}"/>
                                
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Description}"
                                           FontSize="11"
                                           Foreground="{ThemeResource MutedForegroundBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="8,0"/>
                                
                                <Button Grid.Column="3"
                                        Content="Edit"
                                        Click="EditParameter_Click"
                                        Tag="{Binding}"
                                        Background="{ThemeResource PrimaryBrush}"
                                        Foreground="{ThemeResource PrimaryForegroundBrush}"
                                        Padding="8,4"
                                        CornerRadius="4"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <!-- Loading Indicator -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <ProgressRing IsActive="True" 
                                  Width="40" 
                                  Height="40"
                                  Foreground="{ThemeResource PrimaryBrush}"/>
                    <TextBlock x:Name="LoadingTextBlock"
                               Text="Loading parameters..."
                               FontSize="14"
                               Foreground="{ThemeResource MutedForegroundBrush}"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                
                <!-- Empty State -->
                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No parameters loaded"
                               FontSize="18"
                               Foreground="{ThemeResource MutedForegroundBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Connect to drone and click Refresh All"
                               FontSize="14"
                               Foreground="{ThemeResource MutedForegroundBrush}"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{ThemeResource MutedBrush}" Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="MessageTextBlock"
                           Grid.Column="0"
                           Text=""
                           FontSize="14"
                           Foreground="{ThemeResource MutedForegroundBrush}"
                           VerticalAlignment="Center"/>
                
                <ProgressBar x:Name="LoadingProgressBar"
                             Grid.Column="1"
                             Width="150"
                             Height="20"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Page>
