<ContentDialog
    x:Class="Pigeon_Uno.Views.AlertSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Alert Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="600">
        <StackPanel Spacing="20" Padding="20">
            
            <!-- Battery Warning Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Battery Warning" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="BatteryAlertEnabledCheck"
                              Content="Enable battery warning alerts"
                              IsChecked="True"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Warning Threshold:" 
                                   VerticalAlignment="Center"
                                   Width="150"/>
                        <Slider x:Name="BatteryThresholdSlider"
                                Minimum="10"
                                Maximum="50"
                                Value="20"
                                Width="200"
                                StepFrequency="5"/>
                        <TextBlock Text="{Binding Value, ElementName=BatteryThresholdSlider}"
                                   VerticalAlignment="Center"
                                   Width="40"/>
                        <TextBlock Text="%"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <CheckBox x:Name="BatteryVoiceCheck"
                              Content="Use voice alert"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- GPS Lost Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="GPS Lost Alert" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="GpsAlertEnabledCheck"
                              Content="Enable GPS lost alerts"
                              IsChecked="True"/>
                    
                    <CheckBox x:Name="GpsVoiceCheck"
                              Content="Use voice alert"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- Connection Lost Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Connection Lost Alert" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="ConnectionAlertEnabledCheck"
                              Content="Enable connection lost alerts"
                              IsChecked="True"/>
                    
                    <CheckBox x:Name="ConnectionVoiceCheck"
                              Content="Use voice alert"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- Geofence Violation Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Geofence Violation Alert" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="GeofenceAlertEnabledCheck"
                              Content="Enable geofence violation alerts"
                              IsChecked="True"/>
                    
                    <CheckBox x:Name="GeofenceVoiceCheck"
                              Content="Use voice alert"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- Flight Mode Change Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Flight Mode Change Alert" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="FlightModeAlertEnabledCheck"
                              Content="Enable flight mode change alerts"
                              IsChecked="True"/>
                    
                    <CheckBox x:Name="FlightModeVoiceCheck"
                              Content="Use voice alert"
                              IsChecked="True"/>
                </StackPanel>
            </Border>

            <!-- General Alert Settings -->
            <Border Background="#ECF0F1" Padding="15" CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="General Settings" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <CheckBox x:Name="AlertSoundCheck"
                              Content="Play sound with alerts"
                              IsChecked="True"/>
                    
                    <TextBlock Text="Note: Voice alerts are controlled by individual alert settings above."
                               FontSize="12"
                               Foreground="Gray"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
