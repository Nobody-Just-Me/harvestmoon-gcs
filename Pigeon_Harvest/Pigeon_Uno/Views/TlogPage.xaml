<Page x:Class="Pigeon_Uno.Views.TlogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Pigeon_Uno.Views"
      xmlns:converters="using:Pigeon_Uno.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
    </Page.Resources>

    <Grid Background="WhiteSmoke">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource WindowColor2}">
            <TextBlock Text="TLOG Player" HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Foreground="White" FontSize="24" FontFamily="{StaticResource CommandoFont}"/>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- File Selection -->
            <Border Grid.Row="0" BorderBrush="#FFA8A8A8" BorderThickness="2" Padding="15" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="File TLOG:" Grid.Column="0" VerticalAlignment="Center" 
                                   FontFamily="{StaticResource RalewayFont}" FontWeight="Bold"/>
                        <TextBox Text="{Binding FilePath, Mode=TwoWay}" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" 
                                 IsReadOnly="True" FontFamily="{StaticResource RalewayFont}"/>
                        <Button Content="Buka File" Grid.Column="2" Padding="15,5" 
                                Command="{Binding OpenFileCommand}" FontFamily="{StaticResource RalewayFont}" 
                                FontWeight="Bold" Background="DeepSkyBlue" Foreground="White"/>
                    </Grid>

                    <!-- Log Info -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="30">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Durasi:" FontFamily="{StaticResource RalewayFont}"/>
                            <TextBlock Text="{Binding TotalDuration}" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Waktu Mulai:" FontFamily="{StaticResource RalewayFont}"/>
                            <TextBlock Text="-" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Playback Info Display -->
            <Border Grid.Row="2" BorderBrush="#FFA8A8A8" BorderThickness="2" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Informasi Playback" Grid.Row="0" 
                               HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" 
                               FontFamily="{StaticResource RalewayFont}" Margin="0,10,0,5"/>

                    <TextBlock Grid.Row="1" Margin="20" TextWrapping="Wrap" 
                               VerticalAlignment="Top" FontFamily="{StaticResource RalewayFont}"
                               Text="Silakan buka file TLOG untuk memulai playback.&#x0a;&#x0a;File TLOG dapat diperoleh dari Mission Planner, QGroundControl, atau aplikasi GCS lainnya."/>
                </Grid>
            </Border>
        </Grid>

        <!-- Playback Controls -->
        <Grid Grid.Row="2" Background="#FFE5E5E5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Timeline -->
            <Grid Grid.Row="0" Margin="20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Time Display -->
                <Grid Grid.Row="0" Margin="0,0,0,5">
                    <TextBlock Text="{Binding CurrentTime}" HorizontalAlignment="Left" FontSize="16"/>
                    <TextBlock Text="{Binding TotalDuration, Converter={StaticResource StringFormatConverter}, ConverterParameter='/ {0}'}" HorizontalAlignment="Right" FontSize="16"/>
                </Grid>

                <!-- Timeline Slider -->
                <Slider Grid.Row="1" Minimum="0" Maximum="100" Value="{Binding Progress, Mode=TwoWay}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Control Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,10">
                <Button Content="▶ Play" Command="{Binding PlayCommand}" 
                        FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" Background="Green" Foreground="White"/>
                <Button Content="⏸ Pause" Command="{Binding PauseCommand}" 
                        FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" Background="Orange" Foreground="White"/>
                <Button Content="⏹ Stop" Command="{Binding StopCommand}" 
                        FontFamily="{StaticResource RalewayFont}" FontWeight="Bold" Background="Red" Foreground="White"/>

                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center" Spacing="5">
                    <TextBlock Text="Kecepatan:" VerticalAlignment="Center" FontFamily="{StaticResource RalewayFont}" FontWeight="Bold"/>
                    <ComboBox SelectedIndex="1" Width="80">
                        <ComboBoxItem Content="0.5x"/>
                        <ComboBoxItem Content="1x"/>
                        <ComboBoxItem Content="2x"/>
                        <ComboBoxItem Content="5x"/>
                        <ComboBoxItem Content="10x"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
