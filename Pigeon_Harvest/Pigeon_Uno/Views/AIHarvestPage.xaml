<Page x:Class="Pigeon_Uno.Views.AIHarvestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Model" Style="{StaticResource TitleStyle}"/>

                        <TextBlock Text="ONNX model" Style="{StaticResource LabelStyle}"/>
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="yolov8n-agri.onnx"/>
                            <ComboBoxItem Content="yolov8n.onnx"/>
                            <ComboBoxItem Content="moonharvest-v2.onnx"/>
                            <ComboBoxItem Content="moonharvest-v1.onnx"/>
                        </ComboBox>

                        <TextBlock Text="Class file" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="classes-yolov8n-agri-basic.txt"/>

                        <TextBlock Text="Performance mode" Style="{StaticResource LabelStyle}"/>
                        <ComboBox SelectedIndex="0">
                            <ComboBoxItem Content="Fast (cepat, akurasi rendah)"/>
                            <ComboBoxItem Content="Balanced"/>
                            <ComboBoxItem Content="Accurate (lambat, akurasi tinggi)"/>
                        </ComboBox>

                        <TextBlock Text="Confidence threshold 35%" Style="{StaticResource LabelStyle}"/>
                        <Slider Minimum="0" Maximum="100" Value="35"/>

                        <TextBlock Text="NMS threshold 45%" Style="{StaticResource LabelStyle}"/>
                        <Slider Minimum="0" Maximum="100" Value="45"/>

                        <CheckBox Content="INT8 quantization (Android)" IsChecked="True"/>
                        <TextBlock Text="Mencegah bottleneck pada perangkat mid-range" Style="{StaticResource LabelStyle}" Margin="20,-6,0,0"/>
                        <CheckBox Content="Zero-Internet Edge AI" IsChecked="True"/>
                        <TextBlock Text="Inferensi sepenuhnya offline pada GCS lokal" Style="{StaticResource LabelStyle}" Margin="20,-6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Test Inference" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Jalankan model pada sample frame sebelum dipakai di misi." Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Run Test" Background="{ThemeResource PrimaryBrush}" Foreground="White" Padding="14,8"/>
                            <Button Content="Upload Frame" Padding="14,8"/>
                        </StackPanel>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="0,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="FPS" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="18" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="4,0,4,0">
                                <StackPanel>
                                    <TextBlock Text="Latency" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="54 ms" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Padding="8" CornerRadius="8" Background="{ThemeResource MutedBrush}" Margin="4,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Avg conf" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="92%" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource ForegroundBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status" Style="{StaticResource TitleStyle}"/>
                        <Grid>
                            <TextBlock Text="Model loaded" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="#332E7D32" BorderBrush="#662E7D32" BorderThickness="1" Padding="8,2" CornerRadius="5">
                                <TextBlock Text="Ready" FontSize="11" Foreground="#2E7D32"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Backend" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="#331976D2" BorderBrush="#661976D2" BorderThickness="1" Padding="8,2" CornerRadius="5">
                            <TextBlock Text="YOLOv8n · OpenCV preprocessing" FontSize="11" Foreground="#1976D2"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Classes" Style="{StaticResource LabelStyle}"/>
                            <Border HorizontalAlignment="Right" Background="{ThemeResource MutedBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="8,2" CornerRadius="5">
                                <TextBlock Text="14" FontSize="11" Foreground="{ThemeResource ForegroundBrush}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Class Labels" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <ItemsControl>
                            <ItemsControl.Items>
                                <x:String>Pest</x:String>
                                <x:String>Crop Stress</x:String>
                                <x:String>Dry Soil</x:String>
                                <x:String>Irrigation</x:String>
                                <x:String>Healthy</x:String>
                                <x:String>Weed</x:String>
                                <x:String>Disease</x:String>
                                <x:String>Yellowing</x:String>
                                <x:String>Wilting</x:String>
                                <x:String>Nutrient</x:String>
                                <x:String>Pest-eggs</x:String>
                                <x:String>Fungus</x:String>
                                <x:String>Lodging</x:String>
                                <x:String>Mature</x:String>
                            </ItemsControl.Items>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,6,6" Padding="8,4" CornerRadius="6" Background="#EEF9EE" BorderBrush="#C8E6C9" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontSize="12" Foreground="#2E7D32"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
