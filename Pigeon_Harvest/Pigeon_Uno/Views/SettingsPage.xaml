<Page x:Class="Pigeon_Uno.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource BackgroundBrush}">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{ThemeResource MutedForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{ThemeResource InputBrush}"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ToggleStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Status Pill Styles -->
        <SolidColorBrush x:Key="SuccessPillBg" Color="#332E7D32"/>
        <SolidColorBrush x:Key="SuccessPillBorder" Color="#662E7D32"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <!-- Drone Connection -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Drone Connection" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Protocol -->
                        <TextBlock Text="Protocol" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ProtocolCombo" Margin="0,0,0,12" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="UDP"/>
                            <ComboBoxItem Content="TCP"/>
                            <ComboBoxItem Content="Serial"/>
                        </ComboBox>

                        <!-- Host + Port -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Host" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="HostInput" Text="127.0.0.1" Style="{StaticResource FieldInputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="PortInput" Text="14550" Style="{StaticResource FieldInputStyle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Buttons + Status -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button x:Name="ConnectBtn" Content="Connect" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button x:Name="TestBtn" Content="Test" Style="{StaticResource OutlineButtonStyle}"/>
                            <Border Margin="8,0,0,0" Padding="12,8" CornerRadius="6" Background="{StaticResource SuccessPillBg}" BorderBrush="{StaticResource SuccessPillBorder}" BorderThickness="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{ThemeResource SuccessBrush}"/>
                                    <TextBlock Text="Connected" FontSize="12" Foreground="{ThemeResource SuccessBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Camera -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Camera" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Source -->
                        <TextBlock Text="Source" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="CameraSourceCombo" Margin="0,0,0,12" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="RTSP Stream"/>
                            <ComboBoxItem Content="USB Camera"/>
                            <ComboBoxItem Content="File"/>
                        </ComboBox>

                        <!-- URL -->
                        <TextBlock Text="URL" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="CameraUrlInput" Text="rtsp://192.168.1.20:8554/uav" Style="{StaticResource FieldInputStyle}"/>

                        <!-- Auto reconnect -->
                        <CheckBox x:Name="AutoReconnectCheck" Content="Auto reconnect" IsChecked="True" Margin="0,12,0,0" Style="{StaticResource ToggleStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <!-- Preferensi -->
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Preferensi" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Bahasa -->
                        <TextBlock Text="Bahasa" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="LanguageCombo" Margin="0,0,0,12" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Indonesia"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>

                        <!-- Unit -->
                        <TextBlock Text="Unit" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="UnitCombo" Margin="0,0,0,12" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Metric (m, m/s)"/>
                            <ComboBoxItem Content="Imperial (ft, mph)"/>
                        </ComboBox>

                        <!-- Tema -->
                        <TextBlock Text="Tema" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ThemeCombo" Margin="0,0,0,12" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Dark"/>
                            <ComboBoxItem Content="Auto"/>
                        </ComboBox>

                        <!-- Toggles -->
                        <CheckBox x:Name="HighContrastCheck" Content="High contrast (outdoor)" IsChecked="False" Margin="0,0,0,8"/>
                        <CheckBox x:Name="OfflineMapCheck" Content="Offline map cache" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="VoiceAlertCheck" Content="Voice alert" IsChecked="False" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AutoRTLCheck" Content="Auto Return-to-Home (battery &lt; 20%)" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ShowTooltipsCheck" Content="Show tooltips" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AnimationsCheck" Content="Enable animations" IsChecked="True" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Akun -->
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Akun" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Operator -->
                        <TextBlock Text="Operator" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="OperatorInput" Text="Fadli Saputra" Style="{StaticResource FieldInputStyle}" Margin="0,0,0,12"/>

                        <!-- Role -->
                        <TextBlock Text="Role" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="RoleCombo" Margin="0,0,0,12" SelectedIndex="1" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Petani"/>
                            <ComboBoxItem Content="Operator"/>
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Researcher"/>
                        </ComboBox>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button x:Name="SaveBtn" Content="Simpan" Style="{StaticResource PrimaryButtonStyle}"/>
                            <Button x:Name="ResetBtn" Content="Reset" Style="{StaticResource OutlineButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
