<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Pigeon_Uno.Views.DiagnosticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{ThemeResource DarkBackgroundColor}">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">
            <!-- Header -->
            <TextBlock Text="System Diagnostics"
                      Style="{StaticResource HeaderTextStyle}"
                      Margin="0,0,0,10"/>

            <!-- System Health -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="System Health"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                  Text="Overall Status:"
                                  Style="{StaticResource LabelTextStyle}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1"
                                   Orientation="Horizontal"
                                   Spacing="8">
                            <Ellipse x:Name="HealthIndicator"
                                    Width="16" Height="16"
                                    Fill="{ThemeResource SuccessColor}"/>
                            <TextBlock x:Name="HealthStatusText"
                                      Text="Good"
                                      Style="{StaticResource BodyTextStyle}"/>
                        </StackPanel>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                  Text="Last Check:"
                                  Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="LastCheckText"
                                  Grid.Row="1" Grid.Column="1"
                                  Text="--"
                                  Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                    
                    <Button Content="Refresh Health Status"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Click="RefreshHealth_Click"
                           HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- System Information -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="System Information"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App Version:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="AppVersionText" Grid.Row="0" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Platform:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="PlatformText" Grid.Row="1" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="OS Version:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="OsVersionText" Grid.Row="2" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Memory Usage:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="MemoryUsageText" Grid.Row="3" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="CPU Usage:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="CpuUsageText" Grid.Row="4" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Thread Count:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="ThreadCountText" Grid.Row="5" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Uptime:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="UptimeText" Grid.Row="6" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Performance Metrics -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Performance Metrics"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Average FPS:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="FpsText" Grid.Row="0" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Active Connections:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="ConnectionsText" Grid.Row="1" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Telemetry Rate:" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock x:Name="TelemetryRateText" Grid.Row="2" Grid.Column="1" Text="--" Style="{StaticResource BodyTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recent Errors -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Recent Errors"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <ListView x:Name="ErrorsListView"
                             Height="200"
                             Style="{StaticResource StandardListViewStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock Text="{Binding Timestamp}"
                                              Style="{StaticResource CaptionTextStyle}"/>
                                    <TextBlock Text="{Binding Message}"
                                              Style="{StaticResource BodyTextStyle}"
                                              TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Component}"
                                              Style="{StaticResource CaptionTextStyle}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    
                    <Button Content="Clear Error Log"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Click="ClearErrors_Click"
                           HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Log Management -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Log Management"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Diagnostic Report"
                               Style="{StaticResource AccentButtonStyle}"
                               Click="ExportDiagnostics_Click"/>
                        
                        <Button Content="Clear Old Logs"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Click="ClearOldLogs_Click"/>
                    </StackPanel>
                    
                    <TextBlock Text="Export will create a comprehensive diagnostic report including system info, errors, and recent logs"
                              Style="{StaticResource CaptionTextStyle}"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Debug Mode -->
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Debug Mode"
                              Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <CheckBox x:Name="DebugModeCheckBox"
                             Content="Enable Debug Mode"
                             Style="{StaticResource StandardCheckBoxStyle}"
                             Checked="DebugMode_Changed"
                             Unchecked="DebugMode_Changed"/>
                    
                    <TextBlock Text="Debug mode enables detailed logging and diagnostic information. May impact performance."
                              Style="{StaticResource CaptionTextStyle}"
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
