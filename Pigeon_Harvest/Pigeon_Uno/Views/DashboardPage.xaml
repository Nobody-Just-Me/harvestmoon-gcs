                            </Grid>
                            <ProgressBar x:Name="NdviCriticalBar" Minimum="0" Maximum="100" Value="0" Height="8" Foreground="#D32F2F" Background="#FEF2F2"/>
                            <Grid ColumnSpacing="8" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#ECFDF5" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="Avg NDVI" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="NdviAvgText" Text="0.00" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="Coverage" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="NdviCoverageText" Text="0 ha" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
