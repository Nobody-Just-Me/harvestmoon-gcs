<Page
    x:Class="Pigeon_Uno.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Pigeon_Uno.Controls"
    mc:Ignorable="d"
    Background="#F5FBF6">

    <Page.Resources>
        <!-- Card container (matching ui harvest Card: rounded-2xl border border-emerald-100) -->
        <Style x:Key="HarvestCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1E7D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <!-- Card header bar -->
        <Style x:Key="HarvestCardHeaderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5F3E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12"/>
        </Style>

        <!-- Pill styles per tone -->
        <Style x:Key="PillSuccessStyle" TargetType="Border">
            <Setter Property="Background" Value="#ECFDF5"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillInfoStyle" TargetType="Border">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillCriticalStyle" TargetType="Border">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FECACA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>
        <Style x:Key="PillWarningStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFBEB"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,3"/>
        </Style>

        <!-- HUD pill (dark) for video overlay -->
        <Style x:Key="HudPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#8C000000"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Outline button -->
        <Style x:Key="HarvestOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#166534"/>
            <Setter Property="BorderBrush" Value="#A7F3D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="HarvestPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Hud action button -->
        <Style x:Key="HudActionButton" TargetType="Button">
            <Setter Property="Background" Value="#8C000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="16,14,16,20" ColumnSpacing="12" RowSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ================ LEFT COLUMN ================ -->
            <StackPanel Grid.Column="0" Spacing="12">

                <!-- === Live Monitoring Card === -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8F4;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Live Monitoring · YOLO Crop Detection + Vegetation Overlay"
                                               FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Border x:Name="AiStatusPill" Style="{StaticResource PillSuccessStyle}">
                                        <TextBlock x:Name="AiStatusText" Text="AI ON" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Style="{StaticResource PillInfoStyle}">
                                        <TextBlock x:Name="DetectionCountText" Text="0 det" FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Body -->
                        <StackPanel Grid.Row="1" Padding="16" Spacing="12">
                            <!-- === Live Video (16:9) with overlays === -->
                            <Border CornerRadius="12" Background="#0F1F14" BorderBrush="#163021" BorderThickness="1">
                                <Grid Height="380" x:Name="VideoRoot">
                                    <!-- Actual live video (YOLO overlays drawn by VideoStreamControl) -->
                                    <controls:VideoStreamControl x:Name="DashboardVideoStream"/>

                                    <!-- Vegetation overlay (color wash) -->
                                    <Rectangle x:Name="VegetationOverlayLayer" Opacity="0.32" IsHitTestVisible="False">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#8C2E7D32" Offset="0"/>
                                                <GradientStop Color="#55FBC02D" Offset="0.55"/>
                                                <GradientStop Color="#66D32F2F" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Grid overlay -->
                                    <Canvas x:Name="GridOverlayCanvas" IsHitTestVisible="False" Opacity="0.3"/>

                                    <!-- Heatmap overlay (radial gradients) -->
                                    <Grid x:Name="HeatmapOverlayLayer" Visibility="Collapsed" IsHitTestVisible="False">
                                        <Ellipse Width="260" Height="260" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="120,60,0,0" Opacity="0.45">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFF0000" Offset="0"/>
                                                    <GradientStop Color="#00FF0000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="220" Height="220" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,40,140,0" Opacity="0.45">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#FFFFB400" Offset="0"/>
                                                    <GradientStop Color="#00FFB400" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Grid>

                                    <!-- Top HUD bar -->
                                    <Grid VerticalAlignment="Top" Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                    <Ellipse Width="6" Height="6" Fill="#EF4444" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="RecStatusText" Text="REC" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <TextBlock x:Name="FpsHudText" Text="YOLOv8 · standby" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}">
                                                <TextBlock x:Name="ConfAvgText" Text="Conf avg 0%" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource HudPillStyle}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE707;" FontSize="11" Foreground="White"/>
                                                <TextBlock x:Name="GpsHudText" Text="-6.91124, 107.61152" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Bottom HUD bar -->
                                    <Grid VerticalAlignment="Bottom" Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <Border Style="{StaticResource HudPillStyle}" HorizontalAlignment="Left">
                                                <TextBlock x:Name="AltSpdHudText" Text="ALT 0 m · SPD 0 m/s" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource HudPillStyle}" HorizontalAlignment="Left">
                                                <TextBlock x:Name="HdgModeText" Text="HDG 0° · MODE STANDBY" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                            <Button x:Name="RecordButton" Style="{StaticResource HudActionButton}" Click="RecordButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon x:Name="RecordIcon" Glyph="&#xE71A;" FontSize="12"/>
                                                    <TextBlock x:Name="RecordLabel" Text="Stop"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource HudActionButton}" Click="SnapshotButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE722;" FontSize="12"/>
                                                    <TextBlock Text="Snapshot"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource HudActionButton}" Click="PauseAiButton_Click">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon x:Name="PauseAiIcon" Glyph="&#xE769;" FontSize="12"/>
                                                    <TextBlock x:Name="PauseAiLabel" Text="Pause AI"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- IMU HUD (top-right below top bar) -->
                                    <StackPanel x:Name="ImuHudPanel" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,60,16,0" Spacing="4">
                                        <Border Width="84" Height="84" CornerRadius="42" Background="#66000000" BorderBrush="#30FFFFFF" BorderThickness="1">
                                            <Grid>
                                                <Grid x:Name="ImuRotationGrid" RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <RotateTransform x:Name="ImuRollTransform" Angle="0"/>
                                                    </Grid.RenderTransform>
                                                    <Grid x:Name="ImuPitchGrid">
                                                        <Grid.RenderTransform>
                                                            <TranslateTransform x:Name="ImuPitchTransform" Y="0"/>
                                                        </Grid.RenderTransform>
                                                        <Rectangle Height="42" VerticalAlignment="Top" Fill="#4FC3F7"/>
                                                        <Rectangle Height="42" VerticalAlignment="Bottom" Fill="#8D6E63"/>
                                                    </Grid>
                                                </Grid>
                                                <Rectangle Width="28" Height="1" Fill="#FACC15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <Border Background="#99000000" CornerRadius="6" Padding="6,2" HorizontalAlignment="Center">
                                            <TextBlock x:Name="ImuLabelText" Text="P0° R0° Y0°" Foreground="White" FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- === Live Map + Live Detections (2 columns) === -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Live Map -->
                                <Border Grid.Column="0" BorderBrush="#D1E7D5" BorderThickness="1" CornerRadius="12" Padding="10" Background="#FCFFFC">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Live Map · UAV Position" FontSize="12" Foreground="#4F6B5C"/>
                                            <Border Grid.Column="1" Style="{StaticResource PillInfoStyle}">
                                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <FontIcon Glyph="&#xE707;" FontSize="10" Foreground="#1D4ED8"/>
                                                    <TextBlock x:Name="HeadingPillText" Text="HDG 0°" FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Border Height="170" CornerRadius="8" BorderBrush="#CAE3D1" BorderThickness="1" Background="#EAF4EC">
                                            <controls:SkiaMapControl x:Name="DashboardMapControl"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Live Detections list -->
                                <Border Grid.Column="1" BorderBrush="#D1E7D5" BorderThickness="1" CornerRadius="12" Padding="10" Background="#FCFFFC">
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="DetectionsListTitle" Text="Live Detections (0)" FontSize="12" Foreground="#4F6B5C"/>
                                        <ScrollViewer Height="170" VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="DetectionsListStack" Spacing="4">
                                                <TextBlock x:Name="DetectionsEmptyText" Text="Tidak ada deteksi di atas threshold." FontSize="12" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === Row of 3: Overlay & AI Controls / Alert Center / Mission Log === -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Overlay & AI Controls -->
                    <Border Grid.Column="0" Style="{StaticResource HarvestCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8F4;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Overlay &amp; AI Controls" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Row="1" Padding="12" Spacing="6">
                                <ToggleSwitch x:Name="YoloToggleSwitch" Header="YOLO Bounding Box" IsOn="True" Toggled="YoloToggle_Toggled" MinWidth="0"/>
                                <TextBlock Text="ONNX Runtime · runtime swappable" FontSize="10" Foreground="#64766B" Margin="0,-4,0,4"/>
                                <ToggleSwitch x:Name="VegToggleSwitch" Header="Vegetation Overlay" IsOn="True" Toggled="VegToggle_Toggled"/>
                                <TextBlock Text="OpenCV color transform" FontSize="10" Foreground="#64766B" Margin="0,-4,0,4"/>
                                <ToggleSwitch x:Name="GridToggleSwitch" Header="Grid" IsOn="True" Toggled="GridToggle_Toggled"/>
                                <ToggleSwitch x:Name="HeatmapToggleSwitch" Header="Detection Heatmap" IsOn="False" Toggled="HeatmapToggle_Toggled"/>
                                <ToggleSwitch x:Name="ImuToggleSwitch" Header="IMU HUD" IsOn="True" Toggled="ImuToggle_Toggled"/>
                                <TextBlock Text="Pitch · roll · yaw" FontSize="10" Foreground="#64766B" Margin="0,-4,0,4"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Confidence threshold" FontSize="12" Foreground="#4F6B5C"/>
                                    <TextBlock Grid.Column="1" x:Name="ConfThresholdValue" Text="25%" FontSize="12" FontWeight="SemiBold" Foreground="#166534"/>
                                </Grid>
                                <Slider x:Name="ConfThresholdSlider" Minimum="10" Maximum="95" Value="25" ValueChanged="ConfThresholdSlider_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Alert Center -->
                    <Border Grid.Column="1" Style="{StaticResource HarvestCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#F59E0B"/>
                                    <TextBlock Text="Alert Center" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" Padding="12" MaxHeight="220">
                                <StackPanel x:Name="AlertsStack" Spacing="6"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Mission Log · Export -->
                    <Border Grid.Column="2" Style="{StaticResource HarvestCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="Mission Log · Export" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Row="1" Padding="12" Spacing="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mission ID" FontSize="12" Foreground="#64766B"/>
                                    <TextBlock Grid.Column="1" x:Name="MissionIdText" Text="MH-20260501-014" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Operator" FontSize="12" Foreground="#64766B"/>
                                    <TextBlock Grid.Column="1" Text="Operator Satu" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Started" FontSize="12" Foreground="#64766B"/>
                                    <TextBlock Grid.Column="1" x:Name="MissionStartedText" Text="--:--:--" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Detections" FontSize="12" Foreground="#64766B"/>
                                    <TextBlock Grid.Column="1" x:Name="MissionDetectionsText" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Telemetry log" FontSize="12" Foreground="#64766B"/>
                                    <TextBlock Grid.Column="1" x:Name="MissionFramesText" Text="0 frames" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </Grid>
                                <Grid ColumnSpacing="6" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource HarvestOutlineButton}" Click="ExportPdfButton_Click" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                            <TextBlock Text="PDF"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Style="{StaticResource HarvestOutlineButton}" Click="ExportCsvButton_Click" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                            <TextBlock Text="CSV"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Style="{StaticResource HarvestOutlineButton}" Click="ExportJsonButton_Click" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE896;" FontSize="11"/>
                                            <TextBlock Text="JSON"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ================ RIGHT COLUMN ================ -->
            <StackPanel Grid.Column="1" Spacing="12">

                <!-- MAVLink Telemetry -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Text="MAVLink Telemetry" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                                </StackPanel>
                                <Border Grid.Column="1" x:Name="MavLinkStatusPill" Style="{StaticResource PillSuccessStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE701;" FontSize="10" Foreground="#065F46"/>
                                        <TextBlock x:Name="MavLinkStatusText" Text="UDP 14550" FontSize="11" Foreground="#065F46" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE9A9;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Altitude" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryAltitudeText" Text="0 m" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE9A3;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Airspeed" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetrySpeedText" Text="0 m/s" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE81D;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Heading" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryHeadingText" Text="0°" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE704;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="GPS sats" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryGpsText" Text="0 · HDOP --" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE83E;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Battery" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryBatteryText" Text="0% · --" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="6" Background="#ECFDF5" Margin="0,0,8,0">
                                    <FontIcon Glyph="&#xE709;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Flight Mode" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="TelemetryModeText" Text="STANDBY" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="#E5F3E8" Margin="0,10,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mission Progress" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="MissionProgressText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </Grid>
                            <ProgressBar x:Name="MissionProgressBar" Minimum="0" Maximum="100" Value="0" Height="8" Foreground="#2E7D32" Background="#ECFDF5"/>
                            <Grid ColumnSpacing="6" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="WP" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="WaypointProgressText" Text="0/0" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="Elapsed" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MissionElapsedText" Text="00:00" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="6" Padding="6,4">
                                    <StackPanel>
                                        <TextBlock Text="ETA" FontSize="10" Foreground="#64766B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MissionEtaText" Text="--:--" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Analysis Summary -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8F4;" FontSize="14" Foreground="#2E7D32"/>
                                <TextBlock Text="Analysis Summary" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#FEF2F2" Margin="0,0,10,0">
                                    <FontIcon Glyph="&#xEC1F;" FontSize="14" Foreground="#D32F2F"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Pest" FontSize="13" Foreground="#0F3024" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="SummaryPestCount" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#FFFBEB" Margin="0,0,10,0">
                                    <FontIcon Glyph="&#xE790;" FontSize="14" Foreground="#B26B00"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Crop Stress" FontSize="13" Foreground="#0F3024" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="SummaryStressCount" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#EFF6FF" Margin="0,0,10,0">
                                    <FontIcon Glyph="&#xEA3E;" FontSize="14" Foreground="#1976D2"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Irrigation" FontSize="13" Foreground="#0F3024" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="SummaryIrrigationCount" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Background="#ECFDF5" Margin="0,0,10,0">
                                    <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="#2E7D32"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="Healthy" FontSize="13" Foreground="#0F3024" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" x:Name="SummaryHealthyCount" Text="0" FontSize="14" FontWeight="SemiBold" Foreground="#0F3024" VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="#E5F3E8" Margin="0,10,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Priority" FontSize="12" Foreground="#64766B" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="SummaryPriorityPill" Style="{StaticResource PillCriticalStyle}">
                                    <TextBlock x:Name="SummaryPriorityText" Text="Standby" FontSize="11" FontWeight="SemiBold" Foreground="#B91C1C"/>
                                </Border>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Confidence avg" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="SummaryConfidenceText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </Grid>
                            <Button Style="{StaticResource HarvestOutlineButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="GoCropAnalysisButton_Click">
                                <TextBlock Text="Lihat Detail Crop Analysis"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Vegetation Health NDVI -->
                <Border Style="{StaticResource HarvestCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource HarvestCardHeaderStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE81E;" FontSize="14" Foreground="#2E7D32"/>
                                <TextBlock Text="Vegetation Health (NDVI)" FontSize="13" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Row="1" Padding="14" Spacing="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Healthy" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="NdviHealthyText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
                            </Grid>
                            <ProgressBar x:Name="NdviHealthyBar" Minimum="0" Maximum="100" Value="0" Height="8" Foreground="#2E7D32" Background="#ECFDF5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Moderate" FontSize="12" Foreground="#64766B"/>
                                <TextBlock Grid.Column="1" x:Name="NdviModerateText" Text="0%" FontSize="12" FontWeight="SemiBold" Foreground="#0F3024"/>
